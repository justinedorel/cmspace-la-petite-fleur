---
import site from '../data/site.json';
---
<!DOCTYPE html>
<html lang="fr" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{site.seo_title}</title>
  <meta name="description" content={site.seo_description} />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&family=Playfair+Display:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">

  <!-- Config Tailwind avec couleurs custom AVANT le CDN -->
  <script define:vars={{ colorPrimary: site.color_primary, colorAccent: site.color_accent, colorBg: site.color_bg, colorCreaDark: site.color_cream_dark }} is:inline>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            forest: colorPrimary,
            'forest-light': colorPrimary,
            caramel: colorAccent,
            'caramel-light': colorAccent,
            cream: colorBg,
            'cream-dark': colorCreaDark,
          },
          fontFamily: {
            serif: ['Playfair Display', 'Georgia', 'serif'],
            sans: ['Inter', 'system-ui', 'sans-serif'],
          }
        }
      }
    }
  </script>
  <script is:inline src="https://cdn.tailwindcss.com"></script>
  <script is:inline src="https://unpkg.com/lucide@latest"></script>

  <style is:inline>
    ::-webkit-scrollbar { width: 8px; }
    ::-webkit-scrollbar-track { background: #FAF8F3; }
    ::-webkit-scrollbar-thumb { background: #1A2E26; border-radius: 4px; }
  </style>
</head>
<body class="font-sans bg-cream text-forest antialiased overflow-x-hidden selection:bg-caramel selection:text-white">
  <slot />
</body>
</html>
