---
const { title, description } = Astro.props;
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
    <meta property="og:type"    content="website" />
    <meta property="og:title"   content="{title}" />
    <meta property="og:locale"  content="fr_FR" />
    <meta name="twitter:card"   content="summary_large_image" />
  <meta name="description" content={description} />
  <script is:inline src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
  <script is:inline src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
  <style>
    body { font-family: 'Inter', sans-serif; background-color: #001a33; color: #e6f0ff; -webkit-font-smoothing: antialiased; }
    ::selection { background-color: #0a2d4d; color: #e6f0ff; }
    ::-webkit-scrollbar { width: 8px; }
    ::-webkit-scrollbar-track { background: #001a33; }
    ::-webkit-scrollbar-thumb { background: #0a2d4d; border-radius: 4px; }
    ::-webkit-scrollbar-thumb:hover { background: #0d3d66; }
  
    /* ─── Scroll reveal ──────────────────────────────────────── */
    .reveal, .reveal-left, .reveal-right {
      opacity: 0;
      transition: opacity 0.9s cubic-bezier(0.16,1,0.3,1), transform 0.9s cubic-bezier(0.16,1,0.3,1);
    }
    .reveal { transform: translateY(36px); }
    .reveal-left  { transform: translateX(-36px); }
    .reveal-right { transform: translateX(36px); }
    .reveal.visible, .reveal-left.visible, .reveal-right.visible { opacity:1; transform:none; }
    .reveal-d1 { transition-delay:0.08s; } .reveal-d2 { transition-delay:0.16s; }
    .reveal-d3 { transition-delay:0.24s; } .reveal-d4 { transition-delay:0.32s; }
    /* ─── Marquee ─────────────────────────────────────────────── */
    @keyframes marquee { from { transform:translateX(0); } to { transform:translateX(-50%); } }
    .marquee-track { display:flex; white-space:nowrap; animation:marquee 28s linear infinite; }
    /* ─── Parallax ────────────────────────────────────────────── */
    .hero-bg { will-change:transform; }
    /* ─── FAQ smooth ──────────────────────────────────────────── */
    .faq-answer-smooth { display:grid; grid-template-rows:0fr; transition:grid-template-rows 0.4s ease; }
    .faq-answer-smooth.open { grid-template-rows:1fr; }
    .faq-inner { overflow:hidden; }
    /* ─── Line animate ────────────────────────────────────────── */
    .line-grow { transform:scaleX(0); transform-origin:left;
      transition:transform 0.8s cubic-bezier(0.16,1,0.3,1) 0.2s; }
    .line-grow.visible { transform:scaleX(1); }
    /* ─── Portfolio hover ─────────────────────────────────────── */
    .portfolio-overlay { position:absolute; inset:0; background:rgba(0,0,0,0);
      transition:background 0.5s ease; display:flex; align-items:flex-end; padding:1.5rem; }
    .portfolio-card:hover .portfolio-overlay { background:rgba(0,0,0,0.5); }
    .portfolio-overlay-inner { transform:translateY(1rem); opacity:0;
      transition:transform 0.5s ease, opacity 0.5s ease; }
    .portfolio-card:hover .portfolio-overlay-inner { transform:translateY(0); opacity:1; }
    </style>
</head>
<body class="antialiased min-h-screen flex flex-col font-light">
  <slot />

  <script is:inline>
    // ── Scroll reveal ──────────────────────────────────────────────────
    (function() {
      var obs = new IntersectionObserver(function(entries) {
        entries.forEach(function(e) {
          if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
        });
      }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
      document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .line-grow').forEach(function(el) {
        obs.observe(el);
      });
    })();

    // ── Parallax hero ──────────────────────────────────────────────────
    (function() {
      var heroBg = document.querySelector('.hero-bg');
      if (!heroBg) return;
      var ticking = false;
      window.addEventListener('scroll', function() {
        if (!ticking) {
          requestAnimationFrame(function() {
            heroBg.style.transform = 'translateY(' + (window.scrollY * 0.32) + 'px)';
            ticking = false;
          });
          ticking = true;
        }
      }, { passive: true });
    })();

    // ── Compteurs animés ───────────────────────────────────────────────
    (function() {
      var statObs = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (!entry.isIntersecting) return;
          var el = entry.target;
          var target = parseInt(el.dataset.target);
          var suffix = el.dataset.suffix || '';
          if (isNaN(target)) return;
          var start = performance.now();
          (function tick(now) {
            var p = Math.min((now - start) / 1800, 1);
            var ease = 1 - Math.pow(1 - p, 4);
            el.textContent = Math.round(ease * target) + suffix;
            if (p < 1) requestAnimationFrame(tick);
          })(start);
          statObs.unobserve(el);
        });
      }, { threshold: 0.5 });
      document.querySelectorAll('.stat-counter').forEach(function(el) { statObs.observe(el); });
    })();
  </script>
</body>
</html>
