---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
---
<Base title={`Mentions légales — ${site.company_name}`} description="">
  <Header />
  <section class="py-20 bg-[#F9F7F2]">
    <div class="max-w-3xl mx-auto px-6">
      <h1 class="font-display text-4xl font-bold text-[#1C2B1C] mb-10">Mentions légales</h1>
      <div class="prose prose-sm text-[#6B7C6B] space-y-6">
        <div><h2 class="font-semibold text-[#1C2B1C] mb-2">Éditeur</h2><p>{site.company_name} — {site.address}</p><p>Email : {site.email}</p></div>
        <div><h2 class="font-semibold text-[#1C2B1C] mb-2">Hébergement</h2><p>Cloudflare, Inc. — 101 Townsend St, San Francisco, CA 94107, USA</p></div>
        <div><h2 class="font-semibold text-[#1C2B1C] mb-2">Données personnelles</h2><p>Les données collectées via le formulaire de contact sont utilisées uniquement pour répondre à vos demandes. Conformément au RGPD, vous disposez d'un droit d'accès, de rectification et de suppression.</p></div>
      </div>
    </div>
  </section>
  <Footer />
</Base>
