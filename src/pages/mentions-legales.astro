---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
---
<Base title={`Mentions légales — ${site.company_name}`} description={`Mentions légales de ${site.company_name}.`}>

  <Header />

  <section class="pt-32 pb-8" style="background-color:#FDFAF8;">
    <div class="max-w-6xl mx-auto px-6 md:px-8">
      <span class="font-body text-xs tracking-[0.22em] uppercase mb-4 block" style="color:#9E6B6B;">Légal</span>
      <h1 class="font-display text-5xl md:text-6xl font-medium" style="color:#1C1C1C;">Mentions légales</h1>
    </div>
  </section>

  <section class="py-16 pb-32" style="background-color:#FDFAF8;">
    <div class="max-w-3xl mx-auto px-6 md:px-8">

      <div class="mb-12">
        <div class="w-10 h-px mb-8" style="background-color:#EDE0DE;"></div>
        <h2 class="font-display text-2xl font-medium mb-6" style="color:#1C1C1C;">Éditeur du site</h2>
        <div class="flex flex-col gap-3">
          <p class="font-body text-sm" style="color:#9B8B8B;">
            <span style="color:#1C1C1C;">{site.legal_name || site.company_name}</span>
          </p>
          {site.legal_status && (
            <p class="font-body text-sm" style="color:#9B8B8B;">
              Forme juridique : <span style="color:#1C1C1C;">{site.legal_status}</span>
            </p>
          )}
          {site.siret && (
            <p class="font-body text-sm" style="color:#9B8B8B;">
              SIRET : <span style="color:#1C1C1C;">{site.siret}</span>
            </p>
          )}
          {site.address && (
            <p class="font-body text-sm" style="color:#9B8B8B;">
              Adresse : <span style="color:#1C1C1C;">{site.address}</span>
            </p>
          )}
          <p class="font-body text-sm" style="color:#9B8B8B;">
            Email : <a href={`mailto:${site.email}`} class="transition-opacity hover:opacity-70" style="color:#1C1C1C;">{site.email}</a>
          </p>
          {site.website && (
            <p class="font-body text-sm" style="color:#9B8B8B;">
              Site web : <a href={site.website} class="transition-opacity hover:opacity-70" style="color:#1C1C1C;">{site.website}</a>
            </p>
          )}
        </div>
      </div>

      <div class="mb-12">
        <div class="w-10 h-px mb-8" style="background-color:#EDE0DE;"></div>
        <h2 class="font-display text-2xl font-medium mb-6" style="color:#1C1C1C;">Hébergement</h2>
        <p class="font-body text-sm leading-relaxed" style="color:#9B8B8B;">
          Ce site est hébergé par Cloudflare, Inc., 101 Townsend St., San Francisco, CA 94107, États-Unis.
        </p>
      </div>

      <div class="mb-12">
        <div class="w-10 h-px mb-8" style="background-color:#EDE0DE;"></div>
        <h2 class="font-display text-2xl font-medium mb-6" style="color:#1C1C1C;">Propriété intellectuelle</h2>
        <p class="font-body text-sm leading-relaxed mb-4" style="color:#9B8B8B;">
          L'ensemble du contenu de ce site est la propriété exclusive de {site.legal_name || site.company_name}. Toute reproduction sans accord écrit préalable est interdite.
        </p>
      </div>

      <div class="mb-12">
        <div class="w-10 h-px mb-8" style="background-color:#EDE0DE;"></div>
        <h2 class="font-display text-2xl font-medium mb-6" style="color:#1C1C1C;">Données personnelles</h2>
        <p class="font-body text-sm leading-relaxed mb-4" style="color:#9B8B8B;">
          Conformément au RGPD, vous disposez d'un droit d'accès, de rectification et d'effacement de vos données. Pour exercer ces droits : <a href={`mailto:${site.email}`} class="transition-opacity hover:opacity-70" style="color:#9E6B6B;">{site.email}</a>
        </p>
      </div>

      <div class="mb-12">
        <div class="w-10 h-px mb-8" style="background-color:#EDE0DE;"></div>
        <h2 class="font-display text-2xl font-medium mb-6" style="color:#1C1C1C;">Cookies</h2>
        <p class="font-body text-sm leading-relaxed" style="color:#9B8B8B;">
          Ce site peut utiliser des cookies à des fins de mesure d'audience. Vous pouvez configurer votre navigateur pour les refuser.
        </p>
      </div>

      <div class="mt-16">
        <a href="/" class="inline-flex items-center gap-2 font-body text-sm transition-colors" style="color:#9E6B6B;"
          onmouseover="this.style.color='#1C1C1C'"
          onmouseout="this.style.color='#9E6B6B'">
          <span class="iconify" data-icon="lucide:arrow-left" data-width="14"></span>
          Retour à l'accueil
        </a>
      </div>

    </div>
  </section>

  <Footer />

</Base>
