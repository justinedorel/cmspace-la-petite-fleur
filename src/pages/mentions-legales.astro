---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
---
<Base title={`Mentions légales — ${site.company_name} Expertise`} noindex={true}>
  <Header />
  <main class="py-24 px-6 bg-[var(--color-bg)] min-h-[60vh]">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-3xl font-bold text-white mb-10">Mentions légales</h1>
      {[
        { title: 'Éditeur', content: [site.legal_name, site.legal_status, site.siret ? `SIRET : ${site.siret}` : '', site.address, site.email, site.phone].filter(Boolean) },
        { title: 'Profession réglementée', content: [`${site.legal_name} est un cabinet d'expertise comptable inscrit au tableau de l'Ordre des Experts-Comptables — Région Paris Île-de-France.`] },
        { title: 'Hébergement', content: ['Cloudflare Pages — Cloudflare, Inc., 101 Townsend St, San Francisco, CA 94107, USA'] },
        { title: 'Propriété intellectuelle', content: [`L'ensemble du contenu de ce site est la propriété exclusive de ${site.legal_name}.`] },
        { title: 'Données personnelles', content: [`Conformément au RGPD, vous pouvez exercer vos droits d'accès, de rectification et de suppression en contactant ${site.email}.`] },
      ].map(s => (
        <div class="mb-8">
          <h2 class="text-xl font-bold text-white mb-3">{s.title}</h2>
          {s.content.map(line => <p class="text-[var(--color-muted)] leading-relaxed">{line}</p>)}
        </div>
      ))}
    </div>
  </main>
  <Footer />
</Base>
