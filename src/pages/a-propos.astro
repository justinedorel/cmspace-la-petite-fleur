---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
---
<Base title={`À propos — ${site.company_name}`} description={`${site.about_text1}`}>

  <Header />

  <!-- Hero page -->
  <section class="pt-40 pb-20">
    <div class="max-w-7xl mx-auto px-8">
      <span class="font-sans text-xs tracking-[0.22em] uppercase text-gray-400 mb-4 block">{site.about_badge}</span>
      <h1 class="font-sans text-5xl md:text-7xl font-light text-white leading-tight mb-2">
        {site.about_title}
      </h1>
      <h1 class="font-sans text-5xl md:text-7xl font-light italic text-white leading-tight">
        {site.about_title2}
      </h1>
    </div>
  </section>

  <!-- About principal -->
  <section class="py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-8">
      <div class="grid md:grid-cols-2 gap-16 md:gap-24 items-center">
        <div class="relative">
          <img src={site.about_image} alt={site.about_title2} class="w-full aspect-[3/4] object-cover" />
          <div class="absolute -bottom-6 -right-6 w-32 h-32 bg-accent/20 hidden md:block"></div>
        </div>
        <div>
          <p class="font-sans text-sm font-light leading-relaxed text-gray-400 mb-6 tracking-wide">
            {site.about_text1}
          </p>
          <p class="font-sans text-sm font-light leading-relaxed text-gray-400 mb-10 tracking-wide">
            {site.about_text2}
          </p>
          <a href={`mailto:${site.email}`} class="inline-flex items-center gap-3 font-sans text-xs tracking-[0.18em] uppercase text-white hover:opacity-60 transition-opacity">
            {site.about_cta}
            <span class="iconify" data-icon="lucide:arrow-right" data-width="14"></span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Presse / Références -->
  <section class="py-12 bg-black">
    <div class="max-w-7xl mx-auto px-8">
      <div class="flex flex-col md:flex-row items-center gap-10 md:gap-16">
        <span class="font-sans text-xs tracking-[0.22em] uppercase text-white/30 whitespace-nowrap">{site.press_label}</span>
        <div class="w-px h-6 bg-white/20 hidden md:block"></div>
        <div class="flex items-center gap-10 md:gap-16 flex-wrap justify-center md:justify-start">
          <span class="font-sans text-2xl font-light italic tracking-wide text-white/60 hover:text-white/90 transition-colors cursor-default">{site.press1}</span>
          <span class="font-sans text-2xl font-light tracking-[0.15em] text-white/60 hover:text-white/90 transition-colors cursor-default">{site.press2}</span>
          <span class="font-sans text-2xl font-light italic tracking-wide text-white/60 hover:text-white/90 transition-colors cursor-default">{site.press3}</span>
          <span class="font-sans text-2xl font-light tracking-[0.15em] text-white/60 hover:text-white/90 transition-colors cursor-default">{site.press4}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Valeurs / Engagement -->
  <section class="py-28 md:py-36 bg-surface/20">
    <div class="max-w-7xl mx-auto px-8">
      <div class="text-center mb-20">
        <h2 class="font-sans text-4xl md:text-5xl font-light text-white mb-5">{site.process_title}</h2>
        <p class="font-sans text-sm font-light leading-relaxed text-gray-400 max-w-xl mx-auto tracking-wide">{site.process_subtitle}</p>
      </div>
      <div class="grid md:grid-cols-4 gap-10 md:gap-8">
        <div class="relative">
          <div class="font-sans text-8xl font-light text-sand leading-none mb-6 select-none">01</div>
          <div class="w-10 h-px bg-black/20 mb-6"></div>
          <h3 class="font-sans text-2xl font-light text-white mb-3">{site.step1_title}</h3>
          <p class="font-sans text-sm font-light leading-relaxed text-gray-400 tracking-wide">{site.step1_desc}</p>
        </div>
        <div class="relative">
          <div class="font-sans text-8xl font-light text-sand leading-none mb-6 select-none">02</div>
          <div class="w-10 h-px bg-black/20 mb-6"></div>
          <h3 class="font-sans text-2xl font-light text-white mb-3">{site.step2_title}</h3>
          <p class="font-sans text-sm font-light leading-relaxed text-gray-400 tracking-wide">{site.step2_desc}</p>
        </div>
        <div class="relative">
          <div class="font-sans text-8xl font-light text-sand leading-none mb-6 select-none">03</div>
          <div class="w-10 h-px bg-black/20 mb-6"></div>
          <h3 class="font-sans text-2xl font-light text-white mb-3">{site.step3_title}</h3>
          <p class="font-sans text-sm font-light leading-relaxed text-gray-400 tracking-wide">{site.step3_desc}</p>
        </div>
        <div class="relative">
          <div class="font-sans text-8xl font-light text-sand leading-none mb-6 select-none">04</div>
          <div class="w-10 h-px bg-black/20 mb-6"></div>
          <h3 class="font-sans text-2xl font-light text-white mb-3">{site.step4_title}</h3>
          <p class="font-sans text-sm font-light leading-relaxed text-gray-400 tracking-wide">{site.step4_desc}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Témoignage -->
  <section class="py-28 md:py-36 bg-black">
    <div class="max-w-5xl mx-auto px-8 text-center">
      <span class="iconify text-sand/40 mb-10 block mx-auto" data-icon="lucide:quote" data-width="40"></span>
      <blockquote class="font-sans text-3xl md:text-4xl font-light italic leading-relaxed text-white/90 mb-12">
        &ldquo;{site.testimonial_text}&rdquo;
      </blockquote>
      <div class="flex items-center justify-center gap-5">
        <img src={site.testimonial_image} alt={site.testimonial_name} class="w-12 h-12 rounded-full object-cover grayscale opacity-60" />
        <div class="text-left">
          <p class="font-sans text-base font-light text-white/80">{site.testimonial_name}</p>
          <p class="font-sans text-xs tracking-[0.15em] uppercase text-white/30">{site.testimonial_date}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA contact -->
  <section class="py-24">
    <div class="max-w-3xl mx-auto px-8 text-center">
      <h2 class="font-sans text-4xl md:text-5xl font-light text-white mb-6">{site.about_cta}</h2>
      <p class="font-sans text-sm font-light leading-relaxed text-gray-400 mb-10 tracking-wide">{site.tagline}</p>
      <a href="/contact" class="inline-flex items-center gap-3 font-sans text-xs tracking-[0.18em] uppercase text-white border border-dark/30 px-8 py-4 hover:bg-black hover:text-bg transition-all duration-300">
        {site.hero_cta}
        <span class="iconify" data-icon="lucide:arrow-right" data-width="14"></span>
      </a>
    </div>
  </section>

  <Footer />

</Base>
