---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
---
<Base title={`Le Salon — ${site.company_name}`} description={`Découvrez l'histoire d'${site.company_name}, ${site.company_sub} à Paris. Notre équipe passionnée vous accueille dans un cadre élégant et apaisant.`}>

  <Header />

  <!-- Hero page -->
  <section class="pt-32 pb-16" style="background-color:#FDFAF8;">
    <div class="max-w-6xl mx-auto px-6 md:px-8">
      <div class="max-w-2xl">
        <span class="font-body text-xs tracking-[0.22em] uppercase mb-4 block" style="color:#9E6B6B;">À propos</span>
        <h1 class="font-display text-5xl md:text-6xl font-medium leading-tight mb-6" style="color:#1C1C1C;">
          Notre histoire,<br />
          <em class="italic font-normal" style="color:#9E6B6B;">notre passion.</em>
        </h1>
        <p class="font-body text-base leading-relaxed" style="color:#9B8B8B;">
          ÉCLAT est né d'une conviction simple : chaque femme mérite un moment de beauté authentique, dans un cadre qui lui ressemble.
        </p>
      </div>
    </div>
  </section>

  <!-- Histoire du salon -->
  <section class="py-16 md:py-24" style="background-color:#F9F0EE;">
    <div class="max-w-6xl mx-auto px-6 md:px-8">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div class="relative">
          <div class="rounded-2xl overflow-hidden" style="aspect-ratio:4/5;">
            <img src={site.hero_image} alt="Le salon ÉCLAT" class="w-full h-full object-cover" loading="lazy" />
          </div>
          <div class="absolute -bottom-5 -right-5 w-24 h-24 rounded-full hidden md:block" style="background-color:#EDE0DE;z-index:-1;"></div>
        </div>
        <div>
          <h2 class="font-display text-3xl md:text-4xl font-medium mb-6" style="color:#1C1C1C;">Un salon pensé pour vous</h2>
          <p class="font-body text-base leading-relaxed mb-5" style="color:#9B8B8B;">
            Fondé en 2016 au cœur de Paris, ÉCLAT s'est imposé comme une référence en matière de soin des ongles. Chaque espace a été conçu pour que vous vous sentiez comme chez vous : lumière douce, parfums subtils, musique apaisante.
          </p>
          <p class="font-body text-base leading-relaxed mb-8" style="color:#9B8B8B;">
            Nous travaillons exclusivement avec des produits haut de gamme, respectueux de vos ongles naturels. Nos techniques évoluent au fil des tendances, mais notre philosophie reste la même : la beauté doit être durable et bienveillante.
          </p>
          <a href="/contact/"
            class="inline-flex items-center gap-2 font-body text-sm font-medium text-white px-6 py-3 rounded-xl transition-colors"
            style="background-color:#D4A5A5;"
            onmouseover="this.style.backgroundColor='#9E6B6B'"
            onmouseout="this.style.backgroundColor='#D4A5A5'">
            Prendre rendez-vous
            <span class="iconify" data-icon="lucide:arrow-right" data-width="14"></span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Valeurs -->
  <section class="py-16 md:py-24" style="background-color:#FDFAF8;">
    <div class="max-w-6xl mx-auto px-6 md:px-8">
      <div class="text-center mb-14">
        <h2 class="font-display text-3xl md:text-4xl font-medium" style="color:#1C1C1C;">Nos valeurs</h2>
        <p class="font-body text-base mt-3 max-w-lg mx-auto" style="color:#9B8B8B;">Ce qui guide chacun de nos gestes au quotidien.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        {[
          { icon: 'lucide:heart', title: 'Bienveillance', desc: 'Chaque cliente est unique. Nous prenons le temps d\'écouter vos envies et d\'adapter nos soins à vos besoins spécifiques.' },
          { icon: 'lucide:sparkles', title: 'Excellence', desc: 'Produits premium, techniques perfectionnées, finitions irréprochables. Nous ne faisons aucun compromis sur la qualité.' },
          { icon: 'lucide:leaf', title: 'Respect', desc: 'Produits sans substances nocives, gestes doux et respectueux de vos ongles naturels. La beauté ne doit pas se faire au détriment de la santé.' },
        ].map((v) => (
          <div class="text-center p-8 rounded-2xl border" style="border-color:#EDE0DE;background-color:#F9F0EE;">
            <div class="w-12 h-12 rounded-full flex items-center justify-center mx-auto mb-5" style="background-color:#D4A5A5;">
              <span class="iconify text-white" data-icon={v.icon} data-width="22"></span>
            </div>
            <h3 class="font-display text-xl font-medium mb-3" style="color:#1C1C1C;">{v.title}</h3>
            <p class="font-body text-sm leading-relaxed" style="color:#9B8B8B;">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Équipe -->
  <section class="py-16 md:py-24" style="background-color:#F9F0EE;">
    <div class="max-w-6xl mx-auto px-6 md:px-8">
      <div class="text-center mb-14">
        <h2 class="font-display text-3xl md:text-4xl font-medium" style="color:#1C1C1C;">Notre équipe</h2>
        <p class="font-body text-base mt-3 max-w-lg mx-auto" style="color:#9B8B8B;">Des passionnées au service de votre beauté.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        {[
          { name: 'Sophie Martin', role: 'Fondatrice & Nail Artist', desc: '10 ans d\'expérience, spécialiste pose gel et nail art créatif.', img: 'https://images.unsplash.com/photo-1494790108377-be9c29b29330?q=80&w=400&auto=format&fit=crop' },
          { name: 'Léa Bernard', role: 'Manucuriste', desc: 'Experte en pédicure spa et soins des mains naturels.', img: 'https://images.unsplash.com/photo-1438761681033-6461ffad8d80?q=80&w=400&auto=format&fit=crop' },
          { name: 'Clara Petit', role: 'Nail Artist', desc: 'Spécialiste nail art, motifs géométriques et effets chromés.', img: 'https://images.unsplash.com/photo-1489424731084-a5d8b219a5bb?q=80&w=400&auto=format&fit=crop' },
        ].map((m) => (
          <div class="text-center">
            <div class="w-32 h-32 rounded-full overflow-hidden mx-auto mb-5" style="border:3px solid #EDE0DE;">
              <img src={m.img} alt={m.name} class="w-full h-full object-cover" loading="lazy" />
            </div>
            <h3 class="font-display text-lg font-medium mb-1" style="color:#1C1C1C;">{m.name}</h3>
            <p class="font-body text-xs tracking-wide mb-3" style="color:#D4A5A5;">{m.role}</p>
            <p class="font-body text-sm leading-relaxed" style="color:#9B8B8B;">{m.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 text-center" style="background-color:#FDFAF8;">
    <div class="max-w-xl mx-auto px-6">
      <h2 class="font-display text-3xl md:text-4xl font-medium mb-4" style="color:#1C1C1C;">Venez nous rencontrer</h2>
      <p class="font-body text-base mb-8" style="color:#9B8B8B;">{site.tagline}</p>
      <a href="/contact/"
        class="inline-flex items-center gap-2 font-body text-sm font-medium text-white px-8 py-4 rounded-xl transition-colors"
        style="background-color:#D4A5A5;"
        onmouseover="this.style.backgroundColor='#9E6B6B'"
        onmouseout="this.style.backgroundColor='#D4A5A5'">
        {site.hero_cta}
        <span class="iconify" data-icon="lucide:arrow-right" data-width="14"></span>
      </a>
    </div>
  </section>

  <Footer />

</Base>
