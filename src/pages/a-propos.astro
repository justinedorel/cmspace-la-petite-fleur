---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
---
<Base title={`Le Studio — ${site.company_name}`} description={`${(site as any).about_text1}`}>

  <Header />

  <!-- Hero page -->
  <section class="pt-36 pb-16" style="background:#FAF8F5">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <p class="font-sans text-xs tracking-[0.28em] uppercase mb-4" style="color:#C4956A">À propos</p>
      <h1 class="font-serif text-5xl md:text-7xl font-light leading-tight mb-4" style="color:#1A1A1A">
        Le Studio
      </h1>
      <div style="width:3rem;height:1px;background:#C4956A"></div>
    </div>
  </section>

  <!-- Histoire + photo -->
  <section class="py-20 md:py-28" style="background:#FAF8F5">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="grid md:grid-cols-2 gap-16 md:gap-24 items-center">
        <div class="reveal-left overflow-hidden" style="aspect-ratio:3/4">
          <img src={(site as any).about_image} alt="Éstetica Studio" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div class="reveal-right">
          <p class="font-sans text-xs tracking-[0.28em] uppercase mb-6" style="color:#C4956A">Notre histoire</p>
          <h2 class="font-serif text-3xl md:text-4xl font-light mb-8" style="color:#1A1A1A">{(site as any).about_title}</h2>
          <div style="width:3rem;height:1px;background:#E8E0D8;margin-bottom:2rem"></div>
          <p class="font-sans text-sm font-light leading-[1.9] mb-5" style="color:#8A7E75">{(site as any).about_text1}</p>
          <p class="font-sans text-sm font-light leading-[1.9] mb-10" style="color:#8A7E75">{(site as any).about_text2}</p>
          <a href="/contact/" class="inline-flex items-center gap-3 font-sans text-xs tracking-[0.2em] uppercase transition-colors" style="color:#C4956A">
            Prendre rendez-vous
            <span class="iconify" data-icon="lucide:arrow-right" data-width="13"></span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Valeurs -->
  <section class="py-20 md:py-28" style="background:#F2EDE8">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="text-center mb-16 reveal">
        <p class="font-sans text-xs tracking-[0.28em] uppercase mb-4" style="color:#C4956A">Ce qui nous anime</p>
        <h2 class="font-serif text-4xl md:text-5xl font-light" style="color:#1A1A1A">Nos valeurs</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {[
          { num: '01', title: 'Excellence', desc: 'Nous n\'acceptons que le meilleur — dans nos techniques, nos produits et notre accueil.' },
          { num: '02', title: 'Personnalisation', desc: 'Chaque client est unique. Chaque soin est adapté à vos besoins spécifiques.' },
          { num: '03', title: 'Bienveillance', desc: 'Un cadre chaleureux et apaisant pour que vous vous sentiez pleinement à votre place.' },
          { num: '04', title: 'Innovation', desc: 'Formations régulières pour rester à la pointe des techniques et tendances beauté.' },
        ].map((v: any, i: number) => (
          <div class={`p-8 reveal reveal-d${i + 1}`} style="background:#FAF8F5;border:1px solid #E8E0D8">
            <p class="font-serif text-5xl font-light mb-5 select-none" style="color:#E8E0D8">{v.num}</p>
            <div style="width:2rem;height:1px;background:#C4956A;margin-bottom:1rem"></div>
            <h3 class="font-serif text-xl font-semibold mb-3" style="color:#1A1A1A">{v.title}</h3>
            <p class="font-sans text-sm font-light leading-relaxed" style="color:#8A7E75">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Témoignage -->
  <section class="py-20 md:py-28" style="background:#1A1A1A">
    <div class="max-w-3xl mx-auto px-6 md:px-8 text-center reveal">
      <div style="width:1px;height:3rem;background:rgba(255,255,255,0.2);margin:0 auto 2.5rem"></div>
      <blockquote class="font-serif text-2xl md:text-3xl font-light italic leading-relaxed mb-10" style="color:rgba(255,255,255,0.9)">
        &ldquo;{(site as any).review1_text}&rdquo;
      </blockquote>
      <p class="font-sans text-xs tracking-[0.2em] uppercase" style="color:rgba(255,255,255,0.5)">{(site as any).review1_name}</p>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20" style="background:#FAF8F5">
    <div class="max-w-3xl mx-auto px-6 md:px-8 text-center reveal">
      <h2 class="font-serif text-4xl md:text-5xl font-light mb-6" style="color:#1A1A1A">{site.tagline}</h2>
      <p class="font-sans text-sm font-light leading-relaxed mb-10" style="color:#8A7E75">{site.hero_subtitle}</p>
      <a href="/contact/" class="inline-flex items-center gap-3 font-sans text-xs tracking-[0.18em] uppercase px-8 py-4 transition-all duration-300"
        style="background:#C4956A;color:#fff">
        {site.hero_cta}
        <span class="iconify" data-icon="lucide:arrow-right" data-width="13"></span>
      </a>
    </div>
  </section>

  <Footer />

</Base>
