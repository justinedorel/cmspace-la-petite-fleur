---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
---
<Base title={`À propos — ${site.company_name} Expertise`} description={site.about_page_intro}>
  <Header />
  <main>

    <!-- Hero -->
    <section class="hero-grid px-6 pt-20 pb-16 bg-[var(--color-bg)]">
      <div class="max-w-4xl mx-auto text-center" data-animate>
        <span class="inline-flex items-center px-4 py-1.5 rounded-full bg-[var(--color-accent)]/15 border border-[var(--color-accent)]/30 text-[var(--color-accent2)] text-xs font-semibold tracking-wide mb-7">
          Notre histoire
        </span>
        <h1 class="text-5xl lg:text-6xl font-bold tracking-tight text-white leading-tight mb-7">{site.about_page_title}</h1>
        <p class="text-lg text-[var(--color-muted)] leading-relaxed max-w-2xl mx-auto">{site.about_page_intro}</p>
      </div>
    </section>

    <!-- Histoire -->
    <section class="px-6 py-20 bg-[var(--color-bg)]">
      <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-14 items-center">
        <div class="space-y-6" data-animate>
          <h2 class="text-3xl lg:text-4xl font-bold tracking-tight text-white">De la rigueur du chiffre à la stratégie d'entreprise</h2>
          <p class="text-[var(--color-muted)] leading-relaxed">{site.about_history}</p>
          <div class="flex flex-wrap gap-6 pt-2">
            <div>
              <div class="text-3xl font-bold text-white">{site.stat1_value}</div>
              <div class="text-sm text-[var(--color-muted)]">{site.stat1_label}</div>
            </div>
            <div>
              <div class="text-3xl font-bold text-white">{site.stat2_value}</div>
              <div class="text-sm text-[var(--color-muted)]">{site.stat2_label}</div>
            </div>
            <div>
              <div class="text-3xl font-bold text-white">{site.stat3_value}</div>
              <div class="text-sm text-[var(--color-muted)]">{site.stat3_label}</div>
            </div>
          </div>
        </div>
        <div class="bg-[var(--color-surface)] border border-white/[0.06] rounded-3xl p-9 space-y-6" data-animate>
          <div class="flex items-center gap-4">
            <span class="w-12 h-12 rounded-xl bg-[var(--color-accent)] flex items-center justify-center shrink-0">
              <iconify-icon icon="solar:calculator-minimalistic-bold" class="text-2xl text-white"></iconify-icon>
            </span>
            <div>
              <div class="text-lg font-bold text-white">{site.company_name} Expertise</div>
              <div class="text-xs tracking-[0.2em] text-[var(--color-muted)]">{site.company_sub}</div>
            </div>
          </div>
          <p class="text-sm text-[var(--color-muted)] leading-relaxed">
            Membre de l'Ordre des Experts-Comptables — Région Paris Île-de-France. Cabinet indépendant,
            assurance responsabilité civile professionnelle, déontologie stricte et secret professionnel garanti.
          </p>
          <div class="border-t border-white/[0.06] pt-5 flex items-center gap-3 text-sm text-white">
            <iconify-icon icon="solar:map-point-linear" class="text-[var(--color-accent2)] text-lg"></iconify-icon>
            {site.address}
          </div>
        </div>
      </div>
    </section>

    <!-- Équipe (claire) -->
    <section class="px-6 py-24 bg-[#F8FAFC]">
      <div class="max-w-7xl mx-auto">
        <div class="text-center max-w-2xl mx-auto mb-14" data-animate>
          <h2 class="text-4xl lg:text-5xl font-bold tracking-tight text-[#0F172A] mb-5">Trois associés, une exigence commune</h2>
          <p class="text-lg text-slate-500">Une équipe resserrée d'experts seniors, directement impliquée sur chaque dossier.</p>
        </div>
        <div class="grid md:grid-cols-3 gap-7">
          {site.team.map(m => (
            <div class="bg-white rounded-2xl shadow-lg shadow-slate-200/60 border border-slate-100 p-8 text-center" data-animate>
              <span class="w-20 h-20 rounded-full bg-[var(--color-accent)]/10 text-[var(--color-accent)] font-bold text-2xl flex items-center justify-center mx-auto mb-5">{m.initials}</span>
              <h3 class="text-lg font-bold text-[#0F172A]">{m.name}</h3>
              <div class="text-sm text-[var(--color-accent)] font-medium mb-4">{m.role}</div>
              <p class="text-sm text-slate-500 leading-relaxed">{m.bio}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Valeurs (dark) -->
    <section class="px-6 py-24 bg-[var(--color-bg)]">
      <div class="max-w-7xl mx-auto">
        <div class="text-center max-w-2xl mx-auto mb-14" data-animate>
          <h2 class="text-4xl lg:text-5xl font-bold tracking-tight text-white mb-5">Nos valeurs</h2>
          <p class="text-lg text-[var(--color-muted)]">Ce qui guide chacune de nos missions, du premier rendez-vous au bilan annuel.</p>
        </div>
        <div class="grid md:grid-cols-3 gap-7">
          {site.values.map(v => (
            <div class="bg-[var(--color-surface)] border border-white/[0.06] rounded-2xl p-8" data-animate>
              <div class="w-12 h-12 rounded-xl bg-[var(--color-accent)]/15 flex items-center justify-center mb-6">
                <iconify-icon icon={v.icon} class="text-2xl text-[var(--color-accent2)]"></iconify-icon>
              </div>
              <h3 class="text-xl font-bold text-white mb-3">{v.name}</h3>
              <p class="text-sm text-[var(--color-muted)] leading-relaxed">{v.desc}</p>
            </div>
          ))}
        </div>
        <div class="text-center mt-16" data-animate>
          <a href="/contact/"
            class="inline-flex items-center gap-2 bg-[var(--color-accent)] hover:bg-[var(--color-accent2)] text-white px-8 py-4 rounded-full font-semibold text-sm transition-all shadow-lg shadow-blue-600/25">
            Rencontrer le cabinet
            <iconify-icon icon="solar:arrow-right-linear" class="text-base"></iconify-icon>
          </a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Base>
