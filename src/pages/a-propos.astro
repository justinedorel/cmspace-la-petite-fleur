---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
---
<Base title={`À propos — ${site.company_name}`} description={site.seo_description}>
  <Header />

  <!-- Hero page -->
  <section class="bg-[#2D4A2D] py-20">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <p class="text-[#E8D5A3]/70 text-sm font-semibold tracking-widest uppercase mb-4">Notre histoire</p>
      <h1 class="font-display text-5xl font-bold text-white mb-4">À propos</h1>
      <p class="text-white/70 max-w-xl mx-auto leading-relaxed">Une exploitation familiale au service d'une agriculture locale et responsable.</p>
    </div>
  </section>

  <!-- Histoire + photo -->
  <section class="py-24 bg-[#F9F7F2]">
    <div class="max-w-6xl mx-auto px-6 grid lg:grid-cols-2 gap-16 items-center">
      <div class="rounded-2xl overflow-hidden shadow-lg h-96">
        <img src={site.about_image} alt="Le domaine" class="w-full h-full object-cover" />
      </div>
      <div>
        <h2 class="font-display text-3xl font-bold text-[#1C2B1C] mb-6">{site.about_title}</h2>
        <p class="text-[#6B7C6B] leading-relaxed mb-8">{site.about_text}</p>
        <div class="flex items-center gap-4">
          <a href="/contact/" class="bg-[#2D4A2D] text-[#E8D5A3] font-semibold px-6 py-3 rounded-full hover:bg-[#1C2B1C] transition-colors text-sm">
            Nous rendre visite
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Nos valeurs -->
  <section class="py-24 bg-[#EDE8DE]">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="font-display text-3xl font-bold text-[#1C2B1C]">Nos engagements</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        {[
          { t: site.value1_title, d: site.value1_desc },
          { t: site.value2_title, d: site.value2_desc },
          { t: site.value3_title, d: site.value3_desc },
        ].map((v, i) => (
          <div class="bg-white rounded-2xl p-8 shadow-sm">
            <div class="w-10 h-10 bg-[#2D4A2D] rounded-full flex items-center justify-center text-[#E8D5A3] font-bold text-sm mb-5">{i + 1}</div>
            <h3 class="font-display font-bold text-[#1C2B1C] text-xl mb-3">{v.t}</h3>
            <p class="text-[#6B7C6B] leading-relaxed text-sm">{v.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Base>
