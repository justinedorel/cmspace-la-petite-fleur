---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
---
<Base title={`À propos — ${site.company_name}`} description={`Découvrez l'histoire et les valeurs de ${site.company_name}.`}>

  <Header />

  <!-- PAGE HERO -->
  <section class="py-20 px-6 text-center bg-zinc-50">
    <div class="max-w-3xl mx-auto">
      <div class="inline-flex items-center gap-2 bg-indigo-50 text-accent rounded-full text-sm font-medium px-3 py-1 mb-6">
        <i data-lucide="users" class="w-3.5 h-3.5"></i>
        Notre histoire
      </div>
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight leading-tight mb-4">
        À propos de {site.company_name}
      </h1>
      <p class="text-zinc-500 text-lg max-w-2xl mx-auto leading-relaxed">
        {site.tagline}
      </p>
    </div>
  </section>

  <!-- MISSION -->
  <section class="py-24 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
        <div>
          <div class="text-6xl font-black text-accent leading-none mb-6">01</div>
          <h2 class="text-2xl font-extrabold text-zinc-900 mb-4">Notre mission</h2>
          <p class="text-zinc-500 leading-relaxed mb-4">
            {site.hero_desc}
          </p>
          <p class="text-zinc-500 leading-relaxed">
            Fondée sur la conviction que les équipes créatives méritent des outils à la hauteur de leur ambition, {site.company_name} repense entièrement la gestion de projet créatif.
          </p>
        </div>
        <div class="bg-zinc-950 rounded-2xl p-8">
          <div class="grid grid-cols-2 gap-6">
            <div class="text-center">
              <div class="text-3xl font-extrabold text-white mb-1">{site.hero_stat1_value}</div>
              <div class="text-zinc-500 text-xs">{site.hero_stat1_label}</div>
            </div>
            <div class="text-center">
              <div class="text-3xl font-extrabold text-white mb-1">{site.hero_stat2_value}</div>
              <div class="text-zinc-500 text-xs">{site.hero_stat2_label}</div>
            </div>
            <div class="text-center col-span-2">
              <div class="text-3xl font-extrabold text-accent mb-1">{site.hero_stat3_value}</div>
              <div class="text-zinc-500 text-xs">{site.hero_stat3_label}</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- VALEURS -->
  <section class="py-24 px-6 bg-zinc-50">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <div class="text-6xl font-black text-accent leading-none mb-4">02</div>
        <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight mb-4">Nos valeurs</h2>
        <p class="text-zinc-500 text-lg max-w-2xl mx-auto">Les principes qui guident chacune de nos décisions produit et chaque interaction avec nos clients.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="group p-6 rounded-2xl border border-zinc-100 bg-white hover:border-indigo-100 hover:bg-indigo-50/30 transition-all">
          <div class="bg-indigo-50 rounded-xl p-3 inline-flex mb-4 group-hover:bg-indigo-100 transition-colors">
            <i data-lucide="zap" class="w-5 h-5 text-accent"></i>
          </div>
          <h3 class="font-bold text-zinc-900 mb-2">Rapidité sans compromis</h3>
          <p class="text-zinc-500 text-sm leading-relaxed">Chaque fonctionnalité est pensée pour réduire la friction et accélérer votre workflow créatif.</p>
        </div>
        <div class="group p-6 rounded-2xl border border-zinc-100 bg-white hover:border-indigo-100 hover:bg-indigo-50/30 transition-all">
          <div class="bg-indigo-50 rounded-xl p-3 inline-flex mb-4 group-hover:bg-indigo-100 transition-colors">
            <i data-lucide="shield-check" class="w-5 h-5 text-accent"></i>
          </div>
          <h3 class="font-bold text-zinc-900 mb-2">Confiance et transparence</h3>
          <p class="text-zinc-500 text-sm leading-relaxed">Vos données vous appartiennent. Nous sommes conformes RGPD et transparents sur nos pratiques.</p>
        </div>
        <div class="group p-6 rounded-2xl border border-zinc-100 bg-white hover:border-indigo-100 hover:bg-indigo-50/30 transition-all">
          <div class="bg-indigo-50 rounded-xl p-3 inline-flex mb-4 group-hover:bg-indigo-100 transition-colors">
            <i data-lucide="heart" class="w-5 h-5 text-accent"></i>
          </div>
          <h3 class="font-bold text-zinc-900 mb-2">Centré sur l'humain</h3>
          <p class="text-zinc-500 text-sm leading-relaxed">Nous construisons pour les équipes, pas pour les tableaux de bord. L'expérience utilisateur est notre obsession.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ÉQUIPE -->
  <section class="py-24 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-16">
        <div class="text-6xl font-black text-accent leading-none mb-4">03</div>
        <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight mb-4">Une équipe passionnée</h2>
        <p class="text-zinc-500 text-lg max-w-2xl mx-auto">Des experts produit, design et ingénierie unis par une même conviction : simplifier la créativité collective.</p>
      </div>
      <div class="bg-zinc-950 rounded-2xl p-8 text-center">
        <p class="text-zinc-400 text-lg leading-relaxed max-w-2xl mx-auto mb-8">
          Envie de rejoindre l'aventure {site.company_name} ? Nous sommes toujours à la recherche de talents passionnés par les produits créatifs.
        </p>
        <a href="/contact" class="inline-flex items-center gap-2 bg-accent text-white font-semibold rounded-xl px-6 py-3 hover:opacity-90 transition-opacity">
          Nous contacter
          <i data-lucide="arrow-right" class="w-4 h-4"></i>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA SECTION -->
  <section class="py-24 px-6 bg-zinc-950">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight text-white mb-6">{site.cta_title}</h2>
      <p class="text-zinc-400 text-lg mb-10 leading-relaxed">{site.cta_desc}</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="/contact" class="bg-accent text-white font-semibold rounded-xl px-6 py-3 hover:opacity-90 transition-opacity shadow-lg shadow-indigo-900/50 flex items-center gap-2">
          {site.cta_primary}
          <i data-lucide="arrow-right" class="w-4 h-4"></i>
        </a>
        <a href="/contact" class="border border-white/20 text-white font-medium rounded-xl px-6 py-3 hover:bg-white/5 transition-colors flex items-center gap-2">
          <i data-lucide="message-circle" class="w-4 h-4"></i>
          {site.cta_secondary}
        </a>
      </div>
    </div>
  </section>

  <Footer />

  <style is:global>
    html { scroll-behavior: smooth; }
  </style>

</Base>
