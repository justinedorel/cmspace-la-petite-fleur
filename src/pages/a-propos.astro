---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
const paragraphs = site.about_text_long.split('\n').filter(Boolean);
const team = [
  { name: site.about_name1, role: site.about_role1, avatar: site.about_avatar1 },
  { name: site.about_name2, role: site.about_role2, avatar: site.about_avatar2 },
].filter(m => m.name);
const values = [
  { title: site.about_value1_title, desc: site.about_value1_desc },
  { title: site.about_value2_title, desc: site.about_value2_desc },
  { title: site.about_value3_title, desc: site.about_value3_desc },
].filter(v => v.title);
---
<Base title={`À propos — ${site.company_name}`} description={site.about_subtitle}>
  <Header />
  <main>
    <section class="pt-20 pb-16 px-6 bg-[var(--color-surface)]">
      <div class="max-w-7xl mx-auto" data-animate>
        <span class="text-xs font-semibold uppercase tracking-widest text-[var(--color-accent)]">Notre histoire</span>
        <h1 class="font-display text-5xl font-medium text-[var(--color-text)] mt-3 mb-4">{site.about_title}</h1>
        <p class="text-lg text-[var(--color-text-muted)] max-w-xl">{site.about_subtitle}</p>
      </div>
    </section>
    <section class="py-24 px-6">
      <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-start">
        <div data-animate>
          {paragraphs.map(p => <p class="text-[var(--color-text)] leading-relaxed mb-5">{p}</p>)}
        </div>
        <div class="h-80 bg-[var(--color-surface)] rounded-2xl overflow-hidden" data-animate="fade-left">
          {site.about_image_url && <img src={site.about_image_url} alt={site.company_name} class="w-full h-full object-cover" />}
        </div>
      </div>
    </section>
    {team.length > 0 && (
      <section class="py-16 px-6 bg-[var(--color-surface)]">
        <div class="max-w-7xl mx-auto">
          <h2 class="font-display text-3xl font-medium text-[var(--color-primary)] mb-10 text-center" data-animate>Notre équipe</h2>
          <div class="flex flex-wrap justify-center gap-8">
            {team.map(m => (
              <div class="text-center" data-animate>
                <div class="w-24 h-24 rounded-full bg-[var(--color-primary)]/10 mx-auto mb-4 overflow-hidden">
                  {m.avatar
                    ? <img src={m.avatar} alt={m.name} class="w-full h-full object-cover" />
                    : <div class="w-full h-full flex items-center justify-center font-display text-3xl text-[var(--color-primary)]">{m.name.charAt(0)}</div>
                  }
                </div>
                <div class="font-semibold text-[var(--color-primary)]">{m.name}</div>
                <div class="text-sm text-[var(--color-text-muted)]">{m.role}</div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}
    {values.length > 0 && (
      <section class="py-24 px-6">
        <div class="max-w-7xl mx-auto">
          <h2 class="font-display text-3xl font-medium text-[var(--color-primary)] mb-10 text-center" data-animate>Nos valeurs</h2>
          <div class="grid md:grid-cols-3 gap-6">
            {values.map((v, i) => (
              <div class="bg-[var(--color-surface)] rounded-2xl p-7 border-l-4 border-[var(--color-accent)]" data-animate style={`transition-delay: ${i * 100}ms`}>
                <h3 class="font-display text-xl font-medium text-[var(--color-primary)] mb-2">{v.title}</h3>
                <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{v.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}
  </main>
  <Footer />
</Base>
