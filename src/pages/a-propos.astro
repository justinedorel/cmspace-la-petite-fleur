---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
---
<Base title={`À propos — ${site.company_name}`} description={`Découvrez l'équipe et la philosophie de ${site.company_name}, votre Korean Head Spa à Paris.`}>

  <Header />

  <section class="pt-36 pb-16" style="background:#FAFAF7;">
    <div class="max-w-6xl mx-auto px-6">
      <p class="font-sans text-xs text-muted uppercase tracking-widest mb-4">À propos</p>
      <h1 class="font-serif text-4xl md:text-6xl font-light text-dark mb-4">{site.company_name}</h1>
      <p class="font-sans text-base text-muted max-w-2xl leading-relaxed">{site.tagline}</p>
    </div>
  </section>

  <section class="py-16" style="background:#F2F2ED;">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div class="reveal">
          <h2 class="font-serif text-3xl md:text-4xl font-light text-dark mb-6">Notre philosophie</h2>
          <p class="font-sans text-sm text-muted leading-relaxed mb-4">
            Inspirés par les rituels de soins coréens millénaires, nous avons créé un espace où la santé du cuir chevelu est traitée avec la même rigueur que celle du visage. Chaque séance commence par une analyse approfondie de votre cuir chevelu à l'aide de notre micro-caméra.
          </p>
          <p class="font-sans text-sm text-muted leading-relaxed mb-6">
            Nos thérapeutes, formés en Corée du Sud, maîtrisent l'art du massage acupression pour libérer les tensions et stimuler la circulation sanguine. Les résultats sont visibles dès la première séance.
          </p>
          <a href="/contact/" class="btn-accent inline-flex items-center gap-3 px-6 py-3 text-sm font-sans">
            Prendre rendez-vous
            <span class="iconify" data-icon="lucide:arrow-right" data-width="14"></span>
          </a>
        </div>
        <div class="reveal reveal-d1">
          <img src="https://images.unsplash.com/photo-1522337660859-02fbefca6088?q=80&w=800&auto=format&fit=crop" alt="Soin coréen" class="w-full aspect-[3/4] object-cover" />
        </div>
      </div>
    </div>
  </section>

  <section class="py-16" style="background:#FAFAF7;">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-14 reveal">
        <h2 class="font-serif text-3xl md:text-4xl font-light text-dark">Notre équipe</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center reveal reveal-d1">
          <img src={site.team1_image} alt={site.team1_name} class="w-48 h-48 rounded-full object-cover mx-auto mb-4 grayscale hover:grayscale-0 transition-all duration-500" />
          <h3 class="font-serif text-xl font-light text-dark mb-1">{site.team1_name}</h3>
          <p class="font-sans text-xs text-muted">{site.team1_role}</p>
        </div>
        <div class="text-center reveal reveal-d2">
          <img src={site.team2_image} alt={site.team2_name} class="w-48 h-48 rounded-full object-cover mx-auto mb-4 grayscale hover:grayscale-0 transition-all duration-500" />
          <h3 class="font-serif text-xl font-light text-dark mb-1">{site.team2_name}</h3>
          <p class="font-sans text-xs text-muted">{site.team2_role}</p>
        </div>
        <div class="text-center reveal reveal-d3">
          <img src={site.team3_image} alt={site.team3_name} class="w-48 h-48 rounded-full object-cover mx-auto mb-4 grayscale hover:grayscale-0 transition-all duration-500" />
          <h3 class="font-serif text-xl font-light text-dark mb-1">{site.team3_name}</h3>
          <p class="font-sans text-xs text-muted">{site.team3_role}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 text-center" style="background:#5C7A5C;">
    <div class="max-w-2xl mx-auto px-6 reveal">
      <h2 class="font-serif text-3xl font-light text-white mb-4">Vivez l'expérience Calm & Cozy</h2>
      <p class="font-sans text-sm text-white/70 mb-8">Disponible Lun–Dim. {site.hours_week}</p>
      <a href="/contact/" class="inline-flex items-center gap-3 px-8 py-4 text-sm font-sans text-dark font-medium bg-white hover:bg-white/90 transition-colors">
        {site.hero_cta}
        <span class="iconify" data-icon="lucide:arrow-right" data-width="14"></span>
      </a>
    </div>
  </section>

  <Footer />

</Base>
