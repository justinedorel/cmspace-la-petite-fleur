---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
---
<Base title={`Services — ${site.company_name}`} description={`Découvrez tous nos services : cosmétologie avancée, manucure japonaise et soins ongles à Paris. ${site.seo_description}`}>

  <Header />

  <!-- Hero page -->
  <section class="pt-36 pb-16" style="background:#FAF8F5">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <p class="font-sans text-xs tracking-[0.28em] uppercase mb-4" style="color:#C4956A">Ce que nous proposons</p>
      <h1 class="font-serif text-5xl md:text-7xl font-light leading-tight mb-4" style="color:#1A1A1A">
        Nos Services
      </h1>
      <div style="width:3rem;height:1px;background:#C4956A"></div>
    </div>
  </section>

  <!-- Section Cosmétologie -->
  <section class="py-20 md:py-28" style="background:#FAF8F5">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="mb-14 reveal">
        <p class="font-sans text-xs tracking-[0.28em] uppercase mb-4" style="color:#C4956A">Soins du visage</p>
        <h2 class="font-serif text-3xl md:text-4xl font-light" style="color:#1A1A1A">Cosmétologie</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {[
          { name: (site as any).service1_name, img: (site as any).service1_image, desc: 'Entretien personnalisé pour évaluer votre peau et définir le protocole adapté.' },
          { name: (site as any).service2_name, img: (site as any).service2_image, desc: 'Soin profond éliminant impuretés, points noirs et cellules mortes pour une peau purifiée.' },
          { name: (site as any).service3_name, img: (site as any).service3_image, desc: 'Protocoles sur-mesure en plusieurs séances pour des résultats visibles et durables.' },
          { name: (site as any).service4_name, img: (site as any).service4_image, desc: 'Exfoliants chimiques adaptés pour renouveler la peau et unifier le teint.' },
          { name: (site as any).service5_name, img: (site as any).service5_image, desc: 'Perçage professionnel avec matériel stérile, dans des conditions d\'hygiène optimales.' },
          { name: (site as any).service6_name, img: (site as any).service6_image, desc: 'Traitement ciblé anti-imperfections pour les peaux sujettes à l\'acné.' },
        ].map((s: any, i: number) => (
          <div class={`group reveal reveal-d${(i % 3) + 1}`} style="background:#F2EDE8;border:1px solid #E8E0D8">
            <div class="overflow-hidden" style="aspect-ratio:4/3">
              <img src={s.img} alt={s.name}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
            </div>
            <div class="p-6">
              <h3 class="font-serif text-xl font-light mb-3" style="color:#1A1A1A">{s.name}</h3>
              <p class="font-sans text-sm font-light leading-relaxed" style="color:#8A7E75">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Section Ongles -->
  <section class="py-20 md:py-28" style="background:#F2EDE8">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="mb-14 reveal">
        <p class="font-sans text-xs tracking-[0.28em] uppercase mb-4" style="color:#C4956A">Soins des mains</p>
        <h2 class="font-serif text-3xl md:text-4xl font-light" style="color:#1A1A1A">Ongles</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {[
          { name: (site as any).featured_name, img: (site as any).featured_image, desc: (site as any).featured_desc, price: (site as any).featured_price, duration: (site as any).featured_duration },
          { name: 'Manucure Classique', img: (site as any).service5_image, desc: 'Soin complet des mains : lime, cuticules, hydratation et vernis au choix.', price: 'À partir de 25€', duration: '45 min' },
          { name: 'Pose Gel & Semi-permanent', img: (site as any).service1_image, desc: 'Couleur longue durée (3 semaines) sans abîmer l\'ongle naturel.', price: 'À partir de 45€', duration: '1h' },
        ].map((s: any, i: number) => (
          <div class={`group reveal reveal-d${i + 1}`} style="background:#FAF8F5;border:1px solid #E8E0D8">
            <div class="overflow-hidden" style="aspect-ratio:4/3">
              <img src={s.img} alt={s.name}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
            </div>
            <div class="p-6">
              <h3 class="font-serif text-xl font-light mb-3" style="color:#1A1A1A">{s.name}</h3>
              <p class="font-sans text-sm font-light leading-relaxed mb-4" style="color:#8A7E75">{s.desc}</p>
              <div class="flex gap-6">
                {s.duration && <span class="font-sans text-xs tracking-[0.15em] uppercase" style="color:#C4956A">{s.duration}</span>}
                {s.price && <span class="font-sans text-xs tracking-[0.15em] uppercase font-medium" style="color:#1A1A1A">{s.price}</span>}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20" style="background:#C4956A">
    <div class="max-w-3xl mx-auto px-6 md:px-8 text-center reveal">
      <h2 class="font-serif text-4xl md:text-5xl font-light mb-8" style="color:#fff">{site.hero_cta}</h2>
      <a href="/contact/" class="inline-flex items-center gap-3 font-sans text-xs tracking-[0.2em] uppercase px-10 py-4 transition-all duration-300"
        style="background:#fff;color:#C4956A">
        Réserver maintenant
        <span class="iconify" data-icon="lucide:arrow-right" data-width="13"></span>
      </a>
    </div>
  </section>

  <Footer />

</Base>
