---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
---
<Base title={"Nos Cours — " + site.seo_title} description={site.experience_subtitle}>

  <Header />

  <section class="relative pt-40 pb-20 px-6 bg-[#F7F5F0]">
    <div class="max-w-3xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 mb-6 px-4 py-2 rounded-full bg-[#8A9A8B]/10 text-[#8A9A8B] text-xs font-medium tracking-wide uppercase">
        <span class="iconify" data-icon="lucide:sparkles" data-width="13"></span>
        Parcours & disciplines
      </div>
      <h1 class="font-playfair text-4xl md:text-6xl font-medium text-[#2F3E35] leading-[1.15] mb-6">
        {site.experience_title}
      </h1>
      <p class="text-[#2F3E35]/60 text-lg font-light mb-8 max-w-xl mx-auto leading-relaxed">
        {site.experience_subtitle}
      </p>
      <a href="/contact" class="inline-flex items-center justify-center gap-2 bg-[#8A9A8B] text-white font-semibold rounded-full px-8 py-4 hover:bg-[#6e7e6f] transition-colors">
        <span class="iconify" data-icon="lucide:calendar" data-width="16"></span>
        Réserver un cours
      </a>
    </div>
  </section>

  <section class="py-20 px-6 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-3 gap-8">

        <div class="group rounded-3xl overflow-hidden bg-[#F7F5F0] border border-[#8A9A8B]/15 hover:shadow-xl transition-all duration-500 hover:-translate-y-1">
          <div class="relative h-56 overflow-hidden">
            <img src={site.pathway1_image} alt={site.pathway1_title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#2F3E35]/40 to-transparent"></div>
            <div class="absolute top-4 right-4 w-10 h-10 rounded-full bg-white/20 backdrop-blur-md flex items-center justify-center">
              <span class="iconify text-white" data-icon="lucide:activity" data-width="18"></span>
            </div>
          </div>
          <div class="p-8">
            <h2 class="font-playfair text-2xl font-medium text-[#2F3E35] mb-3">{site.pathway1_title}</h2>
            <p class="text-[#2F3E35]/60 text-sm font-light leading-relaxed mb-5">{site.pathway1_desc}</p>
            <div class="flex items-center justify-between mb-6">
              <span class="text-xs text-[#8A9A8B] font-medium">{site.pathway1_tags}</span>
              <span class="text-xs text-[#2F3E35]/50 bg-white px-3 py-1 rounded-full border border-[#8A9A8B]/20">{site.pathway1_duration}</span>
            </div>
            <a href="/contact" class="block text-center text-sm font-semibold text-[#8A9A8B] border border-[#8A9A8B]/40 rounded-full px-6 py-3 hover:bg-[#8A9A8B] hover:text-white transition-colors">
              Réserver ce parcours
            </a>
          </div>
        </div>

        <div class="group rounded-3xl overflow-hidden bg-[#F7F5F0] border border-[#8A9A8B]/15 hover:shadow-xl transition-all duration-500 hover:-translate-y-1">
          <div class="relative h-56 overflow-hidden">
            <img src={site.pathway2_image} alt={site.pathway2_title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#2F3E35]/40 to-transparent"></div>
            <div class="absolute top-4 right-4 w-10 h-10 rounded-full bg-white/20 backdrop-blur-md flex items-center justify-center">
              <span class="iconify text-white" data-icon="lucide:moon" data-width="18"></span>
            </div>
          </div>
          <div class="p-8">
            <h2 class="font-playfair text-2xl font-medium text-[#2F3E35] mb-3">{site.pathway2_title}</h2>
            <p class="text-[#2F3E35]/60 text-sm font-light leading-relaxed mb-5">{site.pathway2_desc}</p>
            <div class="flex items-center justify-between mb-6">
              <span class="text-xs text-[#8A9A8B] font-medium">{site.pathway2_tags}</span>
              <span class="text-xs text-[#2F3E35]/50 bg-white px-3 py-1 rounded-full border border-[#8A9A8B]/20">{site.pathway2_duration}</span>
            </div>
            <a href="/contact" class="block text-center text-sm font-semibold text-[#8A9A8B] border border-[#8A9A8B]/40 rounded-full px-6 py-3 hover:bg-[#8A9A8B] hover:text-white transition-colors">
              Réserver ce parcours
            </a>
          </div>
        </div>

        <div class="group rounded-3xl overflow-hidden bg-[#F7F5F0] border border-[#8A9A8B]/15 hover:shadow-xl transition-all duration-500 hover:-translate-y-1">
          <div class="relative h-56 overflow-hidden">
            <img src={site.pathway3_image} alt={site.pathway3_title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#2F3E35]/40 to-transparent"></div>
            <div class="absolute top-4 right-4 w-10 h-10 rounded-full bg-white/20 backdrop-blur-md flex items-center justify-center">
              <span class="iconify text-white" data-icon="lucide:waves" data-width="18"></span>
            </div>
          </div>
          <div class="p-8">
            <h2 class="font-playfair text-2xl font-medium text-[#2F3E35] mb-3">{site.pathway3_title}</h2>
            <p class="text-[#2F3E35]/60 text-sm font-light leading-relaxed mb-5">{site.pathway3_desc}</p>
            <div class="flex items-center justify-between mb-6">
              <span class="text-xs text-[#8A9A8B] font-medium">{site.pathway3_tags}</span>
              <span class="text-xs text-[#2F3E35]/50 bg-white px-3 py-1 rounded-full border border-[#8A9A8B]/20">{site.pathway3_duration}</span>
            </div>
            <a href="/contact" class="block text-center text-sm font-semibold text-[#8A9A8B] border border-[#8A9A8B]/40 rounded-full px-6 py-3 hover:bg-[#8A9A8B] hover:text-white transition-colors">
              Réserver ce parcours
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="py-20 px-6 bg-[#F7F5F0]">
    <div class="max-w-6xl mx-auto">
      <h2 class="font-playfair text-3xl font-medium text-[#2F3E35] mb-8">Prochain cours</h2>

      <div class="rounded-3xl overflow-hidden bg-white border border-[#8A9A8B]/20 shadow-lg grid md:grid-cols-2">
        <div class="relative min-h-[320px]">
          <img src={site.hero_image} alt={site.class_featured_title} class="absolute inset-0 w-full h-full object-cover" />
          <div class="absolute inset-0 bg-gradient-to-r from-transparent to-[#2F3E35]/30"></div>
        </div>

        <div class="p-10 flex flex-col justify-center">
          <div class="flex items-center gap-3 mb-6">
            <div class="flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-red-50 border border-red-200">
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-red-500"></span>
              </span>
              <span class="text-xs font-medium text-red-600">Démarre bientôt</span>
            </div>
            <div class="flex items-center gap-2 text-[#2F3E35]/70 text-sm font-medium">
              <span class="iconify" data-icon="lucide:clock" data-width="15"></span>
              {site.class_featured_time}
            </div>
          </div>

          <h3 class="font-playfair text-3xl font-medium text-[#2F3E35] mb-4 leading-tight">
            {site.class_featured_title}
          </h3>

          <div class="flex flex-col gap-2 mb-8">
            <div class="flex items-center gap-2 text-sm text-[#2F3E35]/70">
              <span class="iconify text-[#8A9A8B]" data-icon="lucide:user" data-width="15"></span>
              {site.class_featured_instructor}
            </div>
            <div class="flex items-center gap-2 text-sm text-[#2F3E35]/70">
              <span class="iconify text-[#8A9A8B]" data-icon="lucide:flame" data-width="15"></span>
              Intensité : {site.class_featured_intensity}
            </div>
            <div class="flex items-center gap-2 text-sm text-[#2F3E35]/70">
              <span class="iconify text-[#8A9A8B]" data-icon="lucide:focus" data-width="15"></span>
              Focus : {site.class_featured_focus}
            </div>
          </div>

          <a href="/contact" class="inline-flex items-center justify-center gap-2 bg-[#2F3E35] text-white font-semibold rounded-full px-8 py-4 hover:bg-[#1a2420] transition-colors mb-4 text-sm">
            <span class="iconify" data-icon="lucide:calendar-check" data-width="16"></span>
            Réserver ma place
          </a>

          <p class="text-xs text-[#2F3E35]/50 font-light leading-relaxed">
            {site.class_featured_note}
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 px-6 bg-[#2F3E35]">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-playfair text-3xl md:text-4xl font-medium text-white mb-4">
        Prêt·e à commencer votre voyage ?
      </h2>
      <p class="text-white/60 text-base font-light mb-8 leading-relaxed">
        {site.hero_bullet1} — {site.hero_bullet2}
      </p>
      <a href="/contact" class="inline-flex items-center justify-center gap-2 bg-[#8A9A8B] text-white font-semibold rounded-full px-8 py-4 hover:bg-[#6e7e6f] transition-colors">
        <span class="iconify" data-icon="lucide:sparkles" data-width="16"></span>
        {site.hero_cta}
      </a>
    </div>
  </section>

  <Footer />

</Base>
