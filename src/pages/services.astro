---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
const services = [
  { title: site.service1_title, desc: site.service1_desc, details: [site.service1_detail1, site.service1_detail2, site.service1_detail3] },
  { title: site.service2_title, desc: site.service2_desc, details: [site.service2_detail1, site.service2_detail2, site.service2_detail3] },
  { title: site.service3_title, desc: site.service3_desc, details: [site.service3_detail1, site.service3_detail2, site.service3_detail3] },
];
---
<Base title={`Nos services — ${site.company_name}`} description={site.services_subtitle}>
  <Header />

  <section style="background:var(--colorSurface);padding:4rem 0 3rem;">
    <div class="container">
      <span class="section-label">Expertise</span>
      <h1 class="section-title">{site.services_title}</h1>
      <p class="section-subtitle">{site.services_subtitle}</p>
    </div>
  </section>

  <section>
    <div class="container" style="display:flex;flex-direction:column;gap:4rem;">
      {services.map((s, i) => (
        <div style={`display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center;${i % 2 === 1 ? 'direction:rtl;' : ''}`}>
          <div style={i % 2 === 1 ? 'direction:ltr;' : ''}>
            <span class="section-label">Service {i + 1}</span>
            <h2 style="font-size:1.75rem;color:var(--colorPrimary);margin-bottom:1rem;">{s.title}</h2>
            <p style="color:var(--colorTextMuted);margin-bottom:1.5rem;line-height:1.7;">{s.desc}</p>
            <ul style="list-style:none;display:flex;flex-direction:column;gap:0.75rem;">
              {s.details.filter(Boolean).map(d => (
                <li style="display:flex;align-items:flex-start;gap:0.75rem;">
                  <span style="color:var(--colorAccent);font-weight:700;font-size:1.1rem;line-height:1;">✓</span>
                  <span style="color:var(--colorText);">{d}</span>
                </li>
              ))}
            </ul>
            <div style="margin-top:2rem;">
              <a href="/contact" class="btn-primary">Demander un devis</a>
            </div>
          </div>
          <div style={`background:var(--colorSurface);border-radius:1rem;aspect-ratio:4/3;${i % 2 === 1 ? 'direction:ltr;' : ''}`}></div>
        </div>
      ))}
    </div>
  </section>

  <section style="background:var(--colorPrimary);color:#fff;">
    <div class="container" style="text-align:center;">
      <h2 style="font-size:2rem;margin-bottom:1rem;">{site.cta_title}</h2>
      <p style="opacity:0.8;margin-bottom:2rem;">{site.cta_subtitle}</p>
      <a href="/contact" style="background:#fff;color:var(--colorPrimary);padding:0.875rem 2rem;border-radius:0.5rem;font-weight:700;display:inline-block;">
        {site.cta_primary}
      </a>
    </div>
  </section>

  <Footer />
</Base>
