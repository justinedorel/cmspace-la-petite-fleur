---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
const details = [
  {
    intro: "Le socle de toute entreprise saine : une comptabilité tenue avec rigueur, des obligations sociales maîtrisées et des comptes toujours prêts pour vos décisions comme pour l'administration.",
    points: [
      "Saisie, lettrage et révision de l'ensemble de vos flux comptables",
      "Production des bulletins de paie et gestion des déclarations sociales",
      "Établissement et télétransmission de vos déclarations de TVA",
      "Accompagnement complet à la création : statuts, immatriculation, prévisionnel",
    ],
  },
  {
    intro: "Notre cœur d'expertise : analyser votre structure, votre rémunération et vos flux pour bâtir une stratégie fiscale optimale, robuste et parfaitement conforme.",
    points: [
      "Audit fiscal complet et identification des leviers d'optimisation",
      "Préparation et dépôt des liasses IS, déclarations IR des dirigeants",
      "Assistance et représentation en cas de contrôle fiscal",
      "Conformité TVA nationale et intracommunautaire (OSS, autoliquidation)",
    ],
  },
  {
    intro: "Au-delà des chiffres : un associé senior à vos côtés pour structurer votre croissance, sécuriser vos opérations et piloter votre performance.",
    points: [
      "Tableaux de bord, reporting mensuel et pilotage de trésorerie",
      "Accompagnement fusions-acquisitions : due diligence, valorisation, structuration",
      "Conseil opérationnel : marges, prix de revient, organisation financière",
      "Établissement des comptes annuels et présentation aux associés",
    ],
  },
];
const pole = site.services.map((svc, i) => ({ ...svc, ...details[i] }));
---
<Base title={`Services — ${site.company_name} Expertise`} description={site.services_subtitle}>
  <Header />
  <main>

    <!-- Hero -->
    <section class="hero-grid px-6 pt-20 pb-16 bg-[var(--color-bg)]">
      <div class="max-w-4xl mx-auto text-center" data-animate>
        <span class="inline-flex items-center px-4 py-1.5 rounded-full bg-[var(--color-accent)]/15 border border-[var(--color-accent)]/30 text-[var(--color-accent2)] text-xs font-semibold tracking-wide mb-7">
          Nos services
        </span>
        <h1 class="text-5xl lg:text-6xl font-bold tracking-tight text-white leading-tight mb-7">{site.services_title}</h1>
        <p class="text-lg text-[var(--color-muted)] leading-relaxed max-w-2xl mx-auto">{site.services_subtitle}</p>
      </div>
    </section>

    <!-- Les 3 pôles détaillés -->
    <section class="px-6 py-20 bg-[var(--color-bg)]">
      <div class="max-w-6xl mx-auto space-y-10">
        {pole.map((svc, i) => (
          <div class="bg-[var(--color-surface)] border border-white/[0.06] rounded-3xl p-8 lg:p-12 grid lg:grid-cols-5 gap-10" data-animate>
            <div class="lg:col-span-2 space-y-5">
              <div class="w-14 h-14 rounded-2xl bg-[var(--color-accent)]/15 flex items-center justify-center">
                <iconify-icon icon={svc.icon} class="text-3xl text-[var(--color-accent2)]"></iconify-icon>
              </div>
              <div class="text-xs font-semibold tracking-[0.2em] text-[var(--color-muted)]">PÔLE {String(i + 1).padStart(2, '0')}</div>
              <h2 class="text-3xl font-bold tracking-tight text-white">{svc.name}</h2>
              <p class="text-[var(--color-muted)] leading-relaxed">{svc.intro}</p>
              <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/[0.04] border border-white/[0.08] text-sm">
                <iconify-icon icon="solar:tag-price-linear" class="text-[var(--color-accent2)]"></iconify-icon>
                <span class="text-white font-semibold">{svc.price}</span>
              </div>
            </div>
            <div class="lg:col-span-3">
              <ul class="grid sm:grid-cols-1 gap-4">
                {svc.points.map(p => (
                  <li class="flex items-start gap-3 bg-white/[0.03] border border-white/[0.05] rounded-xl px-5 py-4">
                    <iconify-icon icon="solar:check-circle-bold" class="text-[var(--color-accent2)] text-lg shrink-0 mt-0.5"></iconify-icon>
                    <span class="text-sm text-white leading-relaxed">{p}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Tarifs indicatifs (claire) -->
    <section class="px-6 py-24 bg-[#F8FAFC]">
      <div class="max-w-6xl mx-auto">
        <div class="text-center max-w-2xl mx-auto mb-14" data-animate>
          <h2 class="text-4xl lg:text-5xl font-bold tracking-tight text-[#0F172A] mb-5">Des honoraires clairs, sans surprise</h2>
          <p class="text-lg text-slate-500">Chaque mission fait l'objet d'une lettre de mission détaillée. Tarifs indicatifs hors taxes.</p>
        </div>
        <div class="grid md:grid-cols-3 gap-7">
          {site.services.map(svc => (
            <div class="bg-white rounded-2xl shadow-lg shadow-slate-200/60 border border-slate-100 p-8 text-center" data-animate>
              <h3 class="text-lg font-bold text-[#0F172A] mb-2">{svc.name}</h3>
              <div class="text-2xl font-bold text-[var(--color-accent)] mb-4">{svc.price}</div>
              <p class="text-sm text-slate-500 leading-relaxed">{svc.desc}</p>
            </div>
          ))}
        </div>
        <p class="text-xs italic text-slate-400 text-center mt-8">Tarification ajustée selon le volume de pièces, l'effectif et la complexité de l'activité. Devis gratuit sous 48h.</p>
      </div>
    </section>

    <!-- CTA -->
    <section class="px-6 py-24 bg-[var(--color-bg)]">
      <div class="max-w-3xl mx-auto text-center space-y-7" data-animate>
        <h2 class="text-4xl font-bold tracking-tight text-white">Un projet, une question, un doute fiscal ?</h2>
        <p class="text-lg text-[var(--color-muted)]">Parlons-en. La première consultation de 30 minutes est offerte et sans engagement.</p>
        <a href="/contact/"
          class="inline-flex items-center gap-2 bg-[var(--color-accent)] hover:bg-[var(--color-accent2)] text-white px-8 py-4 rounded-full font-semibold text-sm transition-all shadow-lg shadow-blue-600/25">
          Planifier une consultation
          <iconify-icon icon="solar:arrow-right-linear" class="text-base"></iconify-icon>
        </a>
      </div>
    </section>

  </main>
  <Footer />
</Base>
