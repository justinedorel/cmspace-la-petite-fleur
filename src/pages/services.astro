---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
const services = [
  { title: site.service1_title, desc: site.service1_desc, details: [site.service1_detail1, site.service1_detail2, site.service1_detail3] },
  { title: site.service2_title, desc: site.service2_desc, details: [site.service2_detail1, site.service2_detail2, site.service2_detail3] },
  { title: site.service3_title, desc: site.service3_desc, details: [site.service3_detail1, site.service3_detail2, site.service3_detail3] },
];
---
<Base title={`Services — ${site.company_name}`} description={site.services_subtitle}>
  <Header />
  <main>
    <section class="pt-20 pb-16 px-6 bg-[var(--color-surface)]">
      <div class="max-w-7xl mx-auto" data-animate>
        <span class="text-xs font-semibold uppercase tracking-widest text-[var(--color-accent)]">Expertise</span>
        <h1 class="font-display text-5xl font-medium text-[var(--color-text)] mt-3 mb-4">{site.services_title}</h1>
        <p class="text-lg text-[var(--color-text-muted)] max-w-xl">{site.services_subtitle}</p>
      </div>
    </section>
    <section class="py-24 px-6">
      <div class="max-w-7xl mx-auto space-y-20">
        {services.map((s, i) => (
          <div class={`grid lg:grid-cols-2 gap-16 items-center ${i % 2 === 1 ? 'lg:flex-row-reverse' : ''}`} data-animate>
            <div class={i % 2 === 1 ? 'lg:order-2' : ''}>
              <span class="text-xs font-semibold uppercase tracking-widest text-[var(--color-accent)]">0{i + 1}</span>
              <h2 class="font-display text-3xl font-medium text-[var(--color-primary)] mt-2 mb-4">{s.title}</h2>
              <p class="text-[var(--color-text-muted)] leading-relaxed mb-6">{s.desc}</p>
              <ul class="space-y-3">
                {s.details.filter(Boolean).map(d => (
                  <li class="flex items-start gap-3">
                    <iconify-icon icon="solar:check-circle-linear" class="text-[var(--color-accent)] text-xl shrink-0 mt-0.5"></iconify-icon>
                    <span class="text-[var(--color-text)]">{d}</span>
                  </li>
                ))}
              </ul>
              <a href="/contact" class="mt-8 inline-flex bg-[var(--color-primary)] text-white px-6 py-3 rounded-xl text-sm font-medium hover:opacity-90 transition-all gap-2 items-center">
                En savoir plus <iconify-icon icon="solar:arrow-right-linear"></iconify-icon>
              </a>
            </div>
            <div class={`h-72 lg:h-96 bg-[var(--color-surface)] rounded-2xl ${i % 2 === 1 ? 'lg:order-1' : ''}`}></div>
          </div>
        ))}
      </div>
    </section>
    <section class="py-20 px-6 bg-[var(--color-primary)]">
      <div class="max-w-3xl mx-auto text-center" data-animate>
        <h2 class="font-display text-4xl font-medium text-white mb-4">{site.cta_title}</h2>
        <p class="text-white/75 mb-8">{site.cta_subtitle}</p>
        <a href="/contact" class="bg-white text-[var(--color-primary)] px-8 py-4 rounded-xl font-semibold text-sm hover:bg-white/90 transition-all shadow-lg inline-block">
          {site.cta_primary}
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Base>
