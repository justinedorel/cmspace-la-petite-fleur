---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
---
<Base title={`Nos Produits — ${site.company_name}`} description={site.seo_description}>
  <Header />

  <!-- Hero page -->
  <section class="bg-[#2D4A2D] py-20">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <p class="text-[#E8D5A3]/70 text-sm font-semibold tracking-widest uppercase mb-4">Ce que nous cultivons</p>
      <h1 class="font-display text-5xl font-bold text-white mb-4">Nos Produits</h1>
      <p class="text-white/70 max-w-xl mx-auto leading-relaxed">
        Découvrez l'ensemble de nos productions, disponibles en vente directe à la ferme ou en commandes professionnelles.
      </p>
    </div>
  </section>

  <!-- Grille produits -->
  <section class="py-24 bg-[#F9F7F2]">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-10">
        {[
          { name: site.product1_name, desc: site.product1_desc, img: site.product1_image },
          { name: site.product2_name, desc: site.product2_desc, img: site.product2_image },
          { name: site.product3_name, desc: site.product3_desc, img: site.product3_image },
          { name: site.product4_name, desc: site.product4_desc, img: site.product4_image },
        ].map(p => (
          <div class="bg-white rounded-2xl overflow-hidden shadow-sm flex flex-col sm:flex-row gap-0">
            <div class="w-full sm:w-48 h-52 sm:h-auto shrink-0 overflow-hidden">
              <img src={p.img} alt={p.name} class="w-full h-full object-cover" />
            </div>
            <div class="p-6 flex flex-col justify-center">
              <h3 class="font-display text-xl font-bold text-[#1C2B1C] mb-3">{p.name}</h3>
              <p class="text-[#6B7C6B] leading-relaxed text-sm">{p.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Commande pro -->
  <section class="py-16 bg-[#EDE8DE]">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="font-display text-3xl font-bold text-[#1C2B1C] mb-4">Commande professionnelle</h2>
      <p class="text-[#6B7C6B] mb-8">Restaurateurs, épiceries, grandes surfaces : nous proposons des tarifs dégressifs et des livraisons régulières.</p>
      <a href="/contact/" class="inline-block bg-[#2D4A2D] text-[#E8D5A3] font-semibold px-8 py-4 rounded-full hover:bg-[#1C2B1C] transition-colors">
        Demander un devis
      </a>
    </div>
  </section>

  <Footer />
</Base>
