---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
---
<Base title={`Saveurs & Services — ${site.company_name}`} description={`Découvrez nos saveurs et créations artisanales. ${site.seo_description}`}>

  <Header />

  <!-- Hero page -->
  <section class="pt-40 pb-20 bg-sand/20">
    <div class="max-w-7xl mx-auto px-8">
      <span class="font-sans text-xs tracking-[0.22em] uppercase text-muted mb-4 block">{site.portfolio_badge}</span>
      <h1 class="font-serif text-5xl md:text-7xl font-light text-dark mb-6">
        {site.flavors_title} <em class="italic">{site.flavors_title_em}</em>
      </h1>
      <p class="font-sans text-sm font-light leading-relaxed text-muted max-w-xl tracking-wide">{site.process_subtitle}</p>
    </div>
  </section>

  <!-- Saveurs -->
  <section class="py-28">
    <div class="max-w-7xl mx-auto px-8">
      <div class="mb-16">
        <h2 class="font-serif text-4xl md:text-5xl font-light text-dark mb-3">
          {site.flavors_title} <em class="italic">{site.flavors_title_em}</em>
        </h2>
      </div>
      <div class="grid md:grid-cols-3 gap-px bg-sand/50">
        <div class="bg-bg p-10 md:p-12 hover:bg-pink/20 transition-colors duration-300">
          <span class="font-sans text-xs tracking-[0.18em] uppercase text-muted border border-sand px-3 py-1 mb-8 inline-block">{site.flavor1_tag}</span>
          <h3 class="font-serif text-2xl font-light text-dark mb-4">{site.flavor1_title}</h3>
          <p class="font-sans text-sm font-light leading-relaxed text-muted tracking-wide">{site.flavor1_desc}</p>
        </div>
        <div class="bg-bg p-10 md:p-12 hover:bg-pink/20 transition-colors duration-300">
          <span class="font-sans text-xs tracking-[0.18em] uppercase text-muted border border-sand px-3 py-1 mb-8 inline-block">{site.flavor2_tag}</span>
          <h3 class="font-serif text-2xl font-light text-dark mb-4">{site.flavor2_title}</h3>
          <p class="font-sans text-sm font-light leading-relaxed text-muted tracking-wide">{site.flavor2_desc}</p>
        </div>
        <div class="bg-bg p-10 md:p-12 hover:bg-pink/20 transition-colors duration-300">
          <span class="font-sans text-xs tracking-[0.18em] uppercase text-muted border border-sand px-3 py-1 mb-8 inline-block">{site.flavor3_tag}</span>
          <h3 class="font-serif text-2xl font-light text-dark mb-4">{site.flavor3_title}</h3>
          <p class="font-sans text-sm font-light leading-relaxed text-muted tracking-wide">{site.flavor3_desc}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Portfolio / Galerie -->
  <section class="py-28 bg-sand/20">
    <div class="max-w-7xl mx-auto px-8">
      <div class="mb-16">
        <span class="font-sans text-xs tracking-[0.22em] uppercase text-muted mb-4 block">{site.portfolio_badge}</span>
        <h2 class="font-serif text-4xl md:text-5xl font-light text-dark">
          {site.portfolio_title} <em class="italic">{site.portfolio_title_em}</em>
        </h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="group cursor-default">
          <div class="overflow-hidden mb-5">
            <img src={site.portfolio1_image} alt={site.portfolio1_title} class="w-full aspect-[3/4] object-cover group-hover:scale-105 transition-transform duration-700" />
          </div>
          <h3 class="font-serif text-xl font-light text-dark mb-1">{site.portfolio1_title}</h3>
          <span class="font-sans text-xs tracking-[0.15em] uppercase text-muted">{site.portfolio1_flavor}</span>
        </div>
        <div class="group cursor-default md:mt-12">
          <div class="overflow-hidden mb-5">
            <img src={site.portfolio2_image} alt={site.portfolio2_title} class="w-full aspect-[3/4] object-cover group-hover:scale-105 transition-transform duration-700" />
          </div>
          <h3 class="font-serif text-xl font-light text-dark mb-1">{site.portfolio2_title}</h3>
          <span class="font-sans text-xs tracking-[0.15em] uppercase text-muted">{site.portfolio2_flavor}</span>
        </div>
        <div class="group cursor-default">
          <div class="overflow-hidden mb-5">
            <img src={site.portfolio3_image} alt={site.portfolio3_title} class="w-full aspect-[3/4] object-cover group-hover:scale-105 transition-transform duration-700" />
          </div>
          <h3 class="font-serif text-xl font-light text-dark mb-1">{site.portfolio3_title}</h3>
          <span class="font-sans text-xs tracking-[0.15em] uppercase text-muted">{site.portfolio3_flavor}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Processus -->
  <section class="py-28 md:py-36">
    <div class="max-w-7xl mx-auto px-8">
      <div class="text-center mb-20">
        <span class="font-sans text-xs tracking-[0.22em] uppercase text-muted mb-4 block">{site.process_badge}</span>
        <h2 class="font-serif text-4xl md:text-5xl font-light text-dark mb-5">{site.process_title}</h2>
        <p class="font-sans text-sm font-light leading-relaxed text-muted max-w-xl mx-auto tracking-wide">{site.process_subtitle}</p>
      </div>
      <div class="grid md:grid-cols-4 gap-10 md:gap-8">
        <div class="relative">
          <div class="font-serif text-8xl font-light text-sand leading-none mb-6 select-none">01</div>
          <div class="w-10 h-px bg-dark/20 mb-6"></div>
          <h3 class="font-serif text-2xl font-light text-dark mb-3">{site.step1_title}</h3>
          <p class="font-sans text-sm font-light leading-relaxed text-muted tracking-wide">{site.step1_desc}</p>
        </div>
        <div class="relative">
          <div class="font-serif text-8xl font-light text-sand leading-none mb-6 select-none">02</div>
          <div class="w-10 h-px bg-dark/20 mb-6"></div>
          <h3 class="font-serif text-2xl font-light text-dark mb-3">{site.step2_title}</h3>
          <p class="font-sans text-sm font-light leading-relaxed text-muted tracking-wide">{site.step2_desc}</p>
        </div>
        <div class="relative">
          <div class="font-serif text-8xl font-light text-sand leading-none mb-6 select-none">03</div>
          <div class="w-10 h-px bg-dark/20 mb-6"></div>
          <h3 class="font-serif text-2xl font-light text-dark mb-3">{site.step3_title}</h3>
          <p class="font-sans text-sm font-light leading-relaxed text-muted tracking-wide">{site.step3_desc}</p>
        </div>
        <div class="relative">
          <div class="font-serif text-8xl font-light text-sand leading-none mb-6 select-none">04</div>
          <div class="w-10 h-px bg-dark/20 mb-6"></div>
          <h3 class="font-serif text-2xl font-light text-dark mb-3">{site.step4_title}</h3>
          <p class="font-sans text-sm font-light leading-relaxed text-muted tracking-wide">{site.step4_desc}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Témoignage -->
  <section class="py-28 md:py-36 bg-dark">
    <div class="max-w-5xl mx-auto px-8 text-center">
      <span class="iconify text-sand/40 mb-10 block mx-auto" data-icon="lucide:quote" data-width="40"></span>
      <blockquote class="font-serif text-3xl md:text-4xl font-light italic leading-relaxed text-white/90 mb-12">
        &ldquo;{site.testimonial_text}&rdquo;
      </blockquote>
      <div class="flex items-center justify-center gap-5">
        <img src={site.testimonial_image} alt={site.testimonial_name} class="w-12 h-12 rounded-full object-cover grayscale opacity-60" />
        <div class="text-left">
          <p class="font-serif text-base font-light text-white/80">{site.testimonial_name}</p>
          <p class="font-sans text-xs tracking-[0.15em] uppercase text-white/30">{site.testimonial_date}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24">
    <div class="max-w-3xl mx-auto px-8 text-center">
      <h2 class="font-serif text-4xl md:text-5xl font-light text-dark mb-6">{site.about_cta}</h2>
      <p class="font-sans text-sm font-light leading-relaxed text-muted mb-10 tracking-wide">{site.hero_subtitle}</p>
      <a href="/contact" class="inline-flex items-center gap-3 font-sans text-xs tracking-[0.18em] uppercase text-dark border border-dark/30 px-8 py-4 hover:bg-dark hover:text-bg transition-all duration-300">
        {site.hero_cta}
        <span class="iconify" data-icon="lucide:arrow-right" data-width="14"></span>
      </a>
    </div>
  </section>

  <Footer />

</Base>
