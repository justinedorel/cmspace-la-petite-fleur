---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
---
<Base title={`Message reçu — ${site.company_name}`} description={`Merci pour votre message. ${site.company_name} vous contactera prochainement.`}>

  <Header />

  <section class="min-h-screen flex items-center justify-center py-40 px-8">
    <div class="text-center max-w-xl">
      <div class="w-16 h-px bg-sand mx-auto mb-12"></div>
      <span class="font-sans text-xs tracking-[0.22em] uppercase text-muted mb-6 block">Confirmation</span>
      <h1 class="font-serif text-5xl md:text-6xl font-light text-dark mb-6 leading-tight">
        Message <em class="italic">reçu</em>
      </h1>
      <p class="font-sans text-sm font-light leading-relaxed text-muted mb-4 tracking-wide">
        Merci de nous avoir contactés. Nous avons bien reçu votre demande et nous vous répondrons dans les plus brefs délais.
      </p>
      <p class="font-sans text-sm font-light leading-relaxed text-muted mb-12 tracking-wide">
        {site.footer_tagline}
      </p>
      <div class="w-16 h-px bg-sand mx-auto mb-12"></div>
      <a href="/" class="inline-flex items-center gap-3 font-sans text-xs tracking-[0.18em] uppercase text-dark hover:opacity-60 transition-opacity">
        Retour à l'accueil
        <span class="iconify" data-icon="lucide:arrow-left" data-width="14"></span>
      </a>
    </div>
  </section>

  <Footer />

</Base>
