---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
---
<Base title="Message envoyé" noindex={true}>
  <Header />
  <main class="min-h-[60vh] flex items-center justify-center px-6">
    <div class="text-center max-w-md" data-animate>
      <div class="w-16 h-16 bg-[var(--color-accent)] rounded-full flex items-center justify-center mx-auto mb-6">
        <iconify-icon icon="solar:check-circle-linear" class="text-3xl text-white"></iconify-icon>
      </div>
      <h1 class="font-display text-3xl font-medium text-[var(--color-primary)] mb-4">Message envoyé !</h1>
      <p class="text-[var(--color-text-muted)] leading-relaxed mb-8">
        Merci de nous avoir contactés. Nous reviendrons vers vous dans les plus brefs délais.
      </p>
      <a href="/" class="bg-[var(--color-primary)] text-white px-7 py-3 rounded-xl font-medium text-sm hover:opacity-90 transition-all inline-block">
        Retour à l'accueil
      </a>
    </div>
  </main>
  <Footer />
</Base>
