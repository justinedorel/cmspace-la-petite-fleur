---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
---
<Base title={`Message reçu — ${site.company_name}`} description={`Merci pour votre message. ${site.company_name} vous contactera prochainement.`}>

  <Header />

  <section class="min-h-screen flex items-center justify-center py-40 px-8" style="background:#FAF8F5">
    <div class="text-center max-w-xl reveal">
      <div style="width:1px;height:3rem;background:#E8E0D8;margin:0 auto 3rem"></div>
      <p class="font-sans text-xs tracking-[0.28em] uppercase mb-6" style="color:#C4956A">Confirmation</p>
      <h1 class="font-serif text-5xl md:text-6xl font-light mb-6 leading-tight" style="color:#1A1A1A">
        Message <em class="italic">reçu</em>
      </h1>
      <p class="font-sans text-sm font-light leading-relaxed mb-4" style="color:#8A7E75">
        Merci de nous avoir contactés. Nous avons bien reçu votre demande et nous vous répondrons dans les plus brefs délais.
      </p>
      <p class="font-sans text-sm font-light leading-relaxed mb-12" style="color:#8A7E75">
        {(site as any).footer_tagline}
      </p>
      <div style="width:2rem;height:1px;background:#C4956A;margin:0 auto 3rem"></div>
      <a href="/" class="inline-flex items-center gap-3 font-sans text-xs tracking-[0.18em] uppercase transition-colors" style="color:#C4956A">
        <span class="iconify" data-icon="lucide:arrow-left" data-width="13"></span>
        Retour à l'accueil
      </a>
    </div>
  </section>

  <Footer />

</Base>
