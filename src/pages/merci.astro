---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
---
<Base title={`Message envoyé — ${site.company_name}`} description="">
  <Header />
  <section class="min-h-[60vh] flex items-center justify-center bg-[#F9F7F2]">
    <div class="text-center px-6">
      <div class="w-16 h-16 bg-[#2D4A2D] rounded-full flex items-center justify-center mx-auto mb-6">
        <svg class="w-8 h-8 text-[#E8D5A3]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
      </div>
      <h1 class="font-display text-3xl font-bold text-[#1C2B1C] mb-3">Message envoyé !</h1>
      <p class="text-[#6B7C6B] mb-8">Nous vous répondons sous 24h. Merci de votre confiance.</p>
      <a href="/" class="inline-block bg-[#2D4A2D] text-[#E8D5A3] font-semibold px-8 py-3 rounded-full hover:bg-[#1C2B1C] transition-colors text-sm">
        Retour à l'accueil
      </a>
    </div>
  </section>
  <Footer />
</Base>
