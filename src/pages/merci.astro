---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
---
<Base title={`Message envoyé — ${site.company_name}`} description="Votre message a bien été envoyé.">
  <Header />

  <main class="flex-grow flex items-center justify-center py-32 px-6">
    <div class="max-w-lg text-center">
      <div class="h-16 w-16 rounded-2xl bg-zinc-900 border border-zinc-800 flex items-center justify-center mx-auto mb-8">
        <iconify-icon icon="solar:check-circle-linear" class="text-3xl text-emerald-400"></iconify-icon>
      </div>
      <h1 class="text-3xl md:text-4xl font-medium tracking-tight text-zinc-100 mb-4">
        Message envoyé !
      </h1>
      <p class="text-zinc-400 mb-10 leading-relaxed">
        Merci pour votre message. Nous l'avons bien reçu et reviendrons vers vous sous 24h pour planifier un appel découverte.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/" class="px-6 py-3 text-sm font-medium bg-zinc-100 text-zinc-950 rounded-md hover:bg-zinc-200 transition-colors flex items-center gap-2">
          Retour à l'accueil
          <iconify-icon icon="solar:arrow-right-linear"></iconify-icon>
        </a>
        <a href="/services" class="px-6 py-3 text-sm font-medium border border-zinc-800 text-zinc-300 rounded-md hover:bg-zinc-900 hover:text-zinc-100 transition-colors">
          Voir nos services
        </a>
      </div>
    </div>
  </main>

  <Footer />
</Base>
