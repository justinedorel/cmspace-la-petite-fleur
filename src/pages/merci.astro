---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
---
<Base title={`Message envoyé — ${site.company_name}`} description={`Merci pour votre message. L'équipe ${site.company_name} vous répondra bientôt.`}>

  <Header />

  <section class="py-32 px-6 text-center">
    <div class="max-w-2xl mx-auto">
      <!-- Icône de succès -->
      <div class="inline-flex items-center justify-center w-20 h-20 bg-indigo-50 rounded-2xl mb-8">
        <i data-lucide="check-circle" class="w-10 h-10 text-accent"></i>
      </div>

      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight leading-tight mb-4">
        Message envoyé !
      </h1>
      <p class="text-zinc-500 text-lg leading-relaxed mb-10">
        Merci de nous avoir contactés. Notre équipe a bien reçu votre message et vous répondra dans les plus brefs délais, généralement sous 24h.
      </p>

      <!-- Stats en rappel -->
      <div class="inline-flex items-center gap-8 bg-zinc-50 rounded-2xl px-8 py-4 border border-zinc-100 mb-12">
        <div class="text-center">
          <div class="text-2xl font-extrabold text-zinc-900">{site.hero_stat1_value}</div>
          <div class="text-xs text-zinc-500 mt-0.5">{site.hero_stat1_label}</div>
        </div>
        <div class="w-px h-8 bg-zinc-200"></div>
        <div class="text-center">
          <div class="text-2xl font-extrabold text-zinc-900">{site.hero_stat2_value}</div>
          <div class="text-xs text-zinc-500 mt-0.5">{site.hero_stat2_label}</div>
        </div>
        <div class="w-px h-8 bg-zinc-200"></div>
        <div class="text-center">
          <div class="text-2xl font-extrabold text-zinc-900">{site.hero_stat3_value}</div>
          <div class="text-xs text-zinc-500 mt-0.5">{site.hero_stat3_label}</div>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="/" class="bg-accent text-white font-semibold rounded-xl px-6 py-3 hover:opacity-90 transition-opacity shadow-lg shadow-indigo-200 flex items-center gap-2">
          <i data-lucide="home" class="w-4 h-4"></i>
          Retour à l'accueil
        </a>
        <a href="/services" class="border border-zinc-200 text-zinc-700 font-medium rounded-xl px-6 py-3 hover:bg-zinc-50 transition-colors flex items-center gap-2">
          <i data-lucide="layout-dashboard" class="w-4 h-4"></i>
          Découvrir nos services
        </a>
      </div>
    </div>
  </section>

  <Footer />

  <style is:global>
    html { scroll-behavior: smooth; }
  </style>

</Base>
