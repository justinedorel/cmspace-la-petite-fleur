---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
---
<Base title="Demande envoyée" noindex={true}>
  <Header />
  <main class="min-h-[60vh] flex items-center justify-center px-6 bg-[var(--color-bg)]">
    <div class="text-center max-w-md" data-animate>
      <div class="w-16 h-16 bg-[var(--color-accent)] rounded-full flex items-center justify-center mx-auto mb-6 shadow-lg shadow-blue-600/30">
        <iconify-icon icon="solar:check-circle-linear" class="text-3xl text-white"></iconify-icon>
      </div>
      <h1 class="text-3xl font-bold text-white mb-4">Demande bien reçue !</h1>
      <p class="text-[var(--color-muted)] leading-relaxed mb-8">
        Merci pour votre confiance. Un associé du cabinet {site.company_name} Expertise vous recontacte sous 24h ouvrées pour planifier votre consultation.
      </p>
      <a href="/" class="inline-flex items-center gap-2 bg-[var(--color-accent)] hover:bg-[var(--color-accent2)] text-white px-7 py-3 rounded-full font-semibold text-sm transition-all">
        Retour à l'accueil
        <iconify-icon icon="solar:arrow-right-linear" class="text-base"></iconify-icon>
      </a>
    </div>
  </main>
  <Footer />
</Base>
