---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
---
<Base title={`Demande reçue — ${site.company_name}`} description={`Merci pour votre message. ${site.company_name} vous contactera prochainement.`}>

  <Header />

  <section class="min-h-screen flex items-center justify-center py-40 px-6" style="background-color:#FDFAF8;">
    <div class="text-center max-w-xl">
      <!-- Icône -->
      <div class="w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-10" style="background-color:#F9F0EE;">
        <span class="iconify" data-icon="lucide:check" data-width="28" style="color:#D4A5A5;"></span>
      </div>

      <span class="font-body text-xs tracking-[0.22em] uppercase mb-4 block" style="color:#9E6B6B;">Confirmation</span>
      <h1 class="font-display text-5xl md:text-6xl font-medium mb-6 leading-tight" style="color:#1C1C1C;">
        Demande <em class="italic font-normal" style="color:#D4A5A5;">reçue</em>
      </h1>
      <p class="font-body text-base leading-relaxed mb-4" style="color:#9B8B8B;">
        Merci de nous avoir contactés. Nous avons bien reçu votre demande et nous vous répondrons dans les plus brefs délais.
      </p>
      <p class="font-body text-sm leading-relaxed mb-12" style="color:#9B8B8B;">
        {site.footer_tagline}
      </p>

      <div class="w-12 h-px mx-auto mb-10" style="background-color:#EDE0DE;"></div>

      <a href="/" class="inline-flex items-center gap-2 font-body text-sm transition-colors" style="color:#9E6B6B;"
        onmouseover="this.style.color='#1C1C1C'"
        onmouseout="this.style.color='#9E6B6B'">
        <span class="iconify" data-icon="lucide:arrow-left" data-width="14"></span>
        Retour à l'accueil
      </a>
    </div>
  </section>

  <Footer />

</Base>
