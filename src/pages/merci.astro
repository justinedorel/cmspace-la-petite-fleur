---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
---
<Base title={"Merci — " + site.company_name} description="Votre message a bien été reçu. Nous vous répondons très bientôt.">

  <Header />

  <section class="min-h-[80vh] flex items-center justify-center px-6 pt-32 pb-20 bg-[#F7F5F0]">
    <div class="max-w-2xl mx-auto text-center">
      <div class="w-20 h-20 rounded-full bg-[#8A9A8B]/15 flex items-center justify-center mx-auto mb-8">
        <span class="iconify text-[#8A9A8B]" data-icon="lucide:check-circle" data-width="40"></span>
      </div>

      <div class="inline-flex items-center gap-2 mb-6 px-4 py-2 rounded-full bg-[#8A9A8B]/10 text-[#8A9A8B] text-xs font-medium tracking-wide uppercase">
        <span class="iconify" data-icon="lucide:leaf" data-width="13"></span>
        Message reçu
      </div>

      <h1 class="font-playfair text-4xl md:text-5xl font-medium text-[#2F3E35] leading-[1.15] mb-6">
        Merci pour votre message
      </h1>

      <p class="text-[#2F3E35]/60 text-lg font-light mb-4 leading-relaxed max-w-lg mx-auto">
        Nous avons bien reçu votre demande et nous vous répondrons dans les prochaines 24 heures.
      </p>

      <p class="text-[#2F3E35]/50 text-base font-light mb-12 leading-relaxed">
        En attendant, explorez nos cours ou découvrez l'histoire du studio.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/services" class="inline-flex items-center justify-center gap-2 bg-[#8A9A8B] text-white font-semibold rounded-full px-8 py-4 hover:bg-[#6e7e6f] transition-colors text-sm">
          <span class="iconify" data-icon="lucide:sparkles" data-width="16"></span>
          Explorer nos cours
        </a>
        <a href="/" class="inline-flex items-center justify-center gap-2 border border-[#2F3E35]/20 bg-white text-[#2F3E35] font-medium rounded-full px-8 py-4 hover:bg-[#F7F5F0] transition-colors text-sm">
          <span class="iconify" data-icon="lucide:home" data-width="16"></span>
          Retour à l'accueil
        </a>
      </div>
    </div>
  </section>

  <Footer />

</Base>
