---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
---
<Base title={`Merci — ${site.company_name}`} description={`Votre demande a été envoyée. ${site.company_name} vous contactera prochainement.`}>

  <Header />

  <section class="min-h-screen flex items-center justify-center py-40 px-6" style="background:#FAFAF7;">
    <div class="text-center max-w-xl">
      <div class="w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-8" style="background:rgba(92,122,92,0.1);border:1px solid rgba(92,122,92,0.3);">
        <span class="iconify text-accent" data-icon="lucide:check" data-width="28"></span>
      </div>
      <h1 class="font-serif text-4xl md:text-5xl font-light text-dark mb-4">Demande reçue</h1>
      <p class="font-sans text-sm text-muted leading-relaxed mb-3">
        Merci de votre confiance. Nous avons bien reçu votre demande et nous vous recontacterons dans les 24 heures pour confirmer votre rendez-vous.
      </p>
      <p class="font-sans text-sm text-muted mb-10">{site.tagline}</p>
      <a href="/" class="inline-flex items-center gap-2 font-sans text-sm text-muted hover:text-dark transition-colors">
        <span class="iconify" data-icon="lucide:arrow-left" data-width="14"></span>
        Retour à l'accueil
      </a>
    </div>
  </section>

  <Footer />

</Base>
