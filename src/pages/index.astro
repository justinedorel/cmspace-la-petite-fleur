---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
---
<Base>
  <Header />

  <!-- Hero -->
  <section style="background:var(--colorSurface);padding:6rem 0;">
    <div class="container" style="display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center;">
      <div>
        <span class="section-label">{site.hero_badge}</span>
        <h1 style="font-size:clamp(2rem,4vw,3.25rem);color:var(--colorPrimary);margin-bottom:1.5rem;line-height:1.15;">
          {site.hero_title_italic === 'true'
            ? <><span>{site.hero_title.split(' ').slice(0,-2).join(' ')}</span> <em style="color:var(--colorAccent);">{site.hero_title.split(' ').slice(-2).join(' ')}</em></>
            : site.hero_title
          }
        </h1>
        <p style="font-size:1.15rem;color:var(--colorTextMuted);margin-bottom:2rem;line-height:1.7;">{site.hero_subtitle}</p>
        <div style="display:flex;gap:1rem;flex-wrap:wrap;">
          <a href={site.hero_cta_primary_href} class="btn-primary">{site.hero_cta_primary}</a>
          <a href="/contact" class="btn-secondary">{site.hero_cta_secondary}</a>
        </div>
        <div style="display:flex;gap:2.5rem;margin-top:3rem;">
          {[
            { v: site.hero_stat1_value, l: site.hero_stat1_label },
            { v: site.hero_stat2_value, l: site.hero_stat2_label },
            { v: site.hero_stat3_value, l: site.hero_stat3_label },
          ].map(s => (
            <div>
              <div style="font-size:1.75rem;font-weight:800;color:var(--colorPrimary);">{s.v}</div>
              <div style="font-size:0.8rem;color:var(--colorTextMuted);">{s.l}</div>
            </div>
          ))}
        </div>
      </div>
      <div style="border-radius:1rem;overflow:hidden;background:var(--colorPrimary);aspect-ratio:4/3;">
        {site.hero_image_url
          ? <img src={site.hero_image_url} alt={site.company_name} style="width:100%;height:100%;object-fit:cover;" />
          : <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;opacity:0.3;">
              <span style="color:#fff;font-size:1rem;">{site.company_name}</span>
            </div>
        }
      </div>
    </div>
  </section>

  <!-- Services résumé -->
  <section>
    <div class="container">
      <div style="text-align:center;margin-bottom:3rem;">
        <span class="section-label">Ce que nous faisons</span>
        <h2 class="section-title">{site.services_title}</h2>
        <p class="section-subtitle" style="margin:0 auto;">{site.services_subtitle}</p>
      </div>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;">
        {[
          { title: site.service1_title, desc: site.service1_desc, details: [site.service1_detail1, site.service1_detail2, site.service1_detail3] },
          { title: site.service2_title, desc: site.service2_desc, details: [site.service2_detail1, site.service2_detail2, site.service2_detail3] },
          { title: site.service3_title, desc: site.service3_desc, details: [site.service3_detail1, site.service3_detail2, site.service3_detail3] },
        ].map(s => (
          <div style="background:var(--colorSurface);border-radius:1rem;padding:2rem;">
            <h3 style="font-size:1.25rem;color:var(--colorPrimary);margin-bottom:0.75rem;">{s.title}</h3>
            <p style="font-size:0.9rem;color:var(--colorTextMuted);margin-bottom:1.25rem;">{s.desc}</p>
            <ul style="list-style:none;display:flex;flex-direction:column;gap:0.5rem;">
              {s.details.filter(Boolean).map(d => (
                <li style="font-size:0.85rem;color:var(--colorText);display:flex;align-items:center;gap:0.5rem;">
                  <span style="color:var(--colorAccent);font-weight:700;">✓</span> {d}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
      <div style="text-align:center;margin-top:2.5rem;">
        <a href="/services" class="btn-secondary">Voir tous nos services</a>
      </div>
    </div>
  </section>

  <!-- Témoignages -->
  <section style="background:var(--colorSurface);">
    <div class="container">
      <div style="text-align:center;margin-bottom:3rem;">
        <span class="section-label">Témoignages</span>
        <h2 class="section-title">{site.testimonials_title}</h2>
      </div>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;">
        {[
          { name: site.testimonial1_name, role: site.testimonial1_role, text: site.testimonial1_text, rating: site.testimonial1_rating },
          { name: site.testimonial2_name, role: site.testimonial2_role, text: site.testimonial2_text, rating: site.testimonial2_rating },
          { name: site.testimonial3_name, role: site.testimonial3_role, text: site.testimonial3_text, rating: site.testimonial3_rating },
        ].map(t => (
          <div style="background:var(--colorBg);border-radius:1rem;padding:1.75rem;">
            <div style="color:var(--colorAccent);font-size:1.1rem;margin-bottom:1rem;">
              {'★'.repeat(Number(t.rating) || 5)}
            </div>
            <p style="font-size:0.95rem;color:var(--colorText);margin-bottom:1.25rem;line-height:1.6;">"{t.text}"</p>
            <div>
              <div style="font-weight:700;font-size:0.9rem;color:var(--colorPrimary);">{t.name}</div>
              <div style="font-size:0.8rem;color:var(--colorTextMuted);">{t.role}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <section style="background:var(--colorPrimary);color:#fff;">
    <div class="container" style="text-align:center;">
      <h2 style="font-size:clamp(1.75rem,3vw,2.5rem);margin-bottom:1rem;">{site.cta_title}</h2>
      <p style="font-size:1.1rem;opacity:0.8;margin-bottom:2rem;">{site.cta_subtitle}</p>
      <a href={site.cta_primary_href} style="background:#fff;color:var(--colorPrimary);padding:0.875rem 2rem;border-radius:0.5rem;font-weight:700;font-size:0.95rem;display:inline-block;">
        {site.cta_primary}
      </a>
    </div>
  </section>

  <Footer />
</Base>
