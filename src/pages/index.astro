---
import Base from '../layouts/Base.astro';
import site from '../data/site.json';
---

<Base title={site.seo_title} description={site.seo_description}>

  <!-- NAV -->
  <nav class="bg-white shadow-sm sticky top-0 z-50">
    <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-1">
        <span class="font-display font-bold text-xl text-gray-900">Atlas</span>
        <span class="font-serif italic text-[#e11d48] text-xl"> Marketing Co.</span>
      </a>
      <div class="hidden md:flex items-center gap-8 text-sm font-medium text-gray-600">
        <a href="#resultats" class="hover:text-gray-900 transition-colors">Résultats</a>
        <a href="#process" class="hover:text-gray-900 transition-colors">Process</a>
        <a href="#faq" class="hover:text-gray-900 transition-colors">FAQ</a>
      </div>
      <a
        href="#rdv"
        class="bg-[#e11d48] text-white text-sm font-semibold px-5 py-2.5 rounded-lg hover:bg-rose-700 transition-colors"
      >
        {site.nav_cta}
      </a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="max-w-6xl mx-auto px-6 pt-20 pb-16 text-center">
    <div class="inline-flex items-center gap-2 bg-rose-50 text-[#e11d48] text-sm font-medium px-4 py-1.5 rounded-full mb-8">
      <i data-lucide="award" class="w-4 h-4"></i>
      {site.hero_badge}
    </div>

    <h1 class="text-5xl md:text-6xl lg:text-7xl leading-tight mb-6">
      <span class="font-display font-black text-gray-900">{site.hero_title1}</span>
      <br />
      <span class="font-serif italic text-[#e11d48]">{site.hero_title2}</span>
    </h1>

    <p class="text-lg text-gray-500 max-w-2xl mx-auto mb-10 leading-relaxed">
      {site.hero_desc}
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="#rdv"
        class="bg-[#e11d48] text-white font-semibold px-8 py-4 rounded-xl hover:bg-rose-700 transition-colors text-base"
      >
        {site.hero_cta_primary}
      </a>
      <a
        href="#resultats"
        class="border border-gray-300 text-gray-700 font-semibold px-8 py-4 rounded-xl hover:border-gray-500 hover:text-gray-900 transition-colors text-base"
      >
        {site.hero_cta_secondary}
      </a>
    </div>

    <div class="mt-12 max-w-4xl mx-auto rounded-2xl overflow-hidden shadow-2xl aspect-video">
      <iframe
        src={`https://www.youtube.com/embed/${site.hero_video_id}`}
        title="Atlas Marketing Co. — présentation"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        class="w-full h-full"
      ></iframe>
    </div>
  </section>

  <!-- PAIN POINTS -->
  <section id="resultats" class="bg-white py-20">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="font-display font-black text-4xl md:text-5xl text-center text-gray-900 mb-14">
        {site.pain_title}
      </h2>
      <div class="grid md:grid-cols-3 gap-8">

        <div class="bg-gradient-to-br from-rose-50 to-white border border-rose-100 rounded-2xl p-8">
          <div class="w-12 h-12 bg-[#e11d48] bg-opacity-10 rounded-xl flex items-center justify-center mb-5">
            <i data-lucide={site.pain1_icon} class="w-6 h-6 text-[#e11d48]"></i>
          </div>
          <h3 class="font-bold text-lg text-gray-900 mb-3">{site.pain1_title}</h3>
          <p class="text-gray-500 leading-relaxed">{site.pain1_desc}</p>
        </div>

        <div class="bg-gradient-to-br from-rose-50 to-white border border-rose-100 rounded-2xl p-8">
          <div class="w-12 h-12 bg-[#e11d48] bg-opacity-10 rounded-xl flex items-center justify-center mb-5">
            <i data-lucide={site.pain2_icon} class="w-6 h-6 text-[#e11d48]"></i>
          </div>
          <h3 class="font-bold text-lg text-gray-900 mb-3">{site.pain2_title}</h3>
          <p class="text-gray-500 leading-relaxed">{site.pain2_desc}</p>
        </div>

        <div class="bg-gradient-to-br from-rose-50 to-white border border-rose-100 rounded-2xl p-8">
          <div class="w-12 h-12 bg-[#e11d48] bg-opacity-10 rounded-xl flex items-center justify-center mb-5">
            <i data-lucide={site.pain3_icon} class="w-6 h-6 text-[#e11d48]"></i>
          </div>
          <h3 class="font-bold text-lg text-gray-900 mb-3">{site.pain3_title}</h3>
          <p class="text-gray-500 leading-relaxed">{site.pain3_desc}</p>
        </div>

      </div>
    </div>
  </section>

  <!-- BENEFITS -->
  <section class="bg-gray-50 py-20">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="font-display font-black text-4xl md:text-5xl text-center text-gray-900 mb-14">
        {site.benefits_title}
      </h2>
      <div class="grid md:grid-cols-3 gap-8">

        <div class="glass rounded-2xl p-8 shadow-sm">
          <div class="w-12 h-12 bg-[#e11d48] bg-opacity-10 rounded-xl flex items-center justify-center mb-5">
            <i data-lucide={site.benefit1_icon} class="w-6 h-6 text-[#e11d48]"></i>
          </div>
          <h3 class="font-bold text-lg text-gray-900 mb-3">{site.benefit1_title}</h3>
          <p class="text-gray-500 leading-relaxed">{site.benefit1_desc}</p>
        </div>

        <div class="glass rounded-2xl p-8 shadow-sm">
          <div class="w-12 h-12 bg-[#e11d48] bg-opacity-10 rounded-xl flex items-center justify-center mb-5">
            <i data-lucide={site.benefit2_icon} class="w-6 h-6 text-[#e11d48]"></i>
          </div>
          <h3 class="font-bold text-lg text-gray-900 mb-3">{site.benefit2_title}</h3>
          <p class="text-gray-500 leading-relaxed">{site.benefit2_desc}</p>
        </div>

        <div class="glass rounded-2xl p-8 shadow-sm">
          <div class="w-12 h-12 bg-[#e11d48] bg-opacity-10 rounded-xl flex items-center justify-center mb-5">
            <i data-lucide={site.benefit3_icon} class="w-6 h-6 text-[#e11d48]"></i>
          </div>
          <h3 class="font-bold text-lg text-gray-900 mb-3">{site.benefit3_title}</h3>
          <p class="text-gray-500 leading-relaxed">{site.benefit3_desc}</p>
        </div>

      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section id="process" class="bg-white py-20">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="font-display font-black text-4xl md:text-5xl text-center text-gray-900 mb-16">
        {site.process_title}
      </h2>

      <div class="relative">
        <!-- Ligne de connexion -->
        <div class="hidden md:block absolute top-8 left-1/6 right-1/6 h-px bg-gradient-to-r from-transparent via-rose-200 to-transparent" style="left: 16.666%; right: 16.666%;"></div>

        <div class="grid md:grid-cols-3 gap-12 text-center">

          <div class="fade-up" style="animation-delay: 0s;">
            <div class="w-16 h-16 bg-[#e11d48] text-white rounded-full flex items-center justify-center font-display font-black text-lg mx-auto mb-6 relative z-10">
              {site.process_step1_num}
            </div>
            <h3 class="font-semibold text-xl text-gray-900 mb-3">{site.process_step1_title}</h3>
            <p class="text-gray-500 leading-relaxed">{site.process_step1_desc}</p>
          </div>

          <div class="fade-up" style="animation-delay: 0.15s;">
            <div class="w-16 h-16 bg-[#e11d48] text-white rounded-full flex items-center justify-center font-display font-black text-lg mx-auto mb-6 relative z-10">
              {site.process_step2_num}
            </div>
            <h3 class="font-semibold text-xl text-gray-900 mb-3">{site.process_step2_title}</h3>
            <p class="text-gray-500 leading-relaxed">{site.process_step2_desc}</p>
          </div>

          <div class="fade-up" style="animation-delay: 0.3s;">
            <div class="w-16 h-16 bg-[#e11d48] text-white rounded-full flex items-center justify-center font-display font-black text-lg mx-auto mb-6 relative z-10">
              {site.process_step3_num}
            </div>
            <h3 class="font-semibold text-xl text-gray-900 mb-3">{site.process_step3_title}</h3>
            <p class="text-gray-500 leading-relaxed">{site.process_step3_desc}</p>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="bg-gray-50 py-20">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="font-display font-black text-4xl md:text-5xl text-center text-gray-900 mb-14">
        {site.faq_title}
      </h2>

      <div class="bg-white rounded-2xl shadow-sm overflow-hidden divide-y divide-gray-100">

        <details class="group px-8">
          <summary class="flex justify-between items-center py-5 cursor-pointer font-semibold text-gray-900 hover:text-[#e11d48] transition-colors">
            {site.faq1_q}
            <i data-lucide="chevron-down" class="faq-chevron w-5 h-5 text-gray-400 flex-shrink-0 ml-4"></i>
          </summary>
          <p class="pb-5 text-gray-500 leading-relaxed">{site.faq1_a}</p>
        </details>

        <details class="group px-8">
          <summary class="flex justify-between items-center py-5 cursor-pointer font-semibold text-gray-900 hover:text-[#e11d48] transition-colors">
            {site.faq2_q}
            <i data-lucide="chevron-down" class="faq-chevron w-5 h-5 text-gray-400 flex-shrink-0 ml-4"></i>
          </summary>
          <p class="pb-5 text-gray-500 leading-relaxed">{site.faq2_a}</p>
        </details>

        <details class="group px-8">
          <summary class="flex justify-between items-center py-5 cursor-pointer font-semibold text-gray-900 hover:text-[#e11d48] transition-colors">
            {site.faq3_q}
            <i data-lucide="chevron-down" class="faq-chevron w-5 h-5 text-gray-400 flex-shrink-0 ml-4"></i>
          </summary>
          <p class="pb-5 text-gray-500 leading-relaxed">{site.faq3_a}</p>
        </details>

        <details class="group px-8">
          <summary class="flex justify-between items-center py-5 cursor-pointer font-semibold text-gray-900 hover:text-[#e11d48] transition-colors">
            {site.faq4_q}
            <i data-lucide="chevron-down" class="faq-chevron w-5 h-5 text-gray-400 flex-shrink-0 ml-4"></i>
          </summary>
          <p class="pb-5 text-gray-500 leading-relaxed">{site.faq4_a}</p>
        </details>

      </div>
    </div>
  </section>

  <!-- CALENDLY -->
  <section id="rdv" class="bg-white py-20">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="font-display font-black text-4xl md:text-5xl text-gray-900 mb-4">
        {site.cta_title}
      </h2>
      <p class="text-lg text-gray-500 mb-10">{site.cta_desc}</p>

      <div class="rounded-2xl overflow-hidden shadow-lg border border-gray-100">
        <div
          class="calendly-inline-widget"
          data-url={site.calendly_url}
          style="min-width:320px;height:700px;"
        ></div>
        <script type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async></script>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="bg-gray-900 text-gray-400 py-12">
    <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-1">
        <span class="font-display font-bold text-white text-lg">Atlas</span>
        <span class="font-serif italic text-[#e11d48] text-lg"> Marketing Co.</span>
      </div>

      <p class="text-sm text-gray-500 text-center">
        &copy; {new Date().getFullYear()} Atlas Marketing Co. — {site.address}
      </p>

      <div class="flex items-center gap-4">
        <a href={site.social_linkedin} class="hover:text-white transition-colors" aria-label="LinkedIn">
          <i data-lucide="linkedin" class="w-5 h-5"></i>
        </a>
        <a href={site.social_instagram} class="hover:text-white transition-colors" aria-label="Instagram">
          <i data-lucide="instagram" class="w-5 h-5"></i>
        </a>
        <a href={site.social_twitter} class="hover:text-white transition-colors" aria-label="Twitter / X">
          <i data-lucide="twitter" class="w-5 h-5"></i>
        </a>
      </div>
    </div>
  </footer>

</Base>
