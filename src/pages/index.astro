---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
---
<Base title={site.seo_title} description={site.seo_description} image={(site as any).hero_image} url={(site as any).website}>

  <Header />

  <!-- ── Hero ──────────────────────────────────────────────────────────── -->
  <section class="relative min-h-screen flex items-center overflow-hidden grain">
    <!-- Image avec parallax -->
    <div class="hero-bg absolute inset-0 scale-110">
      <img src={site.hero_image} alt={site.hero_title2}
        class="w-full h-full object-cover" loading="eager" fetchpriority="high" />
      <div class="absolute inset-0" style="background:linear-gradient(to right, rgba(0,0,0,0.65) 0%, rgba(0,0,0,0.3) 60%, rgba(0,0,0,0.1) 100%)"></div>
    </div>

    <!-- Contenu -->
    <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-8 w-full pt-28">
      <div class="max-w-2xl">
        <!-- Badge -->
        <div class="overflow-hidden mb-8" style="opacity:0;animation:fadeSlideIn 0.8s cubic-bezier(0.16,1,0.3,1) 0.3s forwards">
          <span class="font-sans text-[11px] tracking-[0.25em] uppercase text-white/70 border border-white/25 px-4 py-1.5 inline-block">
            {site.hero_badge}
          </span>
        </div>

        <!-- Titre -->
        <div style="overflow:hidden;margin-bottom:0.25rem">
          <h1 class="font-serif text-5xl sm:text-7xl md:text-8xl font-light leading-[0.92] text-white"
            style="opacity:0;animation:fadeSlideIn 0.9s cubic-bezier(0.16,1,0.3,1) 0.5s forwards">
            {site.hero_title1}
          </h1>
        </div>
        <div style="overflow:hidden;margin-bottom:2.5rem">
          <h1 class="font-serif text-5xl sm:text-7xl md:text-8xl font-light italic leading-[0.92] text-white/90"
            style="opacity:0;animation:fadeSlideIn 0.9s cubic-bezier(0.16,1,0.3,1) 0.65s forwards">
            {site.hero_title2}
          </h1>
        </div>

        <!-- Sous-titre + CTA -->
        <div style="opacity:0;animation:fadeSlideIn 0.8s cubic-bezier(0.16,1,0.3,1) 0.85s forwards">
          <p class="font-sans text-sm font-light leading-relaxed text-white/75 max-w-sm mb-10 tracking-wide">
            {site.hero_subtitle}
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/contact"
              class="inline-flex items-center gap-3 font-sans text-xs tracking-[0.2em] uppercase bg-white text-dark px-8 py-4 hover:bg-white/90 transition-all duration-300">
              {site.hero_cta}
              <span class="iconify" data-icon="lucide:arrow-right" data-width="13"></span>
            </a>
            <a href="/services"
              class="inline-flex items-center gap-3 font-sans text-xs tracking-[0.2em] uppercase text-white border border-white/40 px-8 py-4 hover:border-white transition-all duration-300">
              Découvrir
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3 z-10"
      style="opacity:0;animation:fadeSlideIn 0.6s ease 1.2s forwards">
      <div class="w-px h-16 relative overflow-hidden">
        <div class="absolute top-0 w-full bg-white/40" style="height:100%;animation:scrollLine 2s ease-in-out infinite"></div>
      </div>
    </div>
  </section>

  <!-- ── Presse — marquee ──────────────────────────────────────────────── -->
  <section class="py-10 bg-dark overflow-hidden">
    <div class="flex items-center gap-10">
      <div class="marquee-track">
        {[site.press1, site.press2, site.press3, site.press4, site.press1, site.press2, site.press3, site.press4].map((p: string) => (
          <span class="font-serif text-xl font-light italic text-white/40 hover:text-white/70 transition-colors mx-12 cursor-default shrink-0">{p}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- ── À propos ───────────────────────────────────────────────────────── -->
  <section id="about" class="py-28 md:py-40">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="grid md:grid-cols-2 gap-16 md:gap-24 items-center">

        <!-- Image avec décor -->
        <div class="relative reveal-left">
          <div class="relative overflow-hidden">
            <img src={site.about_image} alt={site.about_title2}
              class="w-full aspect-[3/4] object-cover hover:scale-105 transition-transform duration-700" loading="lazy" />
          </div>
          <div class="absolute -bottom-5 -right-5 w-28 h-28 bg-pink hidden md:block"></div>
          <div class="absolute -top-5 -left-5 w-16 h-16 border border-sand hidden md:block"></div>
        </div>

        <!-- Texte -->
        <div class="reveal-right">
          <span class="font-sans text-[11px] tracking-[0.25em] uppercase text-muted mb-5 block reveal reveal-d1">{site.about_badge}</span>
          <h2 class="font-serif text-5xl md:text-6xl font-light leading-tight text-dark">
            {site.about_title}
          </h2>
          <h2 class="font-serif text-5xl md:text-6xl font-light italic leading-tight text-dark mb-8">
            {site.about_title2}
          </h2>
          <div class="w-12 h-px bg-dark/20 mb-8 line-grow"></div>
          <p class="font-sans text-sm font-light leading-[1.9] text-muted mb-5 tracking-wide">{site.about_text1}</p>
          <p class="font-sans text-sm font-light leading-[1.9] text-muted mb-10 tracking-wide">{site.about_text2}</p>
          <a href="/a-propos" class="inline-flex items-center gap-3 font-sans text-xs tracking-[0.2em] uppercase text-dark group">
            {site.about_cta}
            <span class="w-8 h-px bg-dark group-hover:w-14 transition-all duration-400 inline-block"></span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Stats ─────────────────────────────────────────────────────────── -->
  <section class="py-20 bg-dark">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-10 md:gap-6">
        {[
          { n: (site as any).stat1_number, s: (site as any).stat1_suffix || '', l: (site as any).stat1_label },
          { n: (site as any).stat2_number, s: (site as any).stat2_suffix || '', l: (site as any).stat2_label },
          { n: (site as any).stat3_number, s: (site as any).stat3_suffix || '', l: (site as any).stat3_label },
          { n: (site as any).stat4_number, s: (site as any).stat4_suffix || '', l: (site as any).stat4_label },
        ].filter(s => s.n && s.l).map((s, i) => (
          <div class={`text-center reveal reveal-d${i + 1}`}>
            <div class="font-serif text-5xl md:text-6xl font-light text-white mb-2 stat-counter"
              data-target={s.n} data-suffix={s.s}>{s.n}{s.s}</div>
            <p class="font-sans text-[11px] tracking-[0.2em] uppercase text-white/40">{s.l}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Portfolio ──────────────────────────────────────────────────────── -->
  <section id="portfolio" class="py-28 md:py-40">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16 reveal">
        <div>
          <span class="font-sans text-[11px] tracking-[0.25em] uppercase text-muted mb-4 block">{site.portfolio_badge}</span>
          <h2 class="font-serif text-5xl md:text-6xl font-light text-dark">
            {site.portfolio_title} <em class="italic">{site.portfolio_title_em}</em>
          </h2>
        </div>
        <a href="/services" class="font-sans text-xs tracking-[0.18em] uppercase text-muted hover:text-dark transition-colors inline-flex items-center gap-3 shrink-0">
          Tout voir <span class="w-8 h-px bg-current inline-block"></span>
        </a>
      </div>

      <!-- Grille décalée -->
      <div class="grid md:grid-cols-3 gap-6 md:gap-8">
        <div class="group cursor-default reveal reveal-d1">
          <div class="overflow-hidden relative mb-4">
            <img src={site.portfolio1_image} alt={site.portfolio1_title}
              class="w-full aspect-[3/4] object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
            <div class="absolute inset-0 bg-dark/0 group-hover:bg-dark/50 transition-all duration-500 flex items-end p-6">
              <div class="translate-y-4 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-500">
                <a href="/services" class="font-sans text-xs tracking-[0.18em] uppercase text-white inline-flex items-center gap-2">
                  Voir <span class="iconify" data-icon="lucide:arrow-right" data-width="12"></span>
                </a>
              </div>
            </div>
          </div>
          <h3 class="font-serif text-xl font-light text-dark mb-1">{site.portfolio1_title}</h3>
          <span class="font-sans text-[11px] tracking-[0.15em] uppercase text-muted">{site.portfolio1_flavor}</span>
        </div>

        <div class="group cursor-default reveal reveal-d2 md:mt-16">
          <div class="overflow-hidden relative mb-4">
            <img src={site.portfolio2_image} alt={site.portfolio2_title}
              class="w-full aspect-[3/4] object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
            <div class="absolute inset-0 bg-dark/0 group-hover:bg-dark/50 transition-all duration-500 flex items-end p-6">
              <div class="translate-y-4 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-500">
                <a href="/services" class="font-sans text-xs tracking-[0.18em] uppercase text-white inline-flex items-center gap-2">
                  Voir <span class="iconify" data-icon="lucide:arrow-right" data-width="12"></span>
                </a>
              </div>
            </div>
          </div>
          <h3 class="font-serif text-xl font-light text-dark mb-1">{site.portfolio2_title}</h3>
          <span class="font-sans text-[11px] tracking-[0.15em] uppercase text-muted">{site.portfolio2_flavor}</span>
        </div>

        <div class="group cursor-default reveal reveal-d3">
          <div class="overflow-hidden relative mb-4">
            <img src={site.portfolio3_image} alt={site.portfolio3_title}
              class="w-full aspect-[3/4] object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
            <div class="absolute inset-0 bg-dark/0 group-hover:bg-dark/50 transition-all duration-500 flex items-end p-6">
              <div class="translate-y-4 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-500">
                <a href="/services" class="font-sans text-xs tracking-[0.18em] uppercase text-white inline-flex items-center gap-2">
                  Voir <span class="iconify" data-icon="lucide:arrow-right" data-width="12"></span>
                </a>
              </div>
            </div>
          </div>
          <h3 class="font-serif text-xl font-light text-dark mb-1">{site.portfolio3_title}</h3>
          <span class="font-sans text-[11px] tracking-[0.15em] uppercase text-muted">{site.portfolio3_flavor}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Process ────────────────────────────────────────────────────────── -->
  <section id="process" class="py-28 md:py-40 bg-sand/20">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="text-center mb-20 reveal">
        <span class="font-sans text-[11px] tracking-[0.25em] uppercase text-muted mb-4 block">{site.process_badge}</span>
        <h2 class="font-serif text-5xl md:text-6xl font-light text-dark mb-5">{site.process_title}</h2>
        <p class="font-sans text-sm font-light leading-relaxed text-muted max-w-xl mx-auto tracking-wide">{site.process_subtitle}</p>
      </div>
      <div class="grid md:grid-cols-4 gap-10 md:gap-8">
        {[
          { n: '01', t: site.step1_title, d: site.step1_desc },
          { n: '02', t: site.step2_title, d: site.step2_desc },
          { n: '03', t: site.step3_title, d: site.step3_desc },
          { n: '04', t: site.step4_title, d: site.step4_desc },
        ].map((step, i) => (
          <div class={`relative reveal reveal-d${i + 1}`}>
            <div class="font-serif text-[5rem] font-light text-sand/80 leading-none mb-4 select-none">{step.n}</div>
            <div class="w-8 h-px bg-dark/20 mb-6 line-grow"></div>
            <h3 class="font-serif text-2xl font-light text-dark mb-3">{step.t}</h3>
            <p class="font-sans text-sm font-light leading-[1.9] text-muted tracking-wide">{step.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Offres ─────────────────────────────────────────────────────────── -->
  <section id="flavors" class="py-28 md:py-40">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="mb-16 reveal">
        <h2 class="font-serif text-5xl md:text-6xl font-light text-dark">
          {site.flavors_title} <em class="italic">{site.flavors_title_em}</em>
        </h2>
      </div>
      <div class="grid md:grid-cols-3 gap-px bg-sand/40">
        {[
          { tag: site.flavor1_tag, t: site.flavor1_title, d: site.flavor1_desc },
          { tag: site.flavor2_tag, t: site.flavor2_title, d: site.flavor2_desc },
          { tag: site.flavor3_tag, t: site.flavor3_title, d: site.flavor3_desc },
        ].map((f, i) => (
          <div class={`bg-bg p-10 md:p-12 hover:bg-pink/30 transition-colors duration-400 group reveal reveal-d${i + 1}`}>
            <span class="font-sans text-[11px] tracking-[0.2em] uppercase text-muted/70 border border-sand px-3 py-1 mb-8 inline-block group-hover:border-dark/20 transition-colors">{f.tag}</span>
            <h3 class="font-serif text-2xl md:text-3xl font-light text-dark mb-4">{f.t}</h3>
            <p class="font-sans text-sm font-light leading-[1.9] text-muted tracking-wide mb-6">{f.d}</p>
            <a href="/contact" class="font-sans text-[11px] tracking-[0.18em] uppercase text-dark/50 group-hover:text-dark inline-flex items-center gap-2 transition-colors">
              En savoir plus <span class="w-0 group-hover:w-6 h-px bg-dark inline-block transition-all duration-400"></span>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Témoignage ─────────────────────────────────────────────────────── -->
  <section class="py-28 md:py-40 bg-dark relative overflow-hidden">
    <!-- Cercle décoratif -->
    <div class="absolute right-0 top-1/2 -translate-y-1/2 w-96 h-96 border border-white/5 rounded-full -mr-48 hidden md:block"></div>
    <div class="absolute right-24 top-1/2 -translate-y-1/2 w-48 h-48 border border-white/5 rounded-full hidden md:block"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-6 md:px-8 text-center reveal">
      <div class="w-px h-12 bg-white/20 mx-auto mb-10"></div>
      <blockquote class="font-serif text-2xl md:text-4xl font-light italic leading-[1.6] text-white/90 mb-12">
        &ldquo;{site.testimonial_text}&rdquo;
      </blockquote>
      <div class="flex items-center justify-center gap-5">
        <img src={site.testimonial_image} alt={site.testimonial_name}
          class="w-12 h-12 rounded-full object-cover grayscale opacity-50 hover:opacity-80 transition-opacity" loading="lazy" />
        <div class="text-left">
          <p class="font-serif text-base font-light text-white/80">{site.testimonial_name}</p>
          <p class="font-sans text-[11px] tracking-[0.18em] uppercase text-white/30 mt-0.5">{site.testimonial_date}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── FAQ ───────────────────────────────────────────────────────────── -->
  <section class="py-28 md:py-40">
    <div class="max-w-3xl mx-auto px-6 md:px-8">
      <div class="mb-16 reveal">
        <h2 class="font-serif text-5xl md:text-6xl font-light text-dark mb-4">{site.faq_title}</h2>
        <p class="font-sans text-sm font-light text-muted tracking-wide">{site.faq_subtitle}</p>
      </div>
      <div class="divide-y divide-sand/60">
        {[
          { q: site.faq1_q, a: site.faq1_a },
          { q: site.faq2_q, a: site.faq2_a },
          { q: site.faq3_q, a: site.faq3_a },
        ].map((faq, i) => (
          <div class={`faq-item py-7 reveal reveal-d${i + 1}`}>
            <button class="faq-trigger w-full flex items-center justify-between text-left gap-6">
              <span class="font-serif text-xl font-light text-dark">{faq.q}</span>
              <span class="faq-icon shrink-0 w-5 h-5 border border-dark/20 rounded-full flex items-center justify-center transition-all duration-300">
                <span class="iconify" data-icon="lucide:plus" data-width="12"></span>
              </span>
            </button>
            <div class="faq-answer">
              <div class="faq-inner">
                <p class="font-sans text-sm font-light leading-[1.9] text-muted tracking-wide pt-5 pb-2">{faq.a}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA final ──────────────────────────────────────────────────────── -->
  <section class="py-28 md:py-40 bg-dark relative overflow-hidden">
    <div class="absolute inset-0 opacity-20">
      <img src={site.hero_image} alt="" class="w-full h-full object-cover" loading="lazy" aria-hidden="true" />
      <div class="absolute inset-0 bg-dark/80"></div>
    </div>
    <div class="relative z-10 max-w-3xl mx-auto px-6 md:px-8 text-center reveal">
      <span class="font-sans text-[11px] tracking-[0.25em] uppercase text-white/50 mb-6 block">{site.about_badge}</span>
      <h2 class="font-serif text-5xl md:text-7xl font-light text-white mb-8 leading-tight">
        {site.cta_title || site.hero_cta}
      </h2>
      <p class="font-sans text-sm font-light text-white/60 tracking-wide mb-12 max-w-md mx-auto leading-relaxed">
        {site.cta_subtitle || site.hero_subtitle}
      </p>
      <a href="/contact"
        class="inline-flex items-center gap-3 font-sans text-xs tracking-[0.2em] uppercase bg-white text-dark px-10 py-5 hover:bg-white/90 transition-all duration-300">
        {site.hero_cta}
        <span class="iconify" data-icon="lucide:arrow-right" data-width="14"></span>
      </a>
    </div>
  </section>

  <Footer />

  <style>
    @keyframes fadeSlideIn {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes scrollLine {
      0%   { transform: translateY(-100%); opacity: 0; }
      30%  { opacity: 1; }
      70%  { opacity: 1; }
      100% { transform: translateY(100%); opacity: 0; }
    }
  </style>

  <script is:inline>
    // ── FAQ ───────────────────────────────────────────────────────────
    document.querySelectorAll('.faq-item').forEach(function(item) {
      var trigger = item.querySelector('.faq-trigger');
      var answer  = item.querySelector('.faq-answer');
      var icon    = item.querySelector('.faq-icon .iconify');
      trigger.addEventListener('click', function() {
        var isOpen = answer.classList.contains('open');
        document.querySelectorAll('.faq-answer').forEach(function(a) { a.classList.remove('open'); });
        document.querySelectorAll('.faq-icon .iconify').forEach(function(ic) { ic.setAttribute('data-icon', 'lucide:plus'); });
        if (!isOpen) {
          answer.classList.add('open');
          if (icon) icon.setAttribute('data-icon', 'lucide:minus');
        }
      });
    });

    // ── Compteurs animés ──────────────────────────────────────────────
    var statObserver = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (!entry.isIntersecting) return;
        var el = entry.target;
        var target = parseInt(el.dataset.target);
        var suffix = el.dataset.suffix || '';
        if (isNaN(target)) return;
        var start = performance.now();
        var duration = 1800;
        function tick(now) {
          var p = Math.min((now - start) / duration, 1);
          var ease = 1 - Math.pow(1 - p, 4);
          el.textContent = Math.round(ease * target) + suffix;
          if (p < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
        statObserver.unobserve(el);
      });
    }, { threshold: 0.5 });
    document.querySelectorAll('.stat-counter').forEach(function(el) { statObserver.observe(el); });
  </script>

</Base>
