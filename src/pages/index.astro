---
import Base from '../layouts/Base.astro';
import site from '../data/site.json';
---
<Base title={site.seo_title} description={site.seo_description}>

  <div class="loader">
    <span class="loader-text">{site.loader_text}</span>
    <div class="loader-bar"></div>
  </div>

  <nav style="position:fixed;top:0;left:0;width:100%;z-index:1000;padding:1.5rem 3rem;display:flex;justify-content:space-between;align-items:center;mix-blend-mode:difference;">
    <span class="display" style="color:#fff;font-size:1rem;font-weight:700;letter-spacing:0.1em;">{site.company_name}</span>
    <div class="nav-links" style="display:flex;gap:2.5rem;">
      <a href="#services" style="color:#fff;font-size:0.75rem;letter-spacing:0.12em;text-decoration:none;text-transform:uppercase;">Services</a>
      <a href="#clientele" style="color:#fff;font-size:0.75rem;letter-spacing:0.12em;text-decoration:none;text-transform:uppercase;">Clientèle</a>
      <a href="#consultation" style="color:#fff;font-size:0.75rem;letter-spacing:0.12em;text-decoration:none;text-transform:uppercase;">Consultation</a>
      <a href="#contact" style="color:#fff;font-size:0.75rem;letter-spacing:0.12em;text-decoration:none;text-transform:uppercase;">Contact</a>
    </div>
    <button class="nav-mobile-btn" style="display:none;background:none;border:none;cursor:pointer;color:#fff;align-items:center;gap:0.5rem;">
      <iconify-icon icon="solar:hamburger-menu-linear" width="24"></iconify-icon>
      <span style="font-size:0.7rem;letter-spacing:0.15em;text-transform:uppercase;">Menu</span>
    </button>
  </nav>

  <div class="wrapper">

    <section style="position:relative;width:100%;height:100vh;overflow:hidden;display:flex;flex-direction:column;justify-content:center;align-items:center;">
      <img
        src={site.hero_image}
        alt={site.hero_name_line1}
        style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;filter:brightness(0.45);"
      />
      <div style="position:relative;z-index:2;text-align:center;overflow:hidden;padding:0 2rem;">
        <div style="overflow:hidden;line-height:1;">
          <h1 class="display hero-line1" style="font-size:clamp(4rem,14vw,13rem);font-weight:700;color:#fff;margin:0;line-height:0.9;transform:translateY(100%);">{site.hero_name_line1}</h1>
        </div>
        <div style="overflow:hidden;line-height:1;">
          <h1 class="display hero-line2" style="font-size:clamp(4rem,14vw,13rem);font-weight:700;color:#fff;margin:0;line-height:0.9;transform:translateY(100%);">{site.hero_name_line2}</h1>
        </div>
        <p class="hero-subtitle" style="color:rgba(255,255,255,0.75);font-size:clamp(0.9rem,1.5vw,1.2rem);letter-spacing:0.15em;text-transform:uppercase;margin-top:2rem;opacity:0;">{site.hero_subtitle}</p>
      </div>
    </section>

    <section style="padding:8rem 6vw;display:grid;grid-template-columns:1fr 1fr;gap:6rem;align-items:start;" id="intro">
      <div>
        <div style="overflow:hidden;">
          <h2 class="display split-animate" style="font-size:clamp(2rem,4vw,3.5rem);font-weight:700;line-height:1.1;margin:0 0 1.5rem;">{site.intro_title}</h2>
        </div>
        <p class="display" style="font-size:clamp(0.9rem,1.2vw,1rem);opacity:0.6;letter-spacing:0.08em;text-transform:uppercase;margin:0;">{site.intro_subtitle}</p>
      </div>
      <div>
        <p style="font-size:1.05rem;line-height:1.8;color:var(--c-dark);opacity:0.85;margin:0 0 3rem;">{site.intro_text}</p>
        <div style="width:100%;height:1px;background:var(--c-dark);opacity:0.15;margin-bottom:3rem;"></div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:2.5rem;">
          <div style="display:flex;gap:1rem;align-items:flex-start;">
            <iconify-icon icon="solar:medal-star-bold" width="28" style="color:var(--c-accent);flex-shrink:0;margin-top:0.2rem;"></iconify-icon>
            <div>
              <div class="display" style="font-size:2rem;font-weight:700;line-height:1;">{site.stat1_value}</div>
              <div style="font-size:0.8rem;opacity:0.6;margin-top:0.3rem;text-transform:uppercase;letter-spacing:0.08em;">{site.stat1_label}</div>
            </div>
          </div>
          <div style="display:flex;gap:1rem;align-items:flex-start;">
            <iconify-icon icon="solar:users-group-rounded-bold" width="28" style="color:var(--c-accent);flex-shrink:0;margin-top:0.2rem;"></iconify-icon>
            <div>
              <div class="display" style="font-size:2rem;font-weight:700;line-height:1;">{site.stat2_value}</div>
              <div style="font-size:0.8rem;opacity:0.6;margin-top:0.3rem;text-transform:uppercase;letter-spacing:0.08em;">{site.stat2_label}</div>
            </div>
          </div>
          <div style="display:flex;gap:1rem;align-items:flex-start;">
            <iconify-icon icon="solar:document-add-bold" width="28" style="color:var(--c-accent);flex-shrink:0;margin-top:0.2rem;"></iconify-icon>
            <div>
              <div class="display" style="font-size:2rem;font-weight:700;line-height:1;">{site.stat3_value}</div>
              <div style="font-size:0.8rem;opacity:0.6;margin-top:0.3rem;text-transform:uppercase;letter-spacing:0.08em;">{site.stat3_label}</div>
            </div>
          </div>
          <div style="display:flex;gap:1rem;align-items:flex-start;">
            <iconify-icon icon="solar:share-circle-bold" width="28" style="color:var(--c-accent);flex-shrink:0;margin-top:0.2rem;"></iconify-icon>
            <div>
              <div class="display" style="font-size:2rem;font-weight:700;line-height:1;">{site.stat4_value}</div>
              <div style="font-size:0.8rem;opacity:0.6;margin-top:0.3rem;text-transform:uppercase;letter-spacing:0.08em;">{site.stat4_label}</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="stack-section" id="services">
      <div style="padding:6rem 6vw 3rem;text-align:center;">
        <span style="font-size:0.7rem;letter-spacing:0.2em;text-transform:uppercase;opacity:0.5;display:block;margin-bottom:1rem;">{site.services_badge}</span>
        <h2 class="display" style="font-size:clamp(2.5rem,6vw,5rem);font-weight:700;margin:0;">{site.services_title}</h2>
      </div>
      <div class="stack-container">
        <div class="card-item" data-card="0">
          <div class="card-inner">
            <div class="card-content">
              <div>
                <span style="font-size:0.7rem;letter-spacing:0.15em;opacity:0.35;text-transform:uppercase;">{site.service1_number}</span>
                <h3 class="display" style="font-size:clamp(1.8rem,3vw,2.8rem);font-weight:700;margin:1rem 0;line-height:1.1;">{site.service1_title}</h3>
                <span style="display:inline-block;background:var(--c-accent);color:#fff;font-size:0.7rem;letter-spacing:0.1em;text-transform:uppercase;padding:0.4rem 1rem;margin-bottom:1.5rem;">{site.service1_tag}</span>
                <p style="opacity:0.7;line-height:1.75;font-size:0.95rem;">{site.service1_desc}</p>
              </div>
              <a href="#contact" style="display:inline-flex;align-items:center;gap:0.75rem;color:#E3E1DC;text-decoration:none;font-size:0.8rem;letter-spacing:0.12em;text-transform:uppercase;margin-top:2rem;border-top:1px solid rgba(255,255,255,0.1);padding-top:1.5rem;">
                En savoir plus
                <iconify-icon icon="solar:arrow-right-linear" width="18"></iconify-icon>
              </a>
            </div>
            <div class="card-img-wrap">
              <img class="card-img" src={site.service1_image} alt={site.service1_title} />
            </div>
          </div>
        </div>
        <div class="card-item" data-card="1">
          <div class="card-inner">
            <div class="card-content">
              <div>
                <span style="font-size:0.7rem;letter-spacing:0.15em;opacity:0.35;text-transform:uppercase;">{site.service2_number}</span>
                <h3 class="display" style="font-size:clamp(1.8rem,3vw,2.8rem);font-weight:700;margin:1rem 0;line-height:1.1;">{site.service2_title}</h3>
                <span style="display:inline-block;background:var(--c-accent);color:#fff;font-size:0.7rem;letter-spacing:0.1em;text-transform:uppercase;padding:0.4rem 1rem;margin-bottom:1.5rem;">{site.service2_tag}</span>
                <p style="opacity:0.7;line-height:1.75;font-size:0.95rem;">{site.service2_desc}</p>
              </div>
              <a href="#contact" style="display:inline-flex;align-items:center;gap:0.75rem;color:#E3E1DC;text-decoration:none;font-size:0.8rem;letter-spacing:0.12em;text-transform:uppercase;margin-top:2rem;border-top:1px solid rgba(255,255,255,0.1);padding-top:1.5rem;">
                En savoir plus
                <iconify-icon icon="solar:arrow-right-linear" width="18"></iconify-icon>
              </a>
            </div>
            <div class="card-img-wrap">
              <img class="card-img" src={site.service2_image} alt={site.service2_title} />
            </div>
          </div>
        </div>
        <div class="card-item" data-card="2">
          <div class="card-inner">
            <div class="card-content">
              <div>
                <span style="font-size:0.7rem;letter-spacing:0.15em;opacity:0.35;text-transform:uppercase;">{site.service3_number}</span>
                <h3 class="display" style="font-size:clamp(1.8rem,3vw,2.8rem);font-weight:700;margin:1rem 0;line-height:1.1;">{site.service3_title}</h3>
                <span style="display:inline-block;background:var(--c-accent);color:#fff;font-size:0.7rem;letter-spacing:0.1em;text-transform:uppercase;padding:0.4rem 1rem;margin-bottom:1.5rem;">{site.service3_tag}</span>
                <p style="opacity:0.7;line-height:1.75;font-size:0.95rem;">{site.service3_desc}</p>
              </div>
              <a href="#contact" style="display:inline-flex;align-items:center;gap:0.75rem;color:#E3E1DC;text-decoration:none;font-size:0.8rem;letter-spacing:0.12em;text-transform:uppercase;margin-top:2rem;border-top:1px solid rgba(255,255,255,0.1);padding-top:1.5rem;">
                En savoir plus
                <iconify-icon icon="solar:arrow-right-linear" width="18"></iconify-icon>
              </a>
            </div>
            <div class="card-img-wrap">
              <img class="card-img" src={site.service3_image} alt={site.service3_title} />
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="clientele" style="padding:10rem 6vw;display:grid;grid-template-columns:auto 1fr;gap:6rem;align-items:start;">
      <div style="width:1px;background:var(--c-dark);opacity:0.2;height:100%;min-height:16rem;"></div>
      <div>
        <iconify-icon icon="solar:star-bold" width="36" style="color:var(--c-accent);display:block;margin-bottom:2.5rem;"></iconify-icon>
        <h2 class="display" style="font-size:clamp(2rem,4.5vw,4rem);font-weight:700;line-height:1.1;margin:0 0 2rem;max-width:28ch;">{site.clientele_title}</h2>
        <p style="font-size:1.05rem;line-height:1.85;opacity:0.75;max-width:52ch;">{site.clientele_text}</p>
      </div>
    </section>

  </div>

  <footer class="footer-sticky" id="contact" style="overflow:hidden;">
    <div style="position:absolute;inset:0;background-image:url('{site.hero_image}');background-size:cover;background-position:center;opacity:0.08;pointer-events:none;"></div>
    <div style="position:relative;z-index:2;width:100%;padding:0 6vw;display:flex;flex-direction:column;justify-content:center;height:100%;">
      <span style="font-size:0.7rem;letter-spacing:0.2em;text-transform:uppercase;opacity:0.4;margin-bottom:2rem;">{site.footer_cta}</span>
      <a href={`tel:${site.phone}`} class="display" style="font-size:6vw;font-weight:700;color:#fff;text-decoration:none;line-height:1;margin-bottom:3rem;display:block;">{site.phone}</a>
      <p style="opacity:0.5;font-size:0.95rem;max-width:50ch;line-height:1.7;margin-bottom:4rem;">{site.footer_text}</p>
      <div style="display:flex;gap:3rem;border-top:1px solid rgba(255,255,255,0.1);padding-top:2rem;align-items:center;justify-content:space-between;flex-wrap:wrap;">
        <nav style="display:flex;gap:2rem;">
          <a href="#consultation" style="color:rgba(255,255,255,0.5);text-decoration:none;font-size:0.75rem;letter-spacing:0.1em;text-transform:uppercase;">Consultation</a>
          <a href="#services" style="color:rgba(255,255,255,0.5);text-decoration:none;font-size:0.75rem;letter-spacing:0.1em;text-transform:uppercase;">Programmes</a>
          <a href="#intro" style="color:rgba(255,255,255,0.5);text-decoration:none;font-size:0.75rem;letter-spacing:0.1em;text-transform:uppercase;">Médias</a>
          <a href={`mailto:${site.email}`} style="color:rgba(255,255,255,0.5);text-decoration:none;font-size:0.75rem;letter-spacing:0.1em;text-transform:uppercase;">Contact</a>
        </nav>
        <span style="color:rgba(255,255,255,0.3);font-size:0.75rem;">© {new Date().getFullYear()} {site.company_name} — {site.address}</span>
      </div>
    </div>
  </footer>

  <style>
    @media (max-width: 768px) {
      nav .nav-links { display: none !important; }
      .nav-mobile-btn { display: flex !important; }
      #intro { grid-template-columns: 1fr !important; gap: 3rem !important; }
      #clientele { grid-template-columns: 1fr !important; }
      #clientele > div:first-child { display: none !important; }
    }
  </style>

  <script is:inline>
    gsap.registerPlugin(ScrollTrigger);

    const lenis = new Lenis({ duration: 1.2, easing: function(t) { return Math.min(1, 1.001 - Math.pow(2, -10 * t)); }, orientation: 'vertical', smoothWheel: true });

    function raf(time) { lenis.raf(time); requestAnimationFrame(raf); }
    requestAnimationFrame(raf);

    lenis.on('scroll', ScrollTrigger.update);
    gsap.ticker.add(function(time) { lenis.raf(time * 1000); });
    gsap.ticker.lagSmoothing(0);

    var loadTl = gsap.timeline({
      onComplete: function() {
        document.body.style.opacity = 1;
        initSite();
      }
    });

    loadTl
      .to('.loader-bar', { width: '100%', duration: 1.2, ease: 'power2.inOut' })
      .to('.loader-text', { y: -30, opacity: 0, duration: 0.4, ease: 'power2.in' })
      .to('.loader', { yPercent: -100, duration: 0.8, ease: 'power3.inOut' });

    function initSite() {
      gsap.to('.hero-line1', { y: 0, duration: 1.1, ease: 'power3.out', delay: 0.1 });
      gsap.to('.hero-line2', { y: 0, duration: 1.1, ease: 'power3.out', delay: 0.25 });
      gsap.to('.hero-subtitle', { opacity: 1, y: 0, duration: 0.8, ease: 'power2.out', delay: 0.7 });

      gsap.from('.split-animate', {
        scrollTrigger: { trigger: '.split-animate', start: 'top 80%' },
        y: 60, opacity: 0, duration: 0.9, ease: 'power3.out'
      });

      gsap.from('#intro p', {
        scrollTrigger: { trigger: '#intro', start: 'top 75%' },
        y: 40, opacity: 0, duration: 0.9, ease: 'power2.out', delay: 0.2
      });

      gsap.from('#intro .display', {
        scrollTrigger: { trigger: '#intro', start: 'top 75%' },
        y: 20, opacity: 0, duration: 0.7, ease: 'power2.out', stagger: 0.1, delay: 0.35
      });

      var cards = gsap.utils.toArray('.card-item');
      cards.forEach(function(card, i) {
        if (i < cards.length - 1) {
          ScrollTrigger.create({
            trigger: cards[i + 1],
            start: 'top 20%',
            end: 'bottom top',
            onEnter: function() {
              gsap.to(card.querySelector('.card-inner'), { scale: 0.94, opacity: 0.5, duration: 0.5, ease: 'power2.out' });
            },
            onLeaveBack: function() {
              gsap.to(card.querySelector('.card-inner'), { scale: 1, opacity: 1, duration: 0.4, ease: 'power2.out' });
            }
          });
        }
      });

      gsap.from('#clientele h2', {
        scrollTrigger: { trigger: '#clientele', start: 'top 75%' },
        y: 50, opacity: 0, duration: 1, ease: 'power3.out'
      });

      gsap.from('#clientele p', {
        scrollTrigger: { trigger: '#clientele', start: 'top 75%' },
        y: 30, opacity: 0, duration: 0.8, ease: 'power2.out', delay: 0.25
      });
    }
  </script>

</Base>
