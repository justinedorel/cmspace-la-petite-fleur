---
import Base from '../layouts/Base.astro';
import site from '../data/site.json';
---
<Base title={site.seo_title} description={site.seo_description}>

  <!-- NAV -->
  <nav class="sticky top-0 z-50 bg-white border-b border-zinc-100 shadow-sm">
    <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/" class="font-bold text-lg text-zinc-900 tracking-tight">{site.company_name}</a>
      <div class="hidden md:flex items-center gap-8">
        <a href="#fonctionnalites" class="text-sm text-zinc-600 hover:text-zinc-900 transition-colors">Fonctionnalités</a>
        <a href="#workflow" class="text-sm text-zinc-600 hover:text-zinc-900 transition-colors">Workflow</a>
        <a href="#faq" class="text-sm text-zinc-600 hover:text-zinc-900 transition-colors">FAQ</a>
      </div>
      <a href="#" class="bg-accent text-white text-sm font-medium rounded-lg px-4 py-2 hover:opacity-90 transition-opacity">
        {site.nav_cta}
      </a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="py-24 px-6 text-center overflow-hidden">
    <div class="max-w-4xl mx-auto">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 bg-indigo-50 text-accent rounded-full text-sm font-medium px-3 py-1 mb-8">
        <i data-lucide="sparkles" class="w-3.5 h-3.5"></i>
        {site.hero_badge}
      </div>

      <!-- Titre -->
      <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight leading-[1.05] mb-6">
        {site.hero_title1}<br />
        <span class="text-accent">{site.hero_title2}</span>
      </h1>

      <!-- Description -->
      <p class="text-zinc-500 text-lg max-w-2xl mx-auto mb-10 leading-relaxed">
        {site.hero_desc}
      </p>

      <!-- CTA -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3 mb-12">
        <a href="#" class="bg-accent text-white font-semibold rounded-xl px-6 py-3 hover:opacity-90 transition-opacity shadow-lg shadow-indigo-200 flex items-center gap-2">
          {site.hero_cta_primary}
          <i data-lucide="arrow-right" class="w-4 h-4"></i>
        </a>
        <a href="#" class="border border-zinc-200 text-zinc-700 font-medium rounded-xl px-6 py-3 hover:bg-zinc-50 transition-colors flex items-center gap-2">
          <i data-lucide="play-circle" class="w-4 h-4"></i>
          {site.hero_cta_secondary}
        </a>
      </div>

      <!-- Stats -->
      <div class="inline-flex items-center gap-8 bg-zinc-50 rounded-2xl px-8 py-4 border border-zinc-100">
        <div class="text-center">
          <div class="text-2xl font-extrabold text-zinc-900">{site.hero_stat1_value}</div>
          <div class="text-xs text-zinc-500 mt-0.5">{site.hero_stat1_label}</div>
        </div>
        <div class="w-px h-8 bg-zinc-200"></div>
        <div class="text-center">
          <div class="text-2xl font-extrabold text-zinc-900">{site.hero_stat2_value}</div>
          <div class="text-xs text-zinc-500 mt-0.5">{site.hero_stat2_label}</div>
        </div>
        <div class="w-px h-8 bg-zinc-200"></div>
        <div class="text-center">
          <div class="text-2xl font-extrabold text-zinc-900">{site.hero_stat3_value}</div>
          <div class="text-xs text-zinc-500 mt-0.5">{site.hero_stat3_label}</div>
        </div>
      </div>

      <!-- Dashboard Mockup -->
      <div class="bg-zinc-950 rounded-2xl p-6 shadow-2xl max-w-4xl mx-auto mt-16 text-left">
        <!-- Barre de titre mockup -->
        <div class="flex items-center gap-2 mb-6">
          <div class="w-3 h-3 rounded-full bg-red-500"></div>
          <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
          <div class="w-3 h-3 rounded-full bg-green-500"></div>
          <div class="flex-1 bg-zinc-800 rounded-md h-5 ml-4 flex items-center px-3">
            <span class="text-zinc-500 text-xs">app.pulsegrid.io/dashboard</span>
          </div>
        </div>
        <!-- Layout dashboard -->
        <div class="grid grid-cols-4 gap-4">
          <!-- Sidebar -->
          <div class="col-span-1 space-y-1">
            <div class="bg-indigo-600 rounded-lg px-3 py-2 flex items-center gap-2">
              <div class="w-3 h-3 rounded-sm bg-white opacity-80"></div>
              <div class="h-2 bg-white opacity-80 rounded w-14"></div>
            </div>
            <div class="px-3 py-2 flex items-center gap-2">
              <div class="w-3 h-3 rounded-sm bg-zinc-600"></div>
              <div class="h-2 bg-zinc-600 rounded w-10"></div>
            </div>
            <div class="px-3 py-2 flex items-center gap-2">
              <div class="w-3 h-3 rounded-sm bg-zinc-600"></div>
              <div class="h-2 bg-zinc-600 rounded w-16"></div>
            </div>
            <div class="px-3 py-2 flex items-center gap-2">
              <div class="w-3 h-3 rounded-sm bg-zinc-600"></div>
              <div class="h-2 bg-zinc-600 rounded w-12"></div>
            </div>
            <div class="px-3 py-2 flex items-center gap-2">
              <div class="w-3 h-3 rounded-sm bg-zinc-600"></div>
              <div class="h-2 bg-zinc-600 rounded w-8"></div>
            </div>
          </div>
          <!-- Contenu principal -->
          <div class="col-span-3 space-y-4">
            <!-- KPI row -->
            <div class="grid grid-cols-3 gap-3">
              <div class="bg-zinc-900 rounded-xl p-3">
                <div class="h-2 bg-zinc-700 rounded w-12 mb-2"></div>
                <div class="text-white font-bold text-lg">24</div>
                <div class="text-zinc-500 text-xs mt-0.5">Projets actifs</div>
              </div>
              <div class="bg-zinc-900 rounded-xl p-3">
                <div class="h-2 bg-zinc-700 rounded w-16 mb-2"></div>
                <div class="text-white font-bold text-lg">142</div>
                <div class="text-zinc-500 text-xs mt-0.5">Livrables</div>
              </div>
              <div class="bg-zinc-900 rounded-xl p-3">
                <div class="h-2 bg-zinc-700 rounded w-10 mb-2"></div>
                <div class="text-indigo-400 font-bold text-lg">98%</div>
                <div class="text-zinc-500 text-xs mt-0.5">Approbations</div>
              </div>
            </div>
            <!-- Graphe en barres -->
            <div class="bg-zinc-900 rounded-xl p-4">
              <div class="h-2 bg-zinc-700 rounded w-24 mb-4"></div>
              <div class="flex items-end gap-2 h-20">
                <div class="flex-1 bg-indigo-500 rounded-t-sm opacity-60" style="height:45%"></div>
                <div class="flex-1 bg-indigo-500 rounded-t-sm opacity-70" style="height:65%"></div>
                <div class="flex-1 bg-indigo-500 rounded-t-sm opacity-80" style="height:80%"></div>
                <div class="flex-1 bg-indigo-500 rounded-t-sm" style="height:55%"></div>
                <div class="flex-1 bg-indigo-500 rounded-t-sm opacity-90" style="height:90%"></div>
                <div class="flex-1 bg-indigo-600 rounded-t-sm" style="height:100%"></div>
                <div class="flex-1 bg-indigo-500 rounded-t-sm opacity-80" style="height:70%"></div>
              </div>
              <div class="flex gap-2 mt-2">
                <div class="flex-1 h-1.5 bg-zinc-800 rounded"></div>
                <div class="flex-1 h-1.5 bg-zinc-800 rounded"></div>
                <div class="flex-1 h-1.5 bg-zinc-800 rounded"></div>
                <div class="flex-1 h-1.5 bg-zinc-800 rounded"></div>
                <div class="flex-1 h-1.5 bg-zinc-800 rounded"></div>
                <div class="flex-1 h-1.5 bg-zinc-800 rounded"></div>
                <div class="flex-1 h-1.5 bg-zinc-800 rounded"></div>
              </div>
            </div>
            <!-- Liste tâches -->
            <div class="bg-zinc-900 rounded-xl p-4 space-y-2">
              <div class="flex items-center gap-3">
                <div class="w-4 h-4 rounded border-2 border-indigo-500 flex-shrink-0"></div>
                <div class="h-2 bg-zinc-700 rounded flex-1"></div>
                <div class="h-2 bg-green-800 rounded w-12"></div>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-4 h-4 rounded bg-indigo-600 flex-shrink-0 flex items-center justify-center">
                  <div class="w-2 h-0.5 bg-white rotate-45 translate-x-0.5"></div>
                </div>
                <div class="h-2 bg-zinc-700 rounded flex-1 opacity-50"></div>
                <div class="h-2 bg-zinc-700 rounded w-16 opacity-50"></div>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-4 h-4 rounded border-2 border-zinc-700 flex-shrink-0"></div>
                <div class="h-2 bg-zinc-700 rounded w-3/4"></div>
                <div class="h-2 bg-yellow-900 rounded w-10"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section id="fonctionnalites" class="py-24 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight mb-4">{site.features_title}</h2>
        <p class="text-zinc-500 text-lg max-w-2xl mx-auto">{site.features_desc}</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Feature 1 -->
        <div class="group p-6 rounded-2xl border border-zinc-100 hover:border-indigo-100 hover:bg-indigo-50/30 transition-all">
          <div class="bg-indigo-50 rounded-xl p-3 inline-flex mb-4 group-hover:bg-indigo-100 transition-colors">
            <i data-lucide={site.feature1_icon} class="w-5 h-5 text-accent"></i>
          </div>
          <h3 class="font-bold text-zinc-900 mb-2">{site.feature1_title}</h3>
          <p class="text-zinc-500 text-sm leading-relaxed">{site.feature1_desc}</p>
        </div>
        <!-- Feature 2 -->
        <div class="group p-6 rounded-2xl border border-zinc-100 hover:border-indigo-100 hover:bg-indigo-50/30 transition-all">
          <div class="bg-indigo-50 rounded-xl p-3 inline-flex mb-4 group-hover:bg-indigo-100 transition-colors">
            <i data-lucide={site.feature2_icon} class="w-5 h-5 text-accent"></i>
          </div>
          <h3 class="font-bold text-zinc-900 mb-2">{site.feature2_title}</h3>
          <p class="text-zinc-500 text-sm leading-relaxed">{site.feature2_desc}</p>
        </div>
        <!-- Feature 3 -->
        <div class="group p-6 rounded-2xl border border-zinc-100 hover:border-indigo-100 hover:bg-indigo-50/30 transition-all">
          <div class="bg-indigo-50 rounded-xl p-3 inline-flex mb-4 group-hover:bg-indigo-100 transition-colors">
            <i data-lucide={site.feature3_icon} class="w-5 h-5 text-accent"></i>
          </div>
          <h3 class="font-bold text-zinc-900 mb-2">{site.feature3_title}</h3>
          <p class="text-zinc-500 text-sm leading-relaxed">{site.feature3_desc}</p>
        </div>
        <!-- Feature 4 -->
        <div class="group p-6 rounded-2xl border border-zinc-100 hover:border-indigo-100 hover:bg-indigo-50/30 transition-all">
          <div class="bg-indigo-50 rounded-xl p-3 inline-flex mb-4 group-hover:bg-indigo-100 transition-colors">
            <i data-lucide={site.feature4_icon} class="w-5 h-5 text-accent"></i>
          </div>
          <h3 class="font-bold text-zinc-900 mb-2">{site.feature4_title}</h3>
          <p class="text-zinc-500 text-sm leading-relaxed">{site.feature4_desc}</p>
        </div>
        <!-- Feature 5 -->
        <div class="group p-6 rounded-2xl border border-zinc-100 hover:border-indigo-100 hover:bg-indigo-50/30 transition-all">
          <div class="bg-indigo-50 rounded-xl p-3 inline-flex mb-4 group-hover:bg-indigo-100 transition-colors">
            <i data-lucide={site.feature5_icon} class="w-5 h-5 text-accent"></i>
          </div>
          <h3 class="font-bold text-zinc-900 mb-2">{site.feature5_title}</h3>
          <p class="text-zinc-500 text-sm leading-relaxed">{site.feature5_desc}</p>
        </div>
        <!-- Feature 6 -->
        <div class="group p-6 rounded-2xl border border-zinc-100 hover:border-indigo-100 hover:bg-indigo-50/30 transition-all">
          <div class="bg-indigo-50 rounded-xl p-3 inline-flex mb-4 group-hover:bg-indigo-100 transition-colors">
            <i data-lucide={site.feature6_icon} class="w-5 h-5 text-accent"></i>
          </div>
          <h3 class="font-bold text-zinc-900 mb-2">{site.feature6_title}</h3>
          <p class="text-zinc-500 text-sm leading-relaxed">{site.feature6_desc}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- WORKFLOW -->
  <section id="workflow" class="py-24 px-6 bg-zinc-50">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-center mb-16">{site.workflow_title}</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <!-- Step 1 -->
        <div class="text-center md:text-left">
          <div class="text-6xl font-black text-accent leading-none mb-4">{site.workflow_step1_number}</div>
          <h3 class="text-xl font-bold text-zinc-900 mb-3">{site.workflow_step1_title}</h3>
          <p class="text-zinc-500 leading-relaxed">{site.workflow_step1_desc}</p>
        </div>
        <!-- Step 2 -->
        <div class="text-center md:text-left">
          <div class="text-6xl font-black text-accent leading-none mb-4">{site.workflow_step2_number}</div>
          <h3 class="text-xl font-bold text-zinc-900 mb-3">{site.workflow_step2_title}</h3>
          <p class="text-zinc-500 leading-relaxed">{site.workflow_step2_desc}</p>
        </div>
        <!-- Step 3 -->
        <div class="text-center md:text-left">
          <div class="text-6xl font-black text-accent leading-none mb-4">{site.workflow_step3_number}</div>
          <h3 class="text-xl font-bold text-zinc-900 mb-3">{site.workflow_step3_title}</h3>
          <p class="text-zinc-500 leading-relaxed">{site.workflow_step3_desc}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="py-24 px-6">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-center mb-12">{site.faq_title}</h2>
      <div class="space-y-0 border-t border-zinc-100">

        <details class="group">
          <summary class="cursor-pointer font-semibold py-4 border-b border-zinc-100 flex justify-between items-center list-none select-none hover:text-accent transition-colors">
            {site.faq1_q}
            <i data-lucide="chevron-down" class="w-4 h-4 text-zinc-400 flex-shrink-0 ml-4 faq-chevron transition-transform duration-200"></i>
          </summary>
          <p class="text-zinc-500 pb-4 pt-3 leading-relaxed">{site.faq1_a}</p>
        </details>

        <details class="group">
          <summary class="cursor-pointer font-semibold py-4 border-b border-zinc-100 flex justify-between items-center list-none select-none hover:text-accent transition-colors">
            {site.faq2_q}
            <i data-lucide="chevron-down" class="w-4 h-4 text-zinc-400 flex-shrink-0 ml-4 faq-chevron transition-transform duration-200"></i>
          </summary>
          <p class="text-zinc-500 pb-4 pt-3 leading-relaxed">{site.faq2_a}</p>
        </details>

        <details class="group">
          <summary class="cursor-pointer font-semibold py-4 border-b border-zinc-100 flex justify-between items-center list-none select-none hover:text-accent transition-colors">
            {site.faq3_q}
            <i data-lucide="chevron-down" class="w-4 h-4 text-zinc-400 flex-shrink-0 ml-4 faq-chevron transition-transform duration-200"></i>
          </summary>
          <p class="text-zinc-500 pb-4 pt-3 leading-relaxed">{site.faq3_a}</p>
        </details>

        <details class="group">
          <summary class="cursor-pointer font-semibold py-4 border-b border-zinc-100 flex justify-between items-center list-none select-none hover:text-accent transition-colors">
            {site.faq4_q}
            <i data-lucide="chevron-down" class="w-4 h-4 text-zinc-400 flex-shrink-0 ml-4 faq-chevron transition-transform duration-200"></i>
          </summary>
          <p class="text-zinc-500 pb-4 pt-3 leading-relaxed">{site.faq4_a}</p>
        </details>

      </div>
    </div>
  </section>

  <!-- CTA SECTION -->
  <section class="py-24 px-6 bg-zinc-950">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight text-white mb-6">{site.cta_title}</h2>
      <p class="text-zinc-400 text-lg mb-10 leading-relaxed">{site.cta_desc}</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="#" class="bg-accent text-white font-semibold rounded-xl px-6 py-3 hover:opacity-90 transition-opacity shadow-lg shadow-indigo-900/50 flex items-center gap-2">
          {site.cta_primary}
          <i data-lucide="arrow-right" class="w-4 h-4"></i>
        </a>
        <a href="#" class="border border-white/20 text-white font-medium rounded-xl px-6 py-3 hover:bg-white/5 transition-colors flex items-center gap-2">
          <i data-lucide="message-circle" class="w-4 h-4"></i>
          {site.cta_secondary}
        </a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="bg-zinc-950 border-t border-white/5 px-6 py-10">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
      <div>
        <div class="font-bold text-white text-lg mb-1">{site.company_name}</div>
        <div class="text-zinc-500 text-sm">{site.tagline}</div>
      </div>
      <div class="flex items-center gap-4">
        <a href={site.social_twitter} class="text-zinc-500 hover:text-white transition-colors p-2 rounded-lg hover:bg-white/5">
          <i data-lucide="twitter" class="w-4 h-4"></i>
        </a>
        <a href={site.social_linkedin} class="text-zinc-500 hover:text-white transition-colors p-2 rounded-lg hover:bg-white/5">
          <i data-lucide="linkedin" class="w-4 h-4"></i>
        </a>
        <a href={site.social_instagram} class="text-zinc-500 hover:text-white transition-colors p-2 rounded-lg hover:bg-white/5">
          <i data-lucide="instagram" class="w-4 h-4"></i>
        </a>
      </div>
    </div>
    <div class="max-w-6xl mx-auto mt-8 pt-6 border-t border-white/5 text-center text-zinc-600 text-xs">
      &copy; {new Date().getFullYear()} {site.company_name}. Tous droits réservés.
    </div>
  </footer>

  <style is:global>
    details[open] .faq-chevron {
      transform: rotate(180deg);
    }
    html {
      scroll-behavior: smooth;
    }
  </style>

</Base>
