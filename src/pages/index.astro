---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
---
<Base>
  <Header />
  <main>

    <!-- Hero -->
    <section class="pt-20 pb-24 px-6 bg-[var(--color-surface)] overflow-hidden">
      <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
        <div class="space-y-7" data-animate>
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-[var(--color-primary)]/5 border border-[var(--color-primary)]/10 text-[var(--color-primary)] text-xs font-medium">
            <iconify-icon icon="solar:star-fall-linear"></iconify-icon>
            {site.hero_badge}
          </div>
          <h1 class="font-display text-5xl lg:text-6xl font-medium tracking-tight text-[var(--color-text)] leading-[1.1]">
            {site.hero_title_italic === 'true'
              ? <Fragment set:html={site.hero_title.replace(/(\w+\s+\w+)$/, '<em class="text-[var(--color-accent)]">$1</em>')} />
              : site.hero_title
            }
          </h1>
          <p class="text-lg text-[var(--color-text-muted)] max-w-lg leading-relaxed">{site.hero_subtitle}</p>
          <div class="flex flex-wrap gap-4 pt-2">
            <a href={site.hero_cta_primary_href}
              class="bg-[var(--color-primary)] text-white px-7 py-3.5 rounded-xl text-sm font-medium hover:opacity-90 transition-all shadow-md flex items-center gap-2">
              {site.hero_cta_primary}
              <iconify-icon icon="solar:arrow-right-linear"></iconify-icon>
            </a>
            <a href="/contact"
              class="border border-[var(--color-primary)] text-[var(--color-primary)] px-7 py-3.5 rounded-xl text-sm font-medium hover:bg-[var(--color-primary)]/5 transition-all">
              {site.hero_cta_secondary}
            </a>
          </div>
          <div class="flex gap-8 pt-2">
            {[
              [site.hero_stat1_value, site.hero_stat1_label],
              [site.hero_stat2_value, site.hero_stat2_label],
              [site.hero_stat3_value, site.hero_stat3_label],
            ].filter(([v]) => v).map(([v, l]) => (
              <div>
                <div class="font-display text-3xl font-medium text-[var(--color-primary)]">{v}</div>
                <div class="text-xs text-[var(--color-text-muted)] mt-1">{l}</div>
              </div>
            ))}
          </div>
        </div>
        <div class="relative h-[480px] flex items-center justify-end" data-animate="fade-left">
          <div class="absolute inset-0 bg-[var(--color-surface)] rounded-[60%_40%_30%_70%/60%_30%_70%_40%] opacity-60 blur-3xl scale-90 translate-x-10"></div>
          {site.hero_image_url
            ? <img src={site.hero_image_url} alt={site.company_name}
                class="relative z-10 w-[85%] h-full object-cover rounded-[60%_40%_30%_70%/60%_30%_70%_40%] shadow-2xl border-4 border-white" />
            : <div class="relative z-10 w-[85%] h-full bg-[var(--color-primary)]/10 rounded-[60%_40%_30%_70%/60%_30%_70%_40%] flex items-center justify-center">
                <span class="font-display text-2xl text-[var(--color-primary)]/40">{site.company_name}</span>
              </div>
          }
        </div>
      </div>
    </section>

    <!-- Services -->
    <section class="py-24 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-14" data-animate>
          <span class="text-xs font-semibold uppercase tracking-widest text-[var(--color-accent)]">{site.services_subtitle}</span>
          <h2 class="font-display text-4xl font-medium text-[var(--color-text)] mt-3">{site.services_title}</h2>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          {[
            { title: site.service1_title, desc: site.service1_desc, details: [site.service1_detail1, site.service1_detail2, site.service1_detail3] },
            { title: site.service2_title, desc: site.service2_desc, details: [site.service2_detail1, site.service2_detail2, site.service2_detail3] },
            { title: site.service3_title, desc: site.service3_desc, details: [site.service3_detail1, site.service3_detail2, site.service3_detail3] },
          ].map((s, i) => (
            <div class="bg-[var(--color-surface)] rounded-2xl p-7 hover:shadow-lg transition-shadow" data-animate style={`transition-delay: ${i * 100}ms`}>
              <h3 class="font-display text-xl font-medium text-[var(--color-primary)] mb-3">{s.title}</h3>
              <p class="text-sm text-[var(--color-text-muted)] mb-5 leading-relaxed">{s.desc}</p>
              <ul class="space-y-2">
                {s.details.filter(Boolean).map(d => (
                  <li class="flex items-center gap-2 text-sm text-[var(--color-text)]">
                    <iconify-icon icon="solar:check-circle-linear" class="text-[var(--color-accent)] shrink-0"></iconify-icon>
                    {d}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
        <div class="text-center mt-10" data-animate>
          <a href="/services" class="border border-[var(--color-primary)] text-[var(--color-primary)] px-6 py-3 rounded-xl text-sm font-medium hover:bg-[var(--color-primary)]/5 transition-all">
            Voir tous nos services
          </a>
        </div>
      </div>
    </section>

    <!-- Témoignages -->
    <section class="py-24 px-6 bg-[var(--color-surface)]">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-14" data-animate>
          <span class="text-xs font-semibold uppercase tracking-widest text-[var(--color-accent)]">Avis clients</span>
          <h2 class="font-display text-4xl font-medium text-[var(--color-text)] mt-3">{site.testimonials_title}</h2>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          {[
            { name: site.testimonial1_name, role: site.testimonial1_role, text: site.testimonial1_text, rating: site.testimonial1_rating },
            { name: site.testimonial2_name, role: site.testimonial2_role, text: site.testimonial2_text, rating: site.testimonial2_rating },
            { name: site.testimonial3_name, role: site.testimonial3_role, text: site.testimonial3_text, rating: site.testimonial3_rating },
          ].map((t, i) => (
            <div class="bg-white rounded-2xl p-7 shadow-sm" data-animate style={`transition-delay: ${i * 100}ms`}>
              <div class="text-[var(--color-accent)] text-lg mb-4">{'★'.repeat(Number(t.rating) || 5)}</div>
              <p class="text-sm text-[var(--color-text)] leading-relaxed mb-5">« {t.text} »</p>
              <div>
                <div class="font-semibold text-sm text-[var(--color-primary)]">{t.name}</div>
                <div class="text-xs text-[var(--color-text-muted)]">{t.role}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-20 px-6 bg-[var(--color-primary)]">
      <div class="max-w-3xl mx-auto text-center" data-animate>
        <h2 class="font-display text-4xl font-medium text-white mb-4">{site.cta_title}</h2>
        <p class="text-white/75 mb-8">{site.cta_subtitle}</p>
        <a href={site.cta_primary_href}
          class="bg-white text-[var(--color-primary)] px-8 py-4 rounded-xl font-semibold text-sm hover:bg-white/90 transition-all shadow-lg inline-block">
          {site.cta_primary}
        </a>
      </div>
    </section>

  </main>
  <Footer />
</Base>
