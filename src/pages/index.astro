---
import Base from '../layouts/Base.astro';
import site from '../data/site.json';
---
<Base title={site.seo_title} description={site.seo_description}>

<!-- Nav -->
<header class="sticky top-0 z-50 w-full border-b border-zinc-900 bg-zinc-950/80 backdrop-blur-md">
  <div class="container mx-auto px-6 h-16 flex items-center justify-between">
    <a href="#" class="text-xl font-medium tracking-tighter text-zinc-100">{site.company_name}</a>
    <nav class="hidden md:flex items-center gap-8 text-sm text-zinc-400">
      <a href="#services" class="hover:text-zinc-100 transition-colors">Services</a>
      <a href="#work" class="hover:text-zinc-100 transition-colors">Réalisations</a>
      <a href="#contact" class="hover:text-zinc-100 transition-colors">Contact</a>
    </nav>
    <a href="#contact" class="px-4 py-2 text-sm font-medium bg-zinc-100 text-zinc-950 rounded-md hover:bg-zinc-200 transition-colors">
      Démarrer un projet
    </a>
  </div>
</header>

<main class="flex-grow">

  <!-- Hero -->
  <section class="relative pt-32 pb-20 md:pt-48 md:pb-32 overflow-hidden">
    <div class="absolute top-0 inset-x-0 h-screen overflow-hidden -z-10 pointer-events-none flex justify-center">
      <div class="w-full max-w-lg aspect-square bg-zinc-800/20 rounded-full blur-3xl opacity-50 translate-y-[-50%]"></div>
    </div>
    <div class="container mx-auto px-6 text-center flex flex-col items-center">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-zinc-800 bg-zinc-900/50 text-xs text-zinc-400 mb-8 backdrop-blur-sm">
        <span class="flex h-2 w-2 rounded-full bg-emerald-500"></span>
        {site.hero_badge}
      </div>
      <h1 class="text-5xl md:text-7xl font-medium tracking-tight text-zinc-100 max-w-4xl leading-tight mb-6">
        {site.hero_title}
      </h1>
      <p class="text-lg md:text-xl text-zinc-400 max-w-2xl mb-10 font-light">{site.hero_subtitle}</p>
      <div class="flex flex-col sm:flex-row items-center gap-4">
        <a href="#contact" class="w-full sm:w-auto px-6 py-3 text-sm font-medium bg-zinc-100 text-zinc-950 rounded-md hover:bg-zinc-200 transition-colors flex items-center justify-center gap-2">
          {site.hero_cta_primary}
          <iconify-icon icon="solar:arrow-right-linear"></iconify-icon>
        </a>
        <a href="#work" class="w-full sm:w-auto px-6 py-3 text-sm font-medium border border-zinc-800 text-zinc-300 rounded-md hover:bg-zinc-900 hover:text-zinc-100 transition-colors flex items-center justify-center gap-2">
          {site.hero_cta_secondary}
        </a>
      </div>
      <!-- Trust logos -->
      <div class="mt-24 pt-10 border-t border-zinc-900 w-full max-w-5xl">
        <p class="text-xs text-zinc-500 mb-6 uppercase tracking-widest text-center">{site.trust_label}</p>
        <div class="flex flex-wrap justify-center items-center gap-8 md:gap-16 opacity-60 grayscale">
          <span class="text-xl font-medium tracking-tighter text-zinc-400 flex items-center gap-1"><iconify-icon icon={site.trust1_icon}></iconify-icon> {site.trust1_name}</span>
          <span class="text-xl font-medium tracking-tighter text-zinc-400 flex items-center gap-1"><iconify-icon icon={site.trust2_icon}></iconify-icon> {site.trust2_name}</span>
          <span class="text-xl font-medium tracking-tighter text-zinc-400 flex items-center gap-1"><iconify-icon icon={site.trust3_icon}></iconify-icon> {site.trust3_name}</span>
          <span class="text-xl font-medium tracking-tighter text-zinc-400 flex items-center gap-1"><iconify-icon icon={site.trust4_icon}></iconify-icon> {site.trust4_name}</span>
          <span class="text-xl font-medium tracking-tighter text-zinc-400 hidden md:flex items-center gap-1"><iconify-icon icon={site.trust5_icon}></iconify-icon> {site.trust5_name}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="py-20 border-y border-zinc-900 bg-zinc-950/50">
    <div class="container mx-auto px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 divide-x divide-zinc-900">
        <div class="flex flex-col items-center text-center px-4">
          <span class="text-4xl font-medium tracking-tight text-zinc-100 mb-2">{site.stat1_value}</span>
          <span class="text-sm text-zinc-500">{site.stat1_label}</span>
        </div>
        <div class="flex flex-col items-center text-center px-4">
          <span class="text-4xl font-medium tracking-tight text-zinc-100 mb-2">{site.stat2_value}</span>
          <span class="text-sm text-zinc-500">{site.stat2_label}</span>
        </div>
        <div class="flex flex-col items-center text-center px-4">
          <span class="text-4xl font-medium tracking-tight text-zinc-100 mb-2">{site.stat3_value}</span>
          <span class="text-sm text-zinc-500">{site.stat3_label}</span>
        </div>
        <div class="flex flex-col items-center text-center px-4">
          <span class="text-4xl font-medium tracking-tight text-zinc-100 mb-2">{site.stat4_value}</span>
          <span class="text-sm text-zinc-500">{site.stat4_label}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-24 md:py-32" id="services">
    <div class="container mx-auto px-6">
      <div class="max-w-3xl mb-16">
        <h2 class="text-3xl md:text-4xl font-medium tracking-tight text-zinc-100 mb-4">{site.services_title}</h2>
        <p class="text-lg text-zinc-400">{site.services_subtitle}</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {[
          { title: site.service1_title, desc: site.service1_desc, icon: site.service1_icon, li1: site.service1_li1, li2: site.service1_li2, li3: site.service1_li3 },
          { title: site.service2_title, desc: site.service2_desc, icon: site.service2_icon, li1: site.service2_li1, li2: site.service2_li2, li3: site.service2_li3 },
          { title: site.service3_title, desc: site.service3_desc, icon: site.service3_icon, li1: site.service3_li1, li2: site.service3_li2, li3: site.service3_li3 },
          { title: site.service4_title, desc: site.service4_desc, icon: site.service4_icon, li1: site.service4_li1, li2: site.service4_li2, li3: site.service4_li3 },
        ].map(s => (
          <div class="group p-8 rounded-2xl border border-zinc-900 bg-zinc-950 hover:bg-zinc-900/50 transition-all duration-300">
            <div class="h-12 w-12 rounded-lg bg-zinc-900 border border-zinc-800 flex items-center justify-center text-zinc-300 mb-6 group-hover:text-zinc-50 group-hover:border-zinc-700 transition-colors">
              <iconify-icon icon={s.icon} class="text-2xl"></iconify-icon>
            </div>
            <h3 class="text-xl font-medium tracking-tight text-zinc-100 mb-3">{s.title}</h3>
            <p class="text-sm text-zinc-400 leading-relaxed mb-6">{s.desc}</p>
            <ul class="space-y-2 text-sm text-zinc-500">
              <li class="flex items-center gap-2"><iconify-icon icon="solar:check-circle-linear" class="text-zinc-700"></iconify-icon> {s.li1}</li>
              <li class="flex items-center gap-2"><iconify-icon icon="solar:check-circle-linear" class="text-zinc-700"></iconify-icon> {s.li2}</li>
              <li class="flex items-center gap-2"><iconify-icon icon="solar:check-circle-linear" class="text-zinc-700"></iconify-icon> {s.li3}</li>
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Case Studies -->
  <section id="work" class="py-24 border-t border-zinc-900">
    <div class="container mx-auto px-6">
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6">
        <div class="max-w-2xl">
          <h2 class="text-3xl md:text-4xl font-medium tracking-tight text-zinc-100 mb-4">{site.work_title}</h2>
          <p class="text-lg text-zinc-400">{site.work_subtitle}</p>
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { tag: site.case1_tag, icon: site.case1_tag_icon, metric: site.case1_metric, color: site.case1_metric_color, title: site.case1_title, desc: site.case1_desc },
          { tag: site.case2_tag, icon: site.case2_tag_icon, metric: site.case2_metric, color: site.case2_metric_color, title: site.case2_title, desc: site.case2_desc },
          { tag: site.case3_tag, icon: site.case3_tag_icon, metric: site.case3_metric, color: site.case3_metric_color, title: site.case3_title, desc: site.case3_desc },
        ].map(c => (
          <div class="group relative overflow-hidden rounded-2xl border border-zinc-900 bg-zinc-950 aspect-[4/3] flex flex-col justify-between p-8 hover:border-zinc-700 transition-colors">
            <div class="absolute inset-0 bg-gradient-to-br from-zinc-900/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <div class="relative z-10 flex items-center gap-2 text-zinc-500 text-sm">
              <iconify-icon icon={c.icon}></iconify-icon> {c.tag}
            </div>
            <div class="relative z-10">
              <div class={`text-4xl font-medium tracking-tight mb-2 ${c.color}`}>{c.metric}</div>
              <h3 class="text-lg font-medium text-zinc-100 mb-2">{c.title}</h3>
              <p class="text-sm text-zinc-400">{c.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact CTA -->
  <section id="contact" class="py-24 md:py-32 relative overflow-hidden">
    <div class="absolute inset-0 bg-zinc-900/20 border-y border-zinc-800/50"></div>
    <div class="container mx-auto px-6 relative z-10">
      <div class="max-w-4xl mx-auto rounded-3xl border border-zinc-800 bg-zinc-950/80 backdrop-blur-xl p-8 md:p-12 shadow-2xl flex flex-col md:flex-row gap-12">
        <div class="flex-1">
          <h2 class="text-3xl font-medium tracking-tight text-zinc-100 mb-4">{site.cta_title}</h2>
          <p class="text-sm text-zinc-400 mb-8">{site.cta_subtitle}</p>
          <div class="space-y-4 text-sm text-zinc-300">
            <div class="flex items-start gap-3">
              <iconify-icon icon="solar:check-circle-linear" class="text-zinc-500 mt-0.5"></iconify-icon>
              <span>{site.cta_li1}</span>
            </div>
            <div class="flex items-start gap-3">
              <iconify-icon icon="solar:check-circle-linear" class="text-zinc-500 mt-0.5"></iconify-icon>
              <span>{site.cta_li2}</span>
            </div>
            <div class="flex items-start gap-3">
              <iconify-icon icon="solar:check-circle-linear" class="text-zinc-500 mt-0.5"></iconify-icon>
              <span>{site.cta_li3}</span>
            </div>
          </div>
        </div>
        <div class="flex-1 w-full">
          <form class="space-y-4">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div class="space-y-1.5">
                <label class="text-xs font-medium text-zinc-400 px-1">Nom</label>
                <input type="text" placeholder="Jean Dupont" class="w-full bg-zinc-900/50 border border-zinc-800 rounded-lg px-4 py-2.5 text-sm text-zinc-100 placeholder:text-zinc-600 focus:outline-none focus:border-zinc-600 transition-colors" />
              </div>
              <div class="space-y-1.5">
                <label class="text-xs font-medium text-zinc-400 px-1">Email</label>
                <input type="email" placeholder="jean@entreprise.fr" class="w-full bg-zinc-900/50 border border-zinc-800 rounded-lg px-4 py-2.5 text-sm text-zinc-100 placeholder:text-zinc-600 focus:outline-none focus:border-zinc-600 transition-colors" />
              </div>
            </div>
            <div class="space-y-1.5">
              <label class="text-xs font-medium text-zinc-400 px-1">Votre besoin</label>
              <textarea rows="3" placeholder="Décrivez votre projet..." class="w-full bg-zinc-900/50 border border-zinc-800 rounded-lg px-4 py-3 text-sm text-zinc-100 placeholder:text-zinc-600 focus:outline-none focus:border-zinc-600 transition-colors resize-none"></textarea>
            </div>
            <button type="submit" class="w-full py-3 mt-2 text-sm font-medium bg-zinc-100 text-zinc-950 rounded-lg hover:bg-zinc-200 transition-colors flex items-center justify-center gap-2">
              {site.cta_primary}
              <iconify-icon icon="solar:plain-2-linear"></iconify-icon>
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

</main>

<!-- Footer -->
<footer class="border-t border-zinc-900 bg-zinc-950 pt-16 pb-8">
  <div class="container mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-5 gap-12 mb-16">
      <div class="md:col-span-2">
        <a href="#" class="text-xl font-medium tracking-tighter text-zinc-100 flex items-center gap-1 mb-4">
          {site.company_name}
        </a>
        <p class="text-sm text-zinc-400 max-w-sm mb-6">{site.footer_tagline}</p>
        <div class="flex items-center gap-4 text-zinc-500">
          {site.email && <a href={`mailto:${site.email}`} class="hover:text-zinc-100 transition-colors"><iconify-icon icon="solar:letter-linear" class="text-xl"></iconify-icon></a>}
          {site.address && <span class="text-xs text-zinc-600">{site.address}</span>}
        </div>
      </div>
      <div>
        <h4 class="text-sm font-medium text-zinc-100 mb-4">Services</h4>
        <ul class="space-y-3 text-sm text-zinc-400">
          <li><a href="#services" class="hover:text-zinc-100 transition-colors">{site.service1_title}</a></li>
          <li><a href="#services" class="hover:text-zinc-100 transition-colors">{site.service2_title}</a></li>
          <li><a href="#services" class="hover:text-zinc-100 transition-colors">{site.service3_title}</a></li>
          <li><a href="#services" class="hover:text-zinc-100 transition-colors">{site.service4_title}</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-sm font-medium text-zinc-100 mb-4">Contact</h4>
        <ul class="space-y-3 text-sm text-zinc-400">
          {site.email && <li><a href={`mailto:${site.email}`} class="hover:text-zinc-100 transition-colors">{site.email}</a></li>}
          {site.address && <li><span>{site.address}</span></li>}
          {site.social_linkedin && <li><a href={site.social_linkedin} class="hover:text-zinc-100 transition-colors">LinkedIn</a></li>}
        </ul>
      </div>
      <div>
        <h4 class="text-sm font-medium text-zinc-100 mb-4">Légal</h4>
        <ul class="space-y-3 text-sm text-zinc-400">
          <li><a href="#" class="hover:text-zinc-100 transition-colors">Mentions légales</a></li>
          <li><a href="#" class="hover:text-zinc-100 transition-colors">Politique de confidentialité</a></li>
        </ul>
      </div>
    </div>
    <div class="pt-8 border-t border-zinc-900 flex flex-col md:flex-row items-center justify-between gap-4 text-xs text-zinc-500">
      <p>© {new Date().getFullYear()} {site.company_name}{site.legal_status ? ` — ${site.legal_status}` : ''}. Tous droits réservés.</p>
      <div class="flex items-center gap-4">
        <span class="flex h-1.5 w-1.5 rounded-full bg-emerald-500/50"></span>
        <span>Systèmes opérationnels</span>
      </div>
    </div>
  </div>
</footer>

</Base>
