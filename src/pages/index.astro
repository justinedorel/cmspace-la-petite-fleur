---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
---
<Base title={site.seo_title} description={site.seo_description} image={(site as any).hero_image} url={(site as any).website}>

  <Header />

  <!-- ── Hero — deux colonnes ────────────────────────────────────────────── -->
  <section class="min-h-screen flex items-center pt-20" style="background-color:#FDFAF8;">
    <div class="max-w-6xl mx-auto px-6 md:px-8 w-full py-16 md:py-24">
      <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-center">

        <!-- Colonne texte -->
        <div>
          <!-- Badge -->
          <div class="inline-flex items-center gap-2 mb-8" style="opacity:0;animation:fadeUp 0.7s cubic-bezier(0.16,1,0.3,1) 0.2s forwards">
            <span class="w-2 h-2 rounded-full" style="background-color:#D4A5A5;"></span>
            <span class="font-body text-xs tracking-[0.2em] uppercase" style="color:#9E6B6B;">{site.hero_badge}</span>
          </div>

          <!-- Titre -->
          <h1 class="font-display font-medium leading-tight mb-6" style="font-size:clamp(2.5rem,5vw,4rem);color:#1C1C1C;opacity:0;animation:fadeUp 0.8s cubic-bezier(0.16,1,0.3,1) 0.35s forwards">
            {site.hero_title1}<br />
            <em class="font-display italic font-normal" style="color:#9E6B6B;">{site.hero_title2}</em>
          </h1>

          <!-- Sous-titre -->
          <p class="font-body text-base leading-relaxed mb-10" style="color:#9B8B8B;max-width:28rem;opacity:0;animation:fadeUp 0.7s cubic-bezier(0.16,1,0.3,1) 0.5s forwards">
            {site.hero_subtitle}
          </p>

          <!-- CTAs -->
          <div class="flex flex-wrap gap-4" style="opacity:0;animation:fadeUp 0.7s cubic-bezier(0.16,1,0.3,1) 0.65s forwards">
            <a href="/contact/"
              class="inline-flex items-center gap-2 font-body text-sm font-medium text-white px-7 py-3.5 transition-colors duration-300"
              style="background-color:#D4A5A5;"
              onmouseover="this.style.backgroundColor='#9E6B6B'"
              onmouseout="this.style.backgroundColor='#D4A5A5'">
              {site.hero_cta}
              <span class="iconify" data-icon="lucide:arrow-right" data-width="16"></span>
            </a>
            <a href="/services/"
              class="inline-flex items-center gap-2 font-body text-sm font-medium px-7 py-3.5 transition-colors duration-300 border"
              style="color:#9E6B6B;border-color:#EDE0DE;background:transparent;"
              onmouseover="this.style.borderColor='#D4A5A5'"
              onmouseout="this.style.borderColor='#EDE0DE'">
              Voir les services
            </a>
          </div>

          <!-- Indicateurs confiance -->
          <div class="flex items-center gap-6 mt-12" style="opacity:0;animation:fadeUp 0.6s cubic-bezier(0.16,1,0.3,1) 0.8s forwards">
            <div class="text-center">
              <p class="font-display text-2xl font-medium" style="color:#D4A5A5;">500+</p>
              <p class="font-body text-xs" style="color:#9B8B8B;">Clientes satisfaites</p>
            </div>
            <div class="w-px h-8" style="background-color:#EDE0DE;"></div>
            <div class="text-center">
              <p class="font-display text-2xl font-medium" style="color:#D4A5A5;">8 ans</p>
              <p class="font-body text-xs" style="color:#9B8B8B;">d'expertise</p>
            </div>
            <div class="w-px h-8" style="background-color:#EDE0DE;"></div>
            <div class="text-center">
              <p class="font-display text-2xl font-medium" style="color:#D4A5A5;">5★</p>
              <p class="font-body text-xs" style="color:#9B8B8B;">Avis clients</p>
            </div>
          </div>
        </div>

        <!-- Colonne image -->
        <div class="relative" style="opacity:0;animation:fadeUp 0.9s cubic-bezier(0.16,1,0.3,1) 0.4s forwards">
          <div class="relative rounded-2xl overflow-hidden" style="aspect-ratio:4/5;">
            <img src={site.hero_image} alt={site.hero_title1}
              class="w-full h-full object-cover" loading="eager" fetchpriority="high" />
            <!-- Overlay subtil -->
            <div class="absolute inset-0" style="background:linear-gradient(to bottom, transparent 60%, rgba(212,165,165,0.15) 100%);"></div>
          </div>
          <!-- Décoration -->
          <div class="absolute -bottom-4 -left-4 w-24 h-24 rounded-full hidden md:block" style="background-color:#F9F0EE;z-index:-1;"></div>
          <div class="absolute -top-4 -right-4 w-16 h-16 rounded-full hidden md:block" style="border:2px solid #EDE0DE;z-index:-1;"></div>
          <!-- Badge flottant -->
          <div class="absolute bottom-6 left-6 bg-white rounded-xl px-4 py-3 shadow-lg">
            <p class="font-body text-xs font-medium" style="color:#1C1C1C;">Réservation en ligne</p>
            <p class="font-body text-xs" style="color:#9B8B8B;">7j/7 disponible</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Nos Prestations ──────────────────────────────────────────────────── -->
  <section class="py-24 md:py-32" style="background-color:#F9F0EE;">
    <div class="max-w-6xl mx-auto px-6 md:px-8">

      <!-- En-tête section -->
      <div class="text-center mb-16 reveal">
        <span class="font-body text-xs tracking-[0.22em] uppercase mb-3 block" style="color:#9E6B6B;">Nos expertises</span>
        <h2 class="font-display text-4xl md:text-5xl font-medium" style="color:#1C1C1C;">Nos Prestations</h2>
        <p class="font-body text-base mt-4 max-w-lg mx-auto" style="color:#9B8B8B;">Des soins sur mesure pour des ongles parfaits, dans un cadre élégant et apaisant.</p>
      </div>

      <!-- Cards services — horizontales -->
      <div class="grid md:grid-cols-2 gap-6">
        {[
          { name: site.service1_name, duration: site.service1_duration, price: site.service1_price, desc: site.service1_desc, img: site.service1_image },
          { name: site.service2_name, duration: site.service2_duration, price: site.service2_price, desc: site.service2_desc, img: site.service2_image },
          { name: site.service3_name, duration: site.service3_duration, price: site.service3_price, desc: site.service3_desc, img: site.service3_image },
          { name: site.service4_name, duration: site.service4_duration, price: site.service4_price, desc: site.service4_desc, img: site.service4_image },
        ].map((s, i) => (
          <div class={`flex gap-5 bg-bg rounded-2xl p-5 border reveal reveal-d${i % 2 + 1}`} style="border-color:#EDE0DE;">
            <!-- Photo -->
            <div class="shrink-0 w-28 h-28 rounded-xl overflow-hidden">
              <img src={s.img} alt={s.name} class="w-full h-full object-cover" loading="lazy" />
            </div>
            <!-- Contenu -->
            <div class="flex flex-col justify-between min-w-0">
              <div>
                <div class="flex items-start justify-between gap-2 mb-1">
                  <h3 class="font-display text-lg font-medium" style="color:#1C1C1C;">{s.name}</h3>
                  <span class="font-body text-xs shrink-0 mt-0.5" style="color:#9E6B6B;">{s.duration}</span>
                </div>
                <p class="font-body text-sm leading-relaxed" style="color:#9B8B8B;">{s.desc}</p>
              </div>
              <div class="flex items-center justify-between mt-3">
                <span class="font-body text-sm font-medium" style="color:#D4A5A5;">{s.price}</span>
                <a href="/contact/"
                  class="font-body text-xs font-medium text-white px-4 py-2 rounded-lg transition-colors duration-200"
                  style="background-color:#D4A5A5;"
                  onmouseover="this.style.backgroundColor='#9E6B6B'"
                  onmouseout="this.style.backgroundColor='#D4A5A5'">
                  Réserver
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="text-center mt-10 reveal">
        <a href="/services/"
          class="inline-flex items-center gap-2 font-body text-sm border px-6 py-3 transition-colors duration-300"
          style="color:#9E6B6B;border-color:#D4A5A5;"
          onmouseover="this.style.backgroundColor='#F9F0EE'"
          onmouseout="this.style.backgroundColor='transparent'">
          Voir tous nos services
          <span class="iconify" data-icon="lucide:arrow-right" data-width="14"></span>
        </a>
      </div>
    </div>
  </section>

  <!-- ── Galerie ──────────────────────────────────────────────────────────── -->
  <section class="py-24 md:py-32" style="background-color:#FDFAF8;">
    <div class="max-w-6xl mx-auto px-6 md:px-8">

      <div class="text-center mb-14 reveal">
        <span class="font-body text-xs tracking-[0.22em] uppercase mb-3 block" style="color:#9E6B6B;">Inspirations</span>
        <h2 class="font-display text-4xl md:text-5xl font-medium" style="color:#1C1C1C;">Notre Galerie</h2>
      </div>

      <!-- Grille 6 photos -->
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        {[
          site.gallery1_image,
          site.gallery2_image,
          site.gallery3_image,
          site.gallery4_image,
          site.gallery5_image,
          site.gallery6_image,
        ].map((img, i) => (
          <div class={`overflow-hidden rounded-xl reveal reveal-d${(i % 3) + 1}`}>
            <img src={img} alt={`Nail art ${i + 1}`}
              class="w-full aspect-square object-cover hover:scale-105 transition-transform duration-700"
              loading="lazy" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Témoignages ─────────────────────────────────────────────────────── -->
  <section class="py-24 md:py-32" style="background-color:#F9F0EE;">
    <div class="max-w-6xl mx-auto px-6 md:px-8">

      <div class="text-center mb-14 reveal">
        <span class="font-body text-xs tracking-[0.22em] uppercase mb-3 block" style="color:#9E6B6B;">Ce qu'elles disent</span>
        <h2 class="font-display text-4xl md:text-5xl font-medium" style="color:#1C1C1C;">Avis Clients</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {[
          { text: site.review1_text, name: site.review1_name },
          { text: site.review2_text, name: site.review2_name },
          { text: site.review3_text, name: site.review3_name },
        ].map((r, i) => (
          <div class={`bg-bg rounded-2xl p-8 border reveal reveal-d${i + 1}`} style="border-color:#EDE0DE;">
            <!-- Étoiles -->
            <div class="flex gap-1 mb-5">
              {[1,2,3,4,5].map(() => (
                <span class="iconify" data-icon="lucide:star" data-width="14" style="color:#D4A5A5;"></span>
              ))}
            </div>
            <p class="font-body text-sm leading-relaxed mb-6" style="color:#1C1C1C;">"{r.text}"</p>
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-full flex items-center justify-center text-white font-display font-medium text-sm" style="background-color:#D4A5A5;">
                {r.name.charAt(0)}
              </div>
              <p class="font-body text-sm font-medium" style="color:#1C1C1C;">{r.name}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Réservation ─────────────────────────────────────────────────────── -->
  <section class="py-24 md:py-32" style="background-color:#FDFAF8;">
    <div class="max-w-4xl mx-auto px-6 md:px-8">

      <div class="text-center mb-14 reveal">
        <span class="font-body text-xs tracking-[0.22em] uppercase mb-3 block" style="color:#9E6B6B;">Prendre rendez-vous</span>
        <h2 class="font-display text-4xl md:text-5xl font-medium" style="color:#1C1C1C;">Réserver en ligne</h2>
        <p class="font-body text-base mt-4" style="color:#9B8B8B;">Choisissez votre créneau, on s'occupe du reste.</p>
      </div>

      <div class="bg-surface rounded-2xl p-8 md:p-12 border reveal" style="border-color:#EDE0DE;">
        <form class="grid md:grid-cols-2 gap-6" action="/merci/" method="POST">
          <!-- Nom -->
          <div>
            <label class="block font-body text-sm font-medium mb-2" style="color:#1C1C1C;">Votre nom</label>
            <input type="text" name="name" placeholder="Marie Dupont" required
              class="w-full font-body text-sm px-4 py-3 rounded-xl border bg-bg outline-none transition-colors focus:border-accent"
              style="border-color:#EDE0DE;color:#1C1C1C;" />
          </div>
          <!-- Email -->
          <div>
            <label class="block font-body text-sm font-medium mb-2" style="color:#1C1C1C;">Email</label>
            <input type="email" name="email" placeholder="marie@email.fr" required
              class="w-full font-body text-sm px-4 py-3 rounded-xl border bg-bg outline-none transition-colors focus:border-accent"
              style="border-color:#EDE0DE;color:#1C1C1C;" />
          </div>
          <!-- Service -->
          <div>
            <label class="block font-body text-sm font-medium mb-2" style="color:#1C1C1C;">Service souhaité</label>
            <select name="service"
              class="w-full font-body text-sm px-4 py-3 rounded-xl border bg-bg outline-none transition-colors focus:border-accent"
              style="border-color:#EDE0DE;color:#1C1C1C;">
              <option value="">Choisir un service…</option>
              <option>{site.service1_name}</option>
              <option>{site.service2_name}</option>
              <option>{site.service3_name}</option>
              <option>{site.service4_name}</option>
            </select>
          </div>
          <!-- Date -->
          <div>
            <label class="block font-body text-sm font-medium mb-2" style="color:#1C1C1C;">Date souhaitée</label>
            <input type="date" name="date"
              class="w-full font-body text-sm px-4 py-3 rounded-xl border bg-bg outline-none transition-colors focus:border-accent"
              style="border-color:#EDE0DE;color:#1C1C1C;" />
          </div>
          <!-- Message -->
          <div class="md:col-span-2">
            <label class="block font-body text-sm font-medium mb-2" style="color:#1C1C1C;">Message (optionnel)</label>
            <textarea name="message" rows="3" placeholder="Précisez vos envies, couleurs souhaitées…"
              class="w-full font-body text-sm px-4 py-3 rounded-xl border bg-bg outline-none transition-colors focus:border-accent resize-none"
              style="border-color:#EDE0DE;color:#1C1C1C;"></textarea>
          </div>
          <!-- Submit -->
          <div class="md:col-span-2 text-center">
            <button type="submit"
              class="inline-flex items-center gap-2 font-body text-sm font-medium text-white px-10 py-4 rounded-xl transition-colors duration-300"
              style="background-color:#D4A5A5;"
              onmouseover="this.style.backgroundColor='#9E6B6B'"
              onmouseout="this.style.backgroundColor='#D4A5A5'">
              Envoyer ma demande
              <span class="iconify" data-icon="lucide:send" data-width="16"></span>
            </button>
          </div>
        </form>
      </div>
    </div>
  </section>

  <Footer />

  <style>
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }
  </style>

</Base>
