---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
---
<Base title={site.seo_title} description={site.seo_description}>
  <Header />

  <!-- Hero -->
  <section class="relative min-h-[90vh] flex items-center overflow-hidden">
    <img src={site.hero_image} alt="Champs" class="absolute inset-0 w-full h-full object-cover" />
    <div class="absolute inset-0 bg-[#1C2B1C]/55"></div>
    <div class="relative z-10 max-w-6xl mx-auto px-6 py-24">
      <div class="max-w-2xl">
        <span class="inline-flex items-center gap-2 bg-[#E8D5A3]/20 border border-[#E8D5A3]/30 text-[#E8D5A3] text-xs font-semibold tracking-widest uppercase px-4 py-2 rounded-full mb-8">
          Agriculture raisonnée · Nord de France
        </span>
        <h1 class="font-display text-5xl sm:text-6xl lg:text-7xl font-bold text-white leading-tight mb-6">
          {site.hero_title}<br />
          <span class="text-[#E8D5A3] italic font-normal">{site.hero_title_accent}</span>
        </h1>
        <p class="text-white/80 text-lg leading-relaxed mb-10 max-w-xl">{site.hero_subtitle}</p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/services/" class="bg-[#E8D5A3] text-[#1C2B1C] font-semibold px-8 py-4 rounded-full hover:bg-white transition-colors text-sm text-center">
            {site.hero_cta_primary}
          </a>
          <a href="/contact/" class="border border-white/40 text-white font-semibold px-8 py-4 rounded-full hover:bg-white/10 transition-colors text-sm text-center">
            {site.hero_cta_secondary}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="bg-[#2D4A2D] py-12">
    <div class="max-w-6xl mx-auto px-6 grid grid-cols-3 divide-x divide-[#E8D5A3]/20">
      {[
        { v: site.stat1_value, u: site.stat1_unit, l: site.stat1_label },
        { v: site.stat2_value, u: site.stat2_unit, l: site.stat2_label },
        { v: site.stat3_value, u: site.stat3_unit, l: site.stat3_label },
      ].map(s => (
        <div class="text-center px-6">
          <p class="font-display text-4xl font-bold text-[#E8D5A3]">{s.v}<span class="text-2xl">{s.u}</span></p>
          <p class="text-white/60 text-sm mt-1">{s.l}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Produits phares -->
  <section class="py-24 bg-[#F9F7F2]">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <p class="text-[#6B7C6B] text-sm font-semibold tracking-widest uppercase mb-3">Ce que nous cultivons</p>
        <h2 class="font-display text-4xl font-bold text-[#1C2B1C]">Nos productions</h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { name: site.product1_name, desc: site.product1_desc, img: site.product1_image },
          { name: site.product2_name, desc: site.product2_desc, img: site.product2_image },
          { name: site.product3_name, desc: site.product3_desc, img: site.product3_image },
          { name: site.product4_name, desc: site.product4_desc, img: site.product4_image },
        ].map(p => (
          <div class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow">
            <div class="h-48 overflow-hidden">
              <img src={p.img} alt={p.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            </div>
            <div class="p-5">
              <h3 class="font-display font-semibold text-[#1C2B1C] mb-2">{p.name}</h3>
              <p class="text-[#6B7C6B] text-sm leading-relaxed">{p.desc}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/services/" class="inline-flex items-center gap-2 border-2 border-[#2D4A2D] text-[#2D4A2D] font-semibold px-8 py-3 rounded-full hover:bg-[#2D4A2D] hover:text-white transition-colors text-sm">
          Voir tous nos produits →
        </a>
      </div>
    </div>
  </section>

  <!-- À propos résumé -->
  <section class="py-24 bg-[#EDE8DE]">
    <div class="max-w-6xl mx-auto px-6 grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <p class="text-[#6B7C6B] text-sm font-semibold tracking-widest uppercase mb-4">Notre histoire</p>
        <h2 class="font-display text-4xl font-bold text-[#1C2B1C] mb-6">{site.about_title}</h2>
        <p class="text-[#6B7C6B] leading-relaxed mb-8">{site.about_text}</p>
        <div class="grid grid-cols-3 gap-4 mb-8">
          {[
            { t: site.value1_title, d: site.value1_desc },
            { t: site.value2_title, d: site.value2_desc },
            { t: site.value3_title, d: site.value3_desc },
          ].map(v => (
            <div class="bg-white rounded-xl p-4">
              <p class="font-semibold text-[#2D4A2D] text-sm mb-1">{v.t}</p>
              <p class="text-[#6B7C6B] text-xs leading-relaxed">{v.d}</p>
            </div>
          ))}
        </div>
        <a href="/a-propos/" class="inline-flex items-center gap-2 text-[#2D4A2D] font-semibold text-sm hover:underline">
          En savoir plus sur le domaine →
        </a>
      </div>
      <div class="rounded-2xl overflow-hidden shadow-lg h-96">
        <img src={site.about_image} alt="Le domaine" class="w-full h-full object-cover" />
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <section class="py-20 bg-[#2D4A2D]">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="font-display text-4xl font-bold text-white mb-4">Vous êtes restaurateur, distributeur ou particulier ?</h2>
      <p class="text-white/70 mb-8 leading-relaxed">Contactez-nous pour une commande pro ou pour visiter le domaine.</p>
      <a href="/contact/" class="inline-block bg-[#E8D5A3] text-[#1C2B1C] font-semibold px-10 py-4 rounded-full hover:bg-white transition-colors">
        {site.hero_cta_secondary}
      </a>
    </div>
  </section>

  <Footer />
</Base>
