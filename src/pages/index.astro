---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
---
<Base title={site.seo_title} description={site.seo_description} image={(site as any).hero_image} url={(site as any).website}>

  <Header />

  <!-- ── 1. HERO — deux colonnes ──────────────────────────────────────── -->
  <section class="min-h-screen flex items-center pt-20" style="background:#FAF8F5">
    <div class="max-w-7xl mx-auto px-6 md:px-8 w-full py-16 md:py-24">
      <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-center">

        <!-- Colonne texte -->
        <div style="opacity:0;animation:fadeUp 0.9s cubic-bezier(0.16,1,0.3,1) 0.2s forwards">
          <p class="font-sans text-xs tracking-[0.28em] uppercase mb-6" style="color:#C4956A">Studio de beauté — Paris</p>
          <h1 class="font-serif text-5xl sm:text-6xl md:text-7xl font-light leading-[1.05] mb-6" style="color:#1A1A1A">
            {site.hero_title}
          </h1>
          <div style="width:3rem;height:1px;background:#C4956A;margin-bottom:1.5rem"></div>
          <p class="font-sans text-sm font-light leading-relaxed mb-10 max-w-sm" style="color:#8A7E75">
            {site.hero_subtitle}
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/contact/"
              class="inline-flex items-center gap-3 font-sans text-xs tracking-[0.2em] uppercase px-8 py-4 transition-all duration-300"
              style="background:#C4956A;color:#fff">
              {site.hero_cta}
              <span class="iconify" data-icon="lucide:arrow-right" data-width="13"></span>
            </a>
            <a href="/services/"
              class="inline-flex items-center gap-3 font-sans text-xs tracking-[0.2em] uppercase px-8 py-4 transition-all duration-300"
              style="border:1px solid #E8E0D8;color:#8A7E75">
              Nos services
            </a>
          </div>
        </div>

        <!-- Colonne image portrait -->
        <div class="relative" style="opacity:0;animation:fadeUp 0.9s cubic-bezier(0.16,1,0.3,1) 0.4s forwards">
          <div class="overflow-hidden" style="aspect-ratio:3/4">
            <img src={site.hero_image} alt={site.hero_title}
              class="w-full h-full object-cover"
              loading="eager" fetchpriority="high" />
          </div>
          <!-- Décor accent -->
          <div class="absolute -bottom-4 -left-4 w-24 h-24 hidden md:block" style="background:#F2EDE8;z-index:-1"></div>
          <div class="absolute -top-4 -right-4 w-16 h-16 hidden md:block" style="border:1px solid #E8E0D8;z-index:-1"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── 2. POURQUOI NOUS — 4 cards numérotées ────────────────────────── -->
  <section class="py-24 md:py-32" style="background:#F2EDE8">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="mb-16 reveal">
        <p class="font-sans text-xs tracking-[0.28em] uppercase mb-4" style="color:#C4956A">Notre différence</p>
        <h2 class="font-serif text-4xl md:text-5xl font-light" style="color:#1A1A1A">POURQUOI NOUS ?</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {[
          { num: (site as any).why1_num, title: (site as any).why1_title, desc: (site as any).why1_desc },
          { num: (site as any).why2_num, title: (site as any).why2_title, desc: (site as any).why2_desc },
          { num: (site as any).why3_num, title: (site as any).why3_title, desc: (site as any).why3_desc },
          { num: (site as any).why4_num, title: (site as any).why4_title, desc: (site as any).why4_desc },
        ].map((card: any, i: number) => (
          <div class={`p-8 reveal reveal-d${i + 1}`} style="background:#FAF8F5;border:1px solid #E8E0D8">
            <p class="font-serif text-5xl font-light mb-5 select-none" style="color:#E8E0D8">{card.num}</p>
            <div style="width:2rem;height:1px;background:#C4956A;margin-bottom:1rem"></div>
            <h3 class="font-serif text-xl font-semibold mb-3" style="color:#1A1A1A">{card.title}</h3>
            <p class="font-sans text-sm font-light leading-relaxed" style="color:#8A7E75">{card.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── 3. SERVICES — onglets Cosmétologie / Ongles ──────────────────── -->
  <section class="py-24 md:py-32" style="background:#FAF8F5">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="mb-12 reveal">
        <p class="font-sans text-xs tracking-[0.28em] uppercase mb-4" style="color:#C4956A">Ce que nous proposons</p>
        <h2 class="font-serif text-4xl md:text-5xl font-light" style="color:#1A1A1A">NOS SERVICES</h2>
      </div>

      <!-- Onglets -->
      <div class="flex gap-0 mb-10 reveal" style="border-bottom:1px solid #E8E0D8">
        <button class="tab-btn active font-sans text-xs tracking-[0.2em] uppercase px-8 py-3 transition-all duration-200" data-tab="tab-cosmetologie"
          style="color:#8A7E75;border-bottom:2px solid transparent">
          Cosmétologie
        </button>
        <button class="tab-btn font-sans text-xs tracking-[0.2em] uppercase px-8 py-3 transition-all duration-200" data-tab="tab-ongles"
          style="color:#8A7E75;border-bottom:2px solid transparent">
          Ongles
        </button>
      </div>

      <!-- Grille Cosmétologie -->
      <div id="tab-cosmetologie" class="tab-content active grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="group overflow-hidden reveal reveal-d1" style="background:#F2EDE8">
          <div class="overflow-hidden" style="aspect-ratio:4/3">
            <img src={(site as any).service1_image} alt={(site as any).service1_name}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
          </div>
          <p class="font-serif text-lg font-light px-6 py-4" style="color:#1A1A1A">{(site as any).service1_name}</p>
        </div>
        <div class="group overflow-hidden reveal reveal-d2" style="background:#F2EDE8">
          <div class="overflow-hidden" style="aspect-ratio:4/3">
            <img src={(site as any).service2_image} alt={(site as any).service2_name}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
          </div>
          <p class="font-serif text-lg font-light px-6 py-4" style="color:#1A1A1A">{(site as any).service2_name}</p>
        </div>
        <div class="group overflow-hidden reveal reveal-d3" style="background:#F2EDE8">
          <div class="overflow-hidden" style="aspect-ratio:4/3">
            <img src={(site as any).service3_image} alt={(site as any).service3_name}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
          </div>
          <p class="font-serif text-lg font-light px-6 py-4" style="color:#1A1A1A">{(site as any).service3_name}</p>
        </div>
        <div class="group overflow-hidden reveal reveal-d2" style="background:#F2EDE8">
          <div class="overflow-hidden" style="aspect-ratio:4/3">
            <img src={(site as any).service4_image} alt={(site as any).service4_name}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
          </div>
          <p class="font-serif text-lg font-light px-6 py-4" style="color:#1A1A1A">{(site as any).service4_name}</p>
        </div>
        <div class="group overflow-hidden reveal reveal-d3" style="background:#F2EDE8">
          <div class="overflow-hidden" style="aspect-ratio:4/3">
            <img src={(site as any).service5_image} alt={(site as any).service5_name}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
          </div>
          <p class="font-serif text-lg font-light px-6 py-4" style="color:#1A1A1A">{(site as any).service5_name}</p>
        </div>
        <div class="group overflow-hidden reveal reveal-d4" style="background:#F2EDE8">
          <div class="overflow-hidden" style="aspect-ratio:4/3">
            <img src={(site as any).service6_image} alt={(site as any).service6_name}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
          </div>
          <p class="font-serif text-lg font-light px-6 py-4" style="color:#1A1A1A">{(site as any).service6_name}</p>
        </div>
      </div>

      <!-- Grille Ongles -->
      <div id="tab-ongles" class="tab-content grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="group overflow-hidden" style="background:#F2EDE8">
          <div class="overflow-hidden" style="aspect-ratio:4/3">
            <img src={(site as any).featured_image} alt={(site as any).featured_name}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
          </div>
          <p class="font-serif text-lg font-light px-6 py-4" style="color:#1A1A1A">{(site as any).featured_name}</p>
        </div>
        <div class="group overflow-hidden" style="background:#F2EDE8">
          <div class="overflow-hidden" style="aspect-ratio:4/3">
            <img src={(site as any).service5_image} alt="Manucure classique"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
          </div>
          <p class="font-serif text-lg font-light px-6 py-4" style="color:#1A1A1A">Manucure Classique</p>
        </div>
        <div class="group overflow-hidden" style="background:#F2EDE8">
          <div class="overflow-hidden" style="aspect-ratio:4/3">
            <img src={(site as any).service1_image} alt="Pose gel"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
          </div>
          <p class="font-serif text-lg font-light px-6 py-4" style="color:#1A1A1A">Pose Gel & Semi-permanent</p>
        </div>
      </div>

      <div class="mt-10 reveal">
        <a href="/services/" class="inline-flex items-center gap-3 font-sans text-xs tracking-[0.2em] uppercase transition-colors" style="color:#C4956A">
          Voir tous les services
          <span class="iconify" data-icon="lucide:arrow-right" data-width="13"></span>
        </a>
      </div>
    </div>
  </section>

  <!-- ── 4. PROCÉDURE VEDETTE — deux colonnes ─────────────────────────── -->
  <section class="py-24 md:py-32" style="background:#F2EDE8">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="grid md:grid-cols-2 gap-12 md:gap-20 items-center">

        <!-- Photo gauche -->
        <div class="reveal-left overflow-hidden" style="aspect-ratio:3/4">
          <img src={(site as any).featured_image} alt={(site as any).featured_name}
            class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" loading="lazy" />
        </div>

        <!-- Texte droite -->
        <div class="reveal-right">
          <p class="font-sans text-xs tracking-[0.28em] uppercase mb-4" style="color:#C4956A">Procédure vedette</p>
          <h2 class="font-serif text-4xl md:text-5xl font-light mb-6" style="color:#1A1A1A">{(site as any).featured_name}</h2>
          <div style="width:3rem;height:1px;background:#C4956A;margin-bottom:1.5rem"></div>
          <p class="font-sans text-sm font-light leading-relaxed mb-6" style="color:#8A7E75">{(site as any).featured_desc}</p>
          <p class="font-sans text-sm font-light leading-relaxed mb-8 italic" style="color:#8A7E75">{(site as any).featured_for}</p>
          <div class="flex gap-8 mb-10">
            <div>
              <p class="font-sans text-xs tracking-[0.18em] uppercase mb-1" style="color:#8A7E75">Durée</p>
              <p class="font-serif text-xl font-light" style="color:#1A1A1A">{(site as any).featured_duration}</p>
            </div>
            <div style="width:1px;background:#E8E0D8"></div>
            <div>
              <p class="font-sans text-xs tracking-[0.18em] uppercase mb-1" style="color:#8A7E75">Tarif</p>
              <p class="font-serif text-xl font-light" style="color:#C4956A">{(site as any).featured_price}</p>
            </div>
          </div>
          <a href="/contact/"
            class="inline-flex items-center gap-3 font-sans text-xs tracking-[0.2em] uppercase px-8 py-4 transition-all duration-300"
            style="background:#C4956A;color:#fff">
            {site.hero_cta}
            <span class="iconify" data-icon="lucide:arrow-right" data-width="13"></span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── 5. TÉMOIGNAGES — 3 avis ──────────────────────────────────────── -->
  <section class="py-24 md:py-32" style="background:#FAF8F5">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="mb-16 reveal">
        <p class="font-sans text-xs tracking-[0.28em] uppercase mb-4" style="color:#C4956A">Ils nous font confiance</p>
        <h2 class="font-serif text-4xl md:text-5xl font-light" style="color:#1A1A1A">Avis clients</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        {[
          { text: (site as any).review1_text, name: (site as any).review1_name },
          { text: (site as any).review2_text, name: (site as any).review2_name },
          { text: (site as any).review3_text, name: (site as any).review3_name },
        ].map((r: any, i: number) => (
          <div class={`p-8 reveal reveal-d${i + 1}`} style="background:#F2EDE8;border:1px solid #E8E0D8">
            <!-- Étoiles -->
            <div class="flex gap-1 mb-6">
              {[1,2,3,4,5].map(() => (
                <span class="iconify" data-icon="lucide:star" data-width="14" style="color:#C4956A"></span>
              ))}
            </div>
            <blockquote class="font-serif text-lg font-light italic leading-relaxed mb-6" style="color:#1A1A1A">
              &ldquo;{r.text}&rdquo;
            </blockquote>
            <div style="width:2rem;height:1px;background:#C4956A;margin-bottom:1rem"></div>
            <p class="font-sans text-xs tracking-[0.15em] uppercase" style="color:#8A7E75">{r.name}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── 6. CTA FINAL — fond accent ───────────────────────────────────── -->
  <section class="py-24 md:py-32" style="background:#C4956A">
    <div class="max-w-3xl mx-auto px-6 md:px-8 text-center reveal">
      <p class="font-sans text-xs tracking-[0.28em] uppercase mb-6" style="color:rgba(255,255,255,0.7)">Prendre soin de soi</p>
      <h2 class="font-serif text-4xl md:text-6xl font-light leading-tight mb-8" style="color:#fff">
        Prendre Rendez-vous
      </h2>
      <p class="font-sans text-sm font-light leading-relaxed mb-10 max-w-md mx-auto" style="color:rgba(255,255,255,0.8)">
        {site.hero_subtitle}
      </p>
      <a href="/contact/"
        class="inline-flex items-center gap-3 font-sans text-xs tracking-[0.2em] uppercase px-10 py-4 transition-all duration-300"
        style="background:#fff;color:#C4956A">
        {site.hero_cta}
        <span class="iconify" data-icon="lucide:arrow-right" data-width="13"></span>
      </a>
    </div>
  </section>

  <Footer />

  <style>
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }
  </style>

</Base>
