---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
const submitUrl = `https://contact.cmspace.app/submit?to=${site.email}`;
---
<Base title={`Contact — ${site.company_name}`} description={site.seo_description}>
  <Header />

  <section class="bg-[#2D4A2D] py-20">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <p class="text-[#E8D5A3]/70 text-sm font-semibold tracking-widest uppercase mb-4">Nous écrire</p>
      <h1 class="font-display text-5xl font-bold text-white mb-4">Contact</h1>
      <p class="text-white/70 max-w-xl mx-auto">{site.contact_subtitle}</p>
    </div>
  </section>

  <section class="py-24 bg-[#F9F7F2]">
    <div class="max-w-5xl mx-auto px-6 grid lg:grid-cols-2 gap-16">
      <!-- Infos -->
      <div>
        <h2 class="font-display text-2xl font-bold text-[#1C2B1C] mb-8">{site.contact_title}</h2>
        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-[#EDE8DE] rounded-full flex items-center justify-center shrink-0">
              <svg class="w-4 h-4 text-[#2D4A2D]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <div>
              <p class="font-semibold text-[#1C2B1C] text-sm mb-1">Adresse</p>
              <p class="text-[#6B7C6B] text-sm">{site.address}</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-[#EDE8DE] rounded-full flex items-center justify-center shrink-0">
              <svg class="w-4 h-4 text-[#2D4A2D]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </div>
            <div>
              <p class="font-semibold text-[#1C2B1C] text-sm mb-1">Email</p>
              <a href={`mailto:${site.email}`} class="text-[#2D4A2D] text-sm hover:underline">{site.email}</a>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-[#EDE8DE] rounded-full flex items-center justify-center shrink-0">
              <svg class="w-4 h-4 text-[#2D4A2D]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            </div>
            <div>
              <p class="font-semibold text-[#1C2B1C] text-sm mb-1">Téléphone</p>
              <a href={`tel:${site.phone}`} class="text-[#2D4A2D] text-sm hover:underline">{site.phone}</a>
            </div>
          </div>
        </div>
      </div>

      <!-- Formulaire -->
      <form action={submitUrl} method="POST" class="bg-white rounded-2xl p-8 shadow-sm space-y-5">
        <div>
          <label class="block text-[#1C2B1C] text-sm font-semibold mb-2">Nom complet</label>
          <input type="text" name="name" required class="w-full border border-[#EDE8DE] rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-[#2D4A2D] transition-colors" placeholder="Marie Dupont" />
        </div>
        <div>
          <label class="block text-[#1C2B1C] text-sm font-semibold mb-2">Email</label>
          <input type="email" name="email" required class="w-full border border-[#EDE8DE] rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-[#2D4A2D] transition-colors" placeholder="marie@restaurant.fr" />
        </div>
        <div>
          <label class="block text-[#1C2B1C] text-sm font-semibold mb-2">Objet</label>
          <select name="subject" class="w-full border border-[#EDE8DE] rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-[#2D4A2D] transition-colors bg-white">
            <option>Commande professionnelle</option>
            <option>Vente directe / visite</option>
            <option>Partenariat</option>
            <option>Autre</option>
          </select>
        </div>
        <div>
          <label class="block text-[#1C2B1C] text-sm font-semibold mb-2">Message</label>
          <textarea name="message" rows="4" required class="w-full border border-[#EDE8DE] rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-[#2D4A2D] transition-colors resize-none" placeholder="Décrivez votre besoin..."></textarea>
        </div>
        <button type="submit" class="w-full bg-[#2D4A2D] text-[#E8D5A3] font-semibold py-3.5 rounded-full hover:bg-[#1C2B1C] transition-colors text-sm">
          Envoyer le message
        </button>
      </form>
    </div>
  </section>

  <Footer />
</Base>
