---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
---
<Base title={`Contact — ${site.company_name}`} description={site.contact_subtitle}>

<Header />

  <!-- Prise de RDV -->
  {site.booking_enabled && site.booking_url && (
    <section style="padding: 2.5rem 0; background: rgba(var(--color-accent-rgb, 200,169,110), 0.08); border-top: 1px solid rgba(var(--color-accent-rgb, 200,169,110), 0.2); border-bottom: 1px solid rgba(var(--color-accent-rgb, 200,169,110), 0.2);">
      <div style="max-width: 72rem; margin: 0 auto; padding: 0 2rem; display: flex; align-items: center; justify-content: space-between; gap: 2rem; flex-wrap: wrap;">
        <div>
          <p style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.18em; opacity: 0.6; margin-bottom: 0.25rem;">Réservation en ligne</p>
          <h2 style="font-size: 1.75rem; font-weight: 300; margin: 0;">{site.booking_cta || 'Prendre rendez-vous'}</h2>
          <p style="font-size: 0.875rem; opacity: 0.7; margin-top: 0.25rem;">{site.booking_subtitle || 'Choisissez votre créneau directement en ligne'}</p>
        </div>
        <a href={site.booking_url} target="_blank" rel="noopener"
          style="display: inline-flex; align-items: center; gap: 0.75rem; padding: 1rem 2rem; background: var(--color-primary, #1B2A4A); color: #fff; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.15em; text-decoration: none; transition: opacity 0.2s;"
          onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
          Réserver un créneau →
        </a>
      </div>
    </section>
  )}



<!-- Page Hero -->
<section class="py-24 relative overflow-hidden" style={`background-color: ${site.color_dark}; background-image: radial-gradient(900px 420px at 20% 10%, ${site.color_primary}40, transparent 60%), radial-gradient(800px 380px at 85% 35%, ${site.color_accent}2e, transparent 55%);`}>
  <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12 text-center">
    <div class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-white/10 backdrop-blur-md border border-white/20 mb-8">
      <iconify-icon icon="solar:chat-round-dots-bold-duotone" width="18" style={`color: ${site.color_accent};`}></iconify-icon>
      <span class="text-xs font-bold tracking-widest uppercase" style={`color: ${site.color_accent};`}>Contact</span>
    </div>
    <h1 class="font-heading text-5xl sm:text-6xl font-bold tracking-tight text-white mb-6">{site.contact_title}</h1>
    <p class="text-white/70 text-xl font-light max-w-2xl mx-auto leading-relaxed">{site.contact_subtitle}</p>
  </div>
</section>

<!-- Contact Form Section -->
<section class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
    <div class="grid lg:grid-cols-12 gap-10 items-start">
      <div class="lg:col-span-5">
        <div class="sticky top-28">
          <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full mb-6" style={`background-color: ${site.color_primary}1a;`}>
            <iconify-icon icon="solar:chat-round-dots-bold-duotone" width="18" style={`color: ${site.color_primary};`}></iconify-icon>
            <span class="text-xs font-semibold tracking-widest uppercase" style={`color: ${site.color_primary};`}>Contact</span>
          </div>
          <h2 class="font-heading text-4xl sm:text-5xl font-semibold tracking-tight" style={`color: ${site.color_dark};`}>{site.contact_title}</h2>
          <p class="text-gray-600 text-lg font-light leading-relaxed mt-5">{site.contact_subtitle}</p>
          <div class="mt-10 space-y-4">
            {site.email && (
              <div class="flex items-start gap-3">
                <iconify-icon icon="solar:letter-bold-duotone" width="18" class="mt-0.5" style={`color: ${site.color_primary};`}></iconify-icon>
                <div>
                  <p class="text-sm font-semibold" style={`color: ${site.color_dark};`}>Email</p>
                  <a href={`mailto:${site.email}`} class="text-sm text-gray-600 font-light hover:underline">{site.email}</a>
                </div>
              </div>
            )}
            {site.phone && (
              <div class="flex items-start gap-3">
                <iconify-icon icon="solar:phone-bold-duotone" width="18" class="mt-0.5" style={`color: ${site.color_primary};`}></iconify-icon>
                <div>
                  <p class="text-sm font-semibold" style={`color: ${site.color_dark};`}>Téléphone</p>
                  <a href={`tel:${site.phone}`} class="text-sm text-gray-600 font-light hover:underline">{site.phone}</a>
                </div>
              </div>
            )}
            {site.address && (
              <div class="flex items-start gap-3">
                <iconify-icon icon="solar:map-point-bold-duotone" width="18" class="mt-0.5" style={`color: ${site.color_primary};`}></iconify-icon>
                <div>
                  <p class="text-sm font-semibold" style={`color: ${site.color_dark};`}>Adresse</p>
                  <p class="text-sm text-gray-600 font-light">{site.address}</p>
                </div>
              </div>
            )}
          </div>
        </div>
      </div>
      <div class="lg:col-span-7">
        <form
          method="POST"
          action={`https://contact.cmspace.app/submit?to=${site.email}`}
          class="border border-gray-100 rounded-[2.5rem] p-8 sm:p-10 shadow-sm"
          style={`background-color: ${site.color_bg};`}
        >
          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label class="text-xs font-semibold tracking-tight" style={`color: ${site.color_dark};`} for="cfName">Nom complet</label>
              <input id="cfName" name="name" type="text" required class="mt-2 w-full bg-white border border-gray-200 rounded-2xl px-5 py-3.5 text-sm focus:outline-none focus:ring-2" placeholder="Votre nom" />
            </div>
            <div>
              <label class="text-xs font-semibold tracking-tight" style={`color: ${site.color_dark};`} for="cfEmail">Email</label>
              <input id="cfEmail" name="email" type="email" required class="mt-2 w-full bg-white border border-gray-200 rounded-2xl px-5 py-3.5 text-sm focus:outline-none focus:ring-2" placeholder="nom@entreprise.com" />
            </div>
            <div>
              <label class="text-xs font-semibold tracking-tight" style={`color: ${site.color_dark};`} for="cfCompany">Entreprise</label>
              <input id="cfCompany" name="company" type="text" class="mt-2 w-full bg-white border border-gray-200 rounded-2xl px-5 py-3.5 text-sm focus:outline-none focus:ring-2" placeholder="Nom de l'entreprise" />
            </div>
            <div>
              <label class="text-xs font-semibold tracking-tight" style={`color: ${site.color_dark};`} for="cfPhone">Téléphone</label>
              <input id="cfPhone" name="phone" type="tel" class="mt-2 w-full bg-white border border-gray-200 rounded-2xl px-5 py-3.5 text-sm focus:outline-none focus:ring-2" placeholder="+33 6 00 00 00 00" />
            </div>
            <div class="sm:col-span-2">
              <label class="text-xs font-semibold tracking-tight" style={`color: ${site.color_dark};`} for="cfMessage">Message</label>
              <textarea id="cfMessage" name="message" rows={5} required class="mt-2 w-full bg-white border border-gray-200 rounded-2xl px-5 py-3.5 text-sm focus:outline-none focus:ring-2" placeholder="Décrivez votre besoin..."></textarea>
            </div>
          </div>
          <div class="mt-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
            <p class="text-xs text-gray-500 font-light">En soumettant ce formulaire, vous acceptez d'être contacté.</p>
            <button type="submit" class="text-white text-sm font-semibold px-8 py-4 rounded-full transition-colors shadow-sm inline-flex items-center gap-2 hover:opacity-90" style={`background-color: ${site.color_primary};`}>
              Envoyer
              <iconify-icon icon="solar:arrow-right-linear" width="18"></iconify-icon>
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<!-- Final CTA Section -->
<section class="py-32 relative overflow-hidden" style={`background-color: ${site.color_primary};`}>
  <div class="absolute inset-0 bg-black/50 mix-blend-overlay z-0" style={`background-image: url('${site.contact_bg_image}'); background-attachment: fixed; background-size: cover; background-position: center;`}></div>
  <div class="absolute inset-0 z-0" style={`background: linear-gradient(to top, ${site.color_primary}, ${site.color_primary}cc, transparent);`}></div>
  <div class="max-w-4xl mx-auto px-6 sm:px-8 text-center relative z-10" data-aos="zoom-in">
    <div class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-white/10 backdrop-blur-md border border-white/20 mb-8 animate-bounce">
      <iconify-icon icon="solar:rocket-bold-duotone" width="20" style={`color: ${site.color_accent};`}></iconify-icon>
      <span class="text-xs font-bold tracking-widest uppercase" style={`color: ${site.color_accent};`}>Travaillons ensemble</span>
    </div>
    <h2 class="font-heading text-5xl sm:text-7xl font-bold tracking-tight text-white mb-8 drop-shadow-lg leading-[1.1]">
      {site.contact_cta_title}
      <span class="italic font-light" style={`color: ${site.color_accent};`}>{site.contact_cta_italic}</span>
    </h2>
    <p class="text-gray-200 text-xl font-light mb-12 max-w-2xl mx-auto drop-shadow-md leading-relaxed">{site.contact_cta_sub}</p>
    <div class="flex flex-col sm:flex-row justify-center items-center gap-6">
      <a href="/services" class="w-full sm:w-auto glass-card text-white border border-white/30 text-lg font-semibold px-10 py-5 rounded-full hover:bg-white/20 transition-all flex items-center justify-center gap-3">
        {site.contact_cta_secondary}
        <iconify-icon icon="solar:box-bold-duotone" width="24"></iconify-icon>
      </a>
    </div>
  </div>
</section>

<Footer />

</Base>
