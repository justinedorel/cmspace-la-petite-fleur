---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
---
<Base title={`Contact — ${site.company_name}`} description={`Contactez ${site.company_name} — ${site.tagline}`}>

  <Header />

  <!-- Prise de RDV -->
  {site.booking_enabled && site.booking_url && (
    <section style="padding: 2.5rem 0; background: rgba(var(--color-accent-rgb, 200,169,110), 0.08); border-top: 1px solid rgba(var(--color-accent-rgb, 200,169,110), 0.2); border-bottom: 1px solid rgba(var(--color-accent-rgb, 200,169,110), 0.2);">
      <div style="max-width: 72rem; margin: 0 auto; padding: 0 2rem; display: flex; align-items: center; justify-content: space-between; gap: 2rem; flex-wrap: wrap;">
        <div>
          <p style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.18em; opacity: 0.6; margin-bottom: 0.25rem;">Réservation en ligne</p>
          <h2 style="font-size: 1.75rem; font-weight: 300; margin: 0;">{site.booking_cta || 'Prendre rendez-vous'}</h2>
          <p style="font-size: 0.875rem; opacity: 0.7; margin-top: 0.25rem;">{site.booking_subtitle || 'Choisissez votre créneau directement en ligne'}</p>
        </div>
        <a href={site.booking_url} target="_blank" rel="noopener"
          style="display: inline-flex; align-items: center; gap: 0.75rem; padding: 1rem 2rem; background: var(--color-primary, #1B2A4A); color: #fff; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.15em; text-decoration: none; transition: opacity 0.2s;"
          onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
          Réserver un créneau →
        </a>
      </div>
    </section>
  )}



  <!-- PAGE HERO -->
  <section class="py-20 px-6 text-center bg-zinc-50">
    <div class="max-w-3xl mx-auto">
      <div class="inline-flex items-center gap-2 bg-indigo-50 text-accent rounded-full text-sm font-medium px-3 py-1 mb-6">
        <i data-lucide="message-circle" class="w-3.5 h-3.5"></i>
        Parlons-nous
      </div>
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight leading-tight mb-4">
        Contactez-nous
      </h1>
      <p class="text-zinc-500 text-lg max-w-2xl mx-auto leading-relaxed">
        Une question, un projet, une idée ? Notre équipe vous répond sous 24h.
      </p>
    </div>
  </section>

  <!-- CONTACT FORM + INFOS -->
  <section class="py-24 px-6">
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16">

      <!-- Infos de contact -->
      <div>
        <h2 class="text-2xl font-extrabold text-zinc-900 mb-8">Nos coordonnées</h2>
        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="bg-indigo-50 rounded-xl p-3 flex-shrink-0">
              <i data-lucide="mail" class="w-5 h-5 text-accent"></i>
            </div>
            <div>
              <div class="font-semibold text-zinc-900 mb-1">Email</div>
              <a href={`mailto:${site.email}`} class="text-zinc-500 hover:text-accent transition-colors text-sm">{site.email}</a>
            </div>
          </div>
          {site.phone && (
            <div class="flex items-start gap-4">
              <div class="bg-indigo-50 rounded-xl p-3 flex-shrink-0">
                <i data-lucide="phone" class="w-5 h-5 text-accent"></i>
              </div>
              <div>
                <div class="font-semibold text-zinc-900 mb-1">Téléphone</div>
                <a href={`tel:${site.phone}`} class="text-zinc-500 hover:text-accent transition-colors text-sm">{site.phone}</a>
              </div>
            </div>
          )}
          {site.address && (
            <div class="flex items-start gap-4">
              <div class="bg-indigo-50 rounded-xl p-3 flex-shrink-0">
                <i data-lucide="map-pin" class="w-5 h-5 text-accent"></i>
              </div>
              <div>
                <div class="font-semibold text-zinc-900 mb-1">Adresse</div>
                <div class="text-zinc-500 text-sm">{site.address}</div>
              </div>
            </div>
          )}
        </div>

        <div class="mt-12 flex items-center gap-4">
          <a href={site.social_twitter} class="text-zinc-500 hover:text-zinc-900 transition-colors p-2 rounded-lg hover:bg-zinc-100">
            <i data-lucide="twitter" class="w-4 h-4"></i>
          </a>
          <a href={site.social_linkedin} class="text-zinc-500 hover:text-zinc-900 transition-colors p-2 rounded-lg hover:bg-zinc-100">
            <i data-lucide="linkedin" class="w-4 h-4"></i>
          </a>
          <a href={site.social_instagram} class="text-zinc-500 hover:text-zinc-900 transition-colors p-2 rounded-lg hover:bg-zinc-100">
            <i data-lucide="instagram" class="w-4 h-4"></i>
          </a>
        </div>
      </div>

      <!-- Formulaire -->
      <div>
        <form
          method="POST"
          action={`https://contact.cmspace.app/submit?to=${site.email}`}
          class="space-y-5"
        >
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="firstname" class="block text-sm font-medium text-zinc-700 mb-1.5">Prénom</label>
              <input
                type="text"
                id="firstname"
                name="firstname"
                required
                placeholder="Marie"
                class="w-full border border-zinc-200 rounded-xl px-4 py-3 text-sm text-zinc-900 placeholder-zinc-400 focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-colors"
              />
            </div>
            <div>
              <label for="lastname" class="block text-sm font-medium text-zinc-700 mb-1.5">Nom</label>
              <input
                type="text"
                id="lastname"
                name="lastname"
                required
                placeholder="Dupont"
                class="w-full border border-zinc-200 rounded-xl px-4 py-3 text-sm text-zinc-900 placeholder-zinc-400 focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-colors"
              />
            </div>
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-zinc-700 mb-1.5">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="marie@entreprise.com"
              class="w-full border border-zinc-200 rounded-xl px-4 py-3 text-sm text-zinc-900 placeholder-zinc-400 focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-colors"
            />
          </div>
          <div>
            <label for="subject" class="block text-sm font-medium text-zinc-700 mb-1.5">Sujet</label>
            <input
              type="text"
              id="subject"
              name="subject"
              placeholder="Demande de démo, question produit..."
              class="w-full border border-zinc-200 rounded-xl px-4 py-3 text-sm text-zinc-900 placeholder-zinc-400 focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-colors"
            />
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-zinc-700 mb-1.5">Message</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              placeholder="Décrivez votre projet ou votre question..."
              class="w-full border border-zinc-200 rounded-xl px-4 py-3 text-sm text-zinc-900 placeholder-zinc-400 focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-colors resize-none"
            ></textarea>
          </div>
          <input type="hidden" name="_redirect" value="/merci" />
          <button
            type="submit"
            class="w-full bg-accent text-white font-semibold rounded-xl px-6 py-3 hover:opacity-90 transition-opacity shadow-lg shadow-indigo-200 flex items-center justify-center gap-2"
          >
            Envoyer le message
            <i data-lucide="send" class="w-4 h-4"></i>
          </button>
        </form>
      </div>

    </div>
  </section>

  <Footer />

  <style is:global>
    html { scroll-behavior: smooth; }
  </style>

</Base>
