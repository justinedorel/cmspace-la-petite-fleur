---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
const formAction = `https://contact.cmspace.app/submit?to=${encodeURIComponent(site.email)}`;
---
<Base title={`Contact — ${site.company_name}`} description={site.contact_subtitle}>
  <Header />

  <section style="background:var(--colorSurface);padding:4rem 0 3rem;">
    <div class="container">
      <span class="section-label">Parlons-en</span>
      <h1 class="section-title">{site.contact_title}</h1>
      <p class="section-subtitle">{site.contact_subtitle}</p>
    </div>
  </section>

  <section>
    <div class="container" style="display:grid;grid-template-columns:1fr 1.5fr;gap:4rem;">
      <div style="display:flex;flex-direction:column;gap:2rem;">
        {site.email && (
          <div>
            <div style="font-weight:700;color:var(--colorPrimary);margin-bottom:0.25rem;">Email</div>
            <a href={`mailto:${site.email}`} style="color:var(--colorTextMuted);">{site.email}</a>
          </div>
        )}
        {site.phone && (
          <div>
            <div style="font-weight:700;color:var(--colorPrimary);margin-bottom:0.25rem;">Téléphone</div>
            <a href={`tel:${site.phone}`} style="color:var(--colorTextMuted);">{site.phone}</a>
          </div>
        )}
        {site.address && (
          <div>
            <div style="font-weight:700;color:var(--colorPrimary);margin-bottom:0.25rem;">Adresse</div>
            <span style="color:var(--colorTextMuted);">{site.address}</span>
          </div>
        )}
        {site.booking_url && (
          <div style="margin-top:1rem;">
            <a href={site.booking_url} target="_blank" class="btn-primary">Prendre rendez-vous</a>
          </div>
        )}
      </div>

      <form method="POST" action={formAction} style="display:flex;flex-direction:column;gap:1.25rem;">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
          <div>
            <label style="font-size:0.85rem;font-weight:600;color:var(--colorText);display:block;margin-bottom:0.4rem;">Nom *</label>
            <input type="text" name="name" required placeholder="Votre nom"
              style="width:100%;padding:0.75rem;border:1px solid #e5e7eb;border-radius:0.5rem;font-size:0.9rem;background:var(--colorBg);" />
          </div>
          <div>
            <label style="font-size:0.85rem;font-weight:600;color:var(--colorText);display:block;margin-bottom:0.4rem;">Email *</label>
            <input type="email" name="email" required placeholder="votre@email.fr"
              style="width:100%;padding:0.75rem;border:1px solid #e5e7eb;border-radius:0.5rem;font-size:0.9rem;background:var(--colorBg);" />
          </div>
        </div>
        <div>
          <label style="font-size:0.85rem;font-weight:600;color:var(--colorText);display:block;margin-bottom:0.4rem;">Téléphone</label>
          <input type="tel" name="phone" placeholder="06 00 00 00 00"
            style="width:100%;padding:0.75rem;border:1px solid #e5e7eb;border-radius:0.5rem;font-size:0.9rem;background:var(--colorBg);" />
        </div>
        <div>
          <label style="font-size:0.85rem;font-weight:600;color:var(--colorText);display:block;margin-bottom:0.4rem;">Message *</label>
          <textarea name="message" required rows="5" placeholder="Décrivez votre projet ou votre question…"
            style="width:100%;padding:0.75rem;border:1px solid #e5e7eb;border-radius:0.5rem;font-size:0.9rem;resize:vertical;background:var(--colorBg);"></textarea>
        </div>
        <button type="submit" class="btn-primary" style="align-self:flex-start;padding:0.875rem 2rem;">
          Envoyer le message
        </button>
      </form>
    </div>
  </section>

  <Footer />
</Base>
