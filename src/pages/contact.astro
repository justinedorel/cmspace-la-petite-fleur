---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
---
<Base title={`Contact — ${site.company_name}`} description={site.cta_subtitle}>
  <Header />

  <main class="flex-grow">

    <!-- Hero contact -->
    <section class="relative pt-32 pb-20 md:pt-40 md:pb-28 overflow-hidden">
      <div class="absolute top-0 inset-x-0 h-screen overflow-hidden -z-10 pointer-events-none flex justify-center">
        <div class="w-full max-w-lg aspect-square bg-zinc-800/20 rounded-full blur-3xl opacity-50 translate-y-[-50%]"></div>
      </div>
      <div class="container mx-auto px-6">
        <div class="max-w-3xl">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-zinc-800 bg-zinc-900/50 text-xs text-zinc-400 mb-8 backdrop-blur-sm">
            <span class="flex h-2 w-2 rounded-full bg-emerald-500"></span>
            Démarrons ensemble
          </div>
          <h1 class="text-4xl md:text-6xl font-medium tracking-tight text-zinc-100 leading-tight mb-6">
            {site.cta_title}
          </h1>
          <p class="text-lg text-zinc-400 max-w-2xl font-light">{site.cta_subtitle}</p>
        </div>
      </div>
    </section>

    <!-- Formulaire + infos -->
    <section class="pb-24 md:pb-32 relative overflow-hidden">
      <div class="container mx-auto px-6">
        <div class="max-w-4xl mx-auto rounded-3xl border border-zinc-800 bg-zinc-950/80 backdrop-blur-xl p-8 md:p-12 shadow-2xl flex flex-col md:flex-row gap-12">
          <div class="flex-1">
            <h2 class="text-2xl font-medium tracking-tight text-zinc-100 mb-4">{site.cta_title}</h2>
            <p class="text-sm text-zinc-400 mb-8">{site.cta_subtitle}</p>
            <div class="space-y-4 text-sm text-zinc-300">
              <div class="flex items-start gap-3">
                <iconify-icon icon="solar:check-circle-linear" class="text-zinc-500 mt-0.5"></iconify-icon>
                <span>{site.cta_li1}</span>
              </div>
              <div class="flex items-start gap-3">
                <iconify-icon icon="solar:check-circle-linear" class="text-zinc-500 mt-0.5"></iconify-icon>
                <span>{site.cta_li2}</span>
              </div>
              <div class="flex items-start gap-3">
                <iconify-icon icon="solar:check-circle-linear" class="text-zinc-500 mt-0.5"></iconify-icon>
                <span>{site.cta_li3}</span>
              </div>
            </div>
            {site.email && (
              <div class="mt-10 pt-8 border-t border-zinc-900">
                <p class="text-xs text-zinc-500 mb-3 uppercase tracking-widest">Ou directement par email</p>
                <a href={`mailto:${site.email}`} class="text-sm text-zinc-300 hover:text-zinc-100 transition-colors flex items-center gap-2">
                  <iconify-icon icon="solar:letter-linear" class="text-zinc-500"></iconify-icon>
                  {site.email}
                </a>
              </div>
            )}
          </div>
          <div class="flex-1 w-full">
            <form
              method="POST"
              action={`https://contact.cmspace.app/submit?to=${site.email}`}
              class="space-y-4"
            >
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="space-y-1.5">
                  <label class="text-xs font-medium text-zinc-400 px-1">Nom</label>
                  <input type="text" name="name" required placeholder="Jean Dupont" class="w-full bg-zinc-900/50 border border-zinc-800 rounded-lg px-4 py-2.5 text-sm text-zinc-100 placeholder:text-zinc-600 focus:outline-none focus:border-zinc-600 transition-colors" />
                </div>
                <div class="space-y-1.5">
                  <label class="text-xs font-medium text-zinc-400 px-1">Email</label>
                  <input type="email" name="email" required placeholder="jean@entreprise.fr" class="w-full bg-zinc-900/50 border border-zinc-800 rounded-lg px-4 py-2.5 text-sm text-zinc-100 placeholder:text-zinc-600 focus:outline-none focus:border-zinc-600 transition-colors" />
                </div>
              </div>
              <div class="space-y-1.5">
                <label class="text-xs font-medium text-zinc-400 px-1">Votre besoin</label>
                <textarea rows="4" name="message" required placeholder="Décrivez votre projet..." class="w-full bg-zinc-900/50 border border-zinc-800 rounded-lg px-4 py-3 text-sm text-zinc-100 placeholder:text-zinc-600 focus:outline-none focus:border-zinc-600 transition-colors resize-none"></textarea>
              </div>
              <input type="hidden" name="_redirect" value="/merci" />
              <button type="submit" class="w-full py-3 mt-2 text-sm font-medium bg-zinc-100 text-zinc-950 rounded-lg hover:bg-zinc-200 transition-colors flex items-center justify-center gap-2">
                {site.cta_primary}
                <iconify-icon icon="solar:plain-2-linear"></iconify-icon>
              </button>
            </form>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Base>
