---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';

const submitUrl = `https://contact.cmspace.app/submit?to=${site.email}`;
---
<Base title={`Contact — ${site.company_name}`} description={`Réservez votre soin chez ${site.company_name}. ${site.tagline}`}>

  <Header />

  <section class="pt-36 pb-16" style="background:#FAFAF7;">
    <div class="max-w-6xl mx-auto px-6">
      <p class="font-sans text-xs text-muted uppercase tracking-widest mb-4">Contact</p>
      <h1 class="font-serif text-4xl md:text-6xl font-light text-dark mb-4">{site.hero_cta}</h1>
      <p class="font-sans text-base text-muted max-w-xl leading-relaxed">{site.tagline}</p>
    </div>
  </section>

  <section class="py-16 pb-28" style="background:#F2F2ED;border-top:1px solid rgba(92,122,92,0.15);">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-16">

        <div>
          <form method="POST" action={submitUrl} class="flex flex-col gap-5">
            <div>
              <label for="name" class="font-sans text-xs text-muted uppercase tracking-widest block mb-2">Nom complet</label>
              <input type="text" id="name" name="name" required placeholder="Votre nom" class="w-full font-sans text-sm text-dark py-3 px-4 outline-none transition-colors bg-transparent" style="border:1px solid rgba(92,122,92,0.3);" />
            </div>
            <div>
              <label for="email" class="font-sans text-xs text-muted uppercase tracking-widest block mb-2">Email</label>
              <input type="email" id="email" name="email" required placeholder="votre@email.com" class="w-full font-sans text-sm text-dark py-3 px-4 outline-none transition-colors bg-transparent" style="border:1px solid rgba(92,122,92,0.3);" />
            </div>
            <div>
              <label for="phone" class="font-sans text-xs text-muted uppercase tracking-widest block mb-2">Téléphone</label>
              <input type="tel" id="phone" name="phone" placeholder="+33 6 xx xx xx xx" class="w-full font-sans text-sm text-dark py-3 px-4 outline-none transition-colors bg-transparent" style="border:1px solid rgba(92,122,92,0.3);" />
            </div>
            <div>
              <label for="message" class="font-sans text-xs text-muted uppercase tracking-widest block mb-2">Soin souhaité & disponibilités</label>
              <textarea id="message" name="message" rows="4" required placeholder="Quel soin vous intéresse ? Quelles sont vos disponibilités ?" class="w-full font-sans text-sm text-dark py-3 px-4 outline-none transition-colors bg-transparent resize-none" style="border:1px solid rgba(92,122,92,0.3);"></textarea>
            </div>
            <input type="hidden" name="_redirect" value="/merci/" />
            <button type="submit" class="btn-accent inline-flex items-center justify-center gap-3 px-8 py-4 text-sm font-sans">
              Envoyer ma demande
              <span class="iconify" data-icon="lucide:arrow-right" data-width="14"></span>
            </button>
          </form>
        </div>

        <div class="flex flex-col gap-8">
          <div>
            <p class="font-sans text-xs text-muted uppercase tracking-widest mb-3">Adresse</p>
            <p class="font-serif text-xl font-light text-dark">{(site as any).address}</p>
          </div>
          <div>
            <p class="font-sans text-xs text-muted uppercase tracking-widest mb-3">Email</p>
            <a href={`mailto:${site.email}`} class="font-serif text-xl font-light text-dark hover:text-accent transition-colors">{site.email}</a>
          </div>
          <div>
            <p class="font-sans text-xs text-muted uppercase tracking-widest mb-3">Téléphone</p>
            <a href={`tel:${(site as any).phone}`} class="font-serif text-xl font-light text-dark hover:text-accent transition-colors">{(site as any).phone}</a>
          </div>
          <div>
            <p class="font-sans text-xs text-muted uppercase tracking-widest mb-3">Horaires</p>
            <p class="font-sans text-sm text-dark">{(site as any).hours_week}</p>
            <p class="font-sans text-sm text-dark">{(site as any).hours_sunday}</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <Footer />

</Base>
