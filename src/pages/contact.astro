---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';

const submitUrl = `https://contact.cmspace.app/submit?to=${site.email}`;
---
<Base title={`Réserver — ${site.company_name}`} description={`Réservez votre rendez-vous chez ${site.company_name}. ${site.tagline}`}>

  <Header />

  <!-- Hero page -->
  <section class="pt-32 pb-16" style="background-color:#FDFAF8;">
    <div class="max-w-6xl mx-auto px-6 md:px-8">
      <div class="max-w-2xl">
        <span class="font-body text-xs tracking-[0.22em] uppercase mb-4 block" style="color:#9E6B6B;">Prendre rendez-vous</span>
        <h1 class="font-display text-5xl md:text-6xl font-medium leading-tight mb-6" style="color:#1C1C1C;">
          Réservez votre<br />
          <em class="italic font-normal" style="color:#9E6B6B;">moment de beauté.</em>
        </h1>
        <p class="font-body text-base leading-relaxed" style="color:#9B8B8B;">
          Remplissez le formulaire ou contactez-nous directement. Nous vous confirmons votre créneau sous 24h.
        </p>
      </div>
    </div>
  </section>

  <!-- Formulaire + Infos -->
  <section class="py-16 md:py-24" style="background-color:#F9F0EE;">
    <div class="max-w-6xl mx-auto px-6 md:px-8">
      <div class="grid md:grid-cols-2 gap-16">

        <!-- Formulaire -->
        <div class="bg-bg rounded-2xl p-8 md:p-10 border" style="border-color:#EDE0DE;">
          <h2 class="font-display text-2xl font-medium mb-8" style="color:#1C1C1C;">Votre demande</h2>
          <form method="POST" action={submitUrl} class="space-y-6">
            <div>
              <label for="name" class="block font-body text-sm font-medium mb-2" style="color:#1C1C1C;">Votre nom</label>
              <input type="text" id="name" name="name" required placeholder="Marie Dupont"
                class="w-full font-body text-sm px-4 py-3 rounded-xl border bg-bg outline-none transition-colors"
                style="border-color:#EDE0DE;color:#1C1C1C;"
                onfocus="this.style.borderColor='#D4A5A5'"
                onblur="this.style.borderColor='#EDE0DE'" />
            </div>
            <div>
              <label for="email" class="block font-body text-sm font-medium mb-2" style="color:#1C1C1C;">Email</label>
              <input type="email" id="email" name="email" required placeholder="marie@email.fr"
                class="w-full font-body text-sm px-4 py-3 rounded-xl border bg-bg outline-none transition-colors"
                style="border-color:#EDE0DE;color:#1C1C1C;"
                onfocus="this.style.borderColor='#D4A5A5'"
                onblur="this.style.borderColor='#EDE0DE'" />
            </div>
            <div>
              <label for="phone" class="block font-body text-sm font-medium mb-2" style="color:#1C1C1C;">Téléphone</label>
              <input type="tel" id="phone" name="phone" placeholder="06 XX XX XX XX"
                class="w-full font-body text-sm px-4 py-3 rounded-xl border bg-bg outline-none transition-colors"
                style="border-color:#EDE0DE;color:#1C1C1C;"
                onfocus="this.style.borderColor='#D4A5A5'"
                onblur="this.style.borderColor='#EDE0DE'" />
            </div>
            <div>
              <label for="service" class="block font-body text-sm font-medium mb-2" style="color:#1C1C1C;">Service souhaité</label>
              <select id="service" name="service"
                class="w-full font-body text-sm px-4 py-3 rounded-xl border bg-bg outline-none transition-colors"
                style="border-color:#EDE0DE;color:#1C1C1C;"
                onfocus="this.style.borderColor='#D4A5A5'"
                onblur="this.style.borderColor='#EDE0DE'">
                <option value="">Choisir un service…</option>
                <option>{site.service1_name} — {site.service1_price}</option>
                <option>{site.service2_name} — {site.service2_price}</option>
                <option>{site.service3_name} — {site.service3_price}</option>
                <option>{site.service4_name} — {site.service4_price}</option>
              </select>
            </div>
            <div>
              <label for="date" class="block font-body text-sm font-medium mb-2" style="color:#1C1C1C;">Date souhaitée</label>
              <input type="date" id="date" name="date"
                class="w-full font-body text-sm px-4 py-3 rounded-xl border bg-bg outline-none transition-colors"
                style="border-color:#EDE0DE;color:#1C1C1C;"
                onfocus="this.style.borderColor='#D4A5A5'"
                onblur="this.style.borderColor='#EDE0DE'" />
            </div>
            <div>
              <label for="message" class="block font-body text-sm font-medium mb-2" style="color:#1C1C1C;">Message (optionnel)</label>
              <textarea id="message" name="message" rows="4"
                placeholder="Précisez vos envies, couleurs ou inspirations…"
                class="w-full font-body text-sm px-4 py-3 rounded-xl border bg-bg outline-none transition-colors resize-none"
                style="border-color:#EDE0DE;color:#1C1C1C;"
                onfocus="this.style.borderColor='#D4A5A5'"
                onblur="this.style.borderColor='#EDE0DE'"></textarea>
            </div>
            <input type="hidden" name="_redirect" value="/merci/" />
            <button type="submit"
              class="w-full font-body text-sm font-medium text-white py-4 rounded-xl transition-colors flex items-center justify-center gap-2"
              style="background-color:#D4A5A5;"
              onmouseover="this.style.backgroundColor='#9E6B6B'"
              onmouseout="this.style.backgroundColor='#D4A5A5'">
              Envoyer ma demande
              <span class="iconify" data-icon="lucide:send" data-width="16"></span>
            </button>
          </form>
        </div>

        <!-- Informations contact -->
        <div class="flex flex-col gap-10">
          <div>
            <h2 class="font-display text-2xl font-medium mb-6" style="color:#1C1C1C;">Informations pratiques</h2>
            <div class="space-y-5">
              <div class="flex gap-4">
                <div class="w-10 h-10 rounded-full flex items-center justify-center shrink-0" style="background-color:#F9F0EE;">
                  <span class="iconify" data-icon="lucide:map-pin" data-width="18" style="color:#D4A5A5;"></span>
                </div>
                <div>
                  <p class="font-body text-sm font-medium mb-0.5" style="color:#1C1C1C;">Adresse</p>
                  <p class="font-body text-sm" style="color:#9B8B8B;">{site.address}</p>
                </div>
              </div>
              <div class="flex gap-4">
                <div class="w-10 h-10 rounded-full flex items-center justify-center shrink-0" style="background-color:#F9F0EE;">
                  <span class="iconify" data-icon="lucide:phone" data-width="18" style="color:#D4A5A5;"></span>
                </div>
                <div>
                  <p class="font-body text-sm font-medium mb-0.5" style="color:#1C1C1C;">Téléphone</p>
                  <a href={`tel:${site.phone}`} class="font-body text-sm transition-colors" style="color:#9B8B8B;"
                    onmouseover="this.style.color='#1C1C1C'"
                    onmouseout="this.style.color='#9B8B8B'">{site.phone}</a>
                </div>
              </div>
              <div class="flex gap-4">
                <div class="w-10 h-10 rounded-full flex items-center justify-center shrink-0" style="background-color:#F9F0EE;">
                  <span class="iconify" data-icon="lucide:mail" data-width="18" style="color:#D4A5A5;"></span>
                </div>
                <div>
                  <p class="font-body text-sm font-medium mb-0.5" style="color:#1C1C1C;">Email</p>
                  <a href={`mailto:${site.email}`} class="font-body text-sm transition-colors" style="color:#9B8B8B;"
                    onmouseover="this.style.color='#1C1C1C'"
                    onmouseout="this.style.color='#9B8B8B'">{site.email}</a>
                </div>
              </div>
            </div>
          </div>

          <!-- Horaires -->
          <div class="bg-bg rounded-2xl p-8 border" style="border-color:#EDE0DE;">
            <h3 class="font-display text-xl font-medium mb-5" style="color:#1C1C1C;">Horaires</h3>
            <div class="space-y-3">
              <div class="flex justify-between items-center py-2" style="border-bottom:1px solid #EDE0DE;">
                <span class="font-body text-sm" style="color:#9B8B8B;">Lundi – Samedi</span>
                <span class="font-body text-sm font-medium" style="color:#9E6B6B;">9h30 – 19h30</span>
              </div>
              <div class="flex justify-between items-center py-2">
                <span class="font-body text-sm" style="color:#9B8B8B;">Dimanche</span>
                <span class="font-body text-sm font-medium" style="color:#9E6B6B;">10h00 – 17h00</span>
              </div>
            </div>
          </div>

          <!-- Avis rapides -->
          <div class="rounded-2xl p-6" style="background-color:#FDFAF8;border:1px solid #EDE0DE;">
            <div class="flex gap-1 mb-3">
              {[1,2,3,4,5].map(() => (
                <span class="iconify" data-icon="lucide:star" data-width="14" style="color:#D4A5A5;"></span>
              ))}
            </div>
            <p class="font-display text-lg italic mb-3" style="color:#1C1C1C;">"{site.review1_text}"</p>
            <p class="font-body text-sm font-medium" style="color:#9E6B6B;">— {site.review1_name}</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <Footer />

</Base>
