---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';

const submitUrl = `https://contact.cmspace.app/submit?to=${site.email}`;
---
<Base title={`Contact — ${site.company_name}`} description={`Contactez ${site.company_name}. ${site.tagline}`}>

  <Header />

  <!-- Hero page -->
  <section class="pt-40 pb-16">
    <div class="max-w-7xl mx-auto px-8">
      <span class="font-sans text-xs tracking-[0.22em] uppercase text-muted mb-4 block">Contact</span>
      <h1 class="font-serif text-5xl md:text-7xl font-light text-dark mb-4">
        {site.hero_cta}
      </h1>
      <p class="font-sans text-sm font-light leading-relaxed text-muted max-w-lg tracking-wide">{site.step1_desc}</p>
    </div>
  </section>

  <!-- Formulaire + infos -->
  <section class="py-16 pb-28">
    <div class="max-w-7xl mx-auto px-8">
      <div class="grid md:grid-cols-2 gap-16 md:gap-24">

        <!-- Formulaire -->
        <div>
          <form
            method="POST"
            action={submitUrl}
            class="flex flex-col gap-7"
          >
            <div>
              <label for="name" class="font-sans text-xs tracking-[0.18em] uppercase text-muted block mb-2">Nom complet</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full bg-transparent border-b border-sand/80 focus:border-dark outline-none py-3 font-sans text-sm font-light text-dark tracking-wide transition-colors duration-200 placeholder:text-muted/40"
                placeholder="Votre nom"
              />
            </div>
            <div>
              <label for="email" class="font-sans text-xs tracking-[0.18em] uppercase text-muted block mb-2">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full bg-transparent border-b border-sand/80 focus:border-dark outline-none py-3 font-sans text-sm font-light text-dark tracking-wide transition-colors duration-200 placeholder:text-muted/40"
                placeholder="votre@email.com"
              />
            </div>
            <div>
              <label for="event_date" class="font-sans text-xs tracking-[0.18em] uppercase text-muted block mb-2">Date de l'événement</label>
              <input
                type="text"
                id="event_date"
                name="event_date"
                class="w-full bg-transparent border-b border-sand/80 focus:border-dark outline-none py-3 font-sans text-sm font-light text-dark tracking-wide transition-colors duration-200 placeholder:text-muted/40"
                placeholder="ex. 15 juin 2026"
              />
            </div>
            <div>
              <label for="guests" class="font-sans text-xs tracking-[0.18em] uppercase text-muted block mb-2">Nombre d'invités</label>
              <input
                type="text"
                id="guests"
                name="guests"
                class="w-full bg-transparent border-b border-sand/80 focus:border-dark outline-none py-3 font-sans text-sm font-light text-dark tracking-wide transition-colors duration-200 placeholder:text-muted/40"
                placeholder="ex. 80 personnes"
              />
            </div>
            <div>
              <label for="message" class="font-sans text-xs tracking-[0.18em] uppercase text-muted block mb-2">Votre vision</label>
              <textarea
                id="message"
                name="message"
                required
                rows="5"
                class="w-full bg-transparent border-b border-sand/80 focus:border-dark outline-none py-3 font-sans text-sm font-light text-dark tracking-wide transition-colors duration-200 placeholder:text-muted/40 resize-none"
                placeholder="Décrivez votre événement, vos goûts, votre esthétique..."
              ></textarea>
            </div>
            <input type="hidden" name="_redirect" value="/merci" />
            <div>
              <button
                type="submit"
                class="inline-flex items-center gap-3 font-sans text-xs tracking-[0.18em] uppercase text-dark border border-dark/30 px-8 py-4 hover:bg-dark hover:text-bg transition-all duration-300"
              >
                Envoyer ma demande
                <span class="iconify" data-icon="lucide:arrow-right" data-width="14"></span>
              </button>
            </div>
          </form>
        </div>

        <!-- Informations de contact -->
        <div class="flex flex-col gap-12">
          <div>
            <p class="font-sans text-xs tracking-[0.22em] uppercase text-muted mb-4">Email</p>
            <a href={`mailto:${site.email}`} class="font-serif text-2xl font-light text-dark hover:opacity-60 transition-opacity">{site.email}</a>
          </div>
          {site.address && (
            <div>
              <p class="font-sans text-xs tracking-[0.22em] uppercase text-muted mb-4">Adresse</p>
              <p class="font-serif text-2xl font-light text-dark">{site.address}</p>
            </div>
          )}
          <div>
            <p class="font-sans text-xs tracking-[0.22em] uppercase text-muted mb-6">{site.process_badge}</p>
            <div class="flex flex-col gap-6">
              <div class="flex gap-5 items-start">
                <div class="font-serif text-3xl font-light text-sand leading-none select-none w-8 flex-shrink-0">01</div>
                <div>
                  <h3 class="font-serif text-lg font-light text-dark mb-1">{site.step1_title}</h3>
                  <p class="font-sans text-xs font-light leading-relaxed text-muted tracking-wide">{site.step1_desc}</p>
                </div>
              </div>
              <div class="flex gap-5 items-start">
                <div class="font-serif text-3xl font-light text-sand leading-none select-none w-8 flex-shrink-0">02</div>
                <div>
                  <h3 class="font-serif text-lg font-light text-dark mb-1">{site.step2_title}</h3>
                  <p class="font-sans text-xs font-light leading-relaxed text-muted tracking-wide">{site.step2_desc}</p>
                </div>
              </div>
              <div class="flex gap-5 items-start">
                <div class="font-serif text-3xl font-light text-sand leading-none select-none w-8 flex-shrink-0">03</div>
                <div>
                  <h3 class="font-serif text-lg font-light text-dark mb-1">{site.step3_title}</h3>
                  <p class="font-sans text-xs font-light leading-relaxed text-muted tracking-wide">{site.step3_desc}</p>
                </div>
              </div>
              <div class="flex gap-5 items-start">
                <div class="font-serif text-3xl font-light text-sand leading-none select-none w-8 flex-shrink-0">04</div>
                <div>
                  <h3 class="font-serif text-lg font-light text-dark mb-1">{site.step4_title}</h3>
                  <p class="font-sans text-xs font-light leading-relaxed text-muted tracking-wide">{site.step4_desc}</p>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-28 md:py-36 bg-sand/20">
    <div class="max-w-3xl mx-auto px-8">
      <div class="mb-16 text-center">
        <h2 class="font-serif text-4xl md:text-5xl font-light text-dark mb-4">{site.faq_title}</h2>
        <p class="font-sans text-sm font-light text-muted tracking-wide">{site.faq_subtitle}</p>
      </div>
      <div class="divide-y divide-sand/60">
        <div class="faq-item py-7">
          <button class="faq-trigger w-full flex items-center justify-between text-left gap-6">
            <span class="font-serif text-xl font-light text-dark">{site.faq1_q}</span>
            <span class="iconify faq-icon flex-shrink-0 text-muted transition-transform duration-300" data-icon="lucide:plus" data-width="18"></span>
          </button>
          <div class="faq-answer hidden pt-5">
            <p class="font-sans text-sm font-light leading-relaxed text-muted tracking-wide">{site.faq1_a}</p>
          </div>
        </div>
        <div class="faq-item py-7">
          <button class="faq-trigger w-full flex items-center justify-between text-left gap-6">
            <span class="font-serif text-xl font-light text-dark">{site.faq2_q}</span>
            <span class="iconify faq-icon flex-shrink-0 text-muted transition-transform duration-300" data-icon="lucide:plus" data-width="18"></span>
          </button>
          <div class="faq-answer hidden pt-5">
            <p class="font-sans text-sm font-light leading-relaxed text-muted tracking-wide">{site.faq2_a}</p>
          </div>
        </div>
        <div class="faq-item py-7">
          <button class="faq-trigger w-full flex items-center justify-between text-left gap-6">
            <span class="font-serif text-xl font-light text-dark">{site.faq3_q}</span>
            <span class="iconify faq-icon flex-shrink-0 text-muted transition-transform duration-300" data-icon="lucide:plus" data-width="18"></span>
          </button>
          <div class="faq-answer hidden pt-5">
            <p class="font-sans text-sm font-light leading-relaxed text-muted tracking-wide">{site.faq3_a}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />

  <script is:inline>
    document.querySelectorAll('.faq-item').forEach(function(item) {
      var trigger = item.querySelector('.faq-trigger');
      var answer = item.querySelector('.faq-answer');
      var icon = item.querySelector('.faq-icon');
      trigger.addEventListener('click', function() {
        var isOpen = !answer.classList.contains('hidden');
        document.querySelectorAll('.faq-answer').forEach(function(a) { a.classList.add('hidden'); });
        document.querySelectorAll('.faq-icon').forEach(function(i) {
          i.setAttribute('data-icon', 'lucide:plus');
          i.style.transform = '';
        });
        if (!isOpen) {
          answer.classList.remove('hidden');
          icon.setAttribute('data-icon', 'lucide:minus');
        }
      });
    });
  </script>

</Base>
