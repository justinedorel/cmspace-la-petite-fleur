---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
const formAction = `https://contact.cmspace.app/submit?to=${encodeURIComponent(site.email)}`;
---
<Base title={`Contact — ${site.company_name} Expertise`} description={site.contact_text}>
  <Header />
  <main>

    <!-- Hero -->
    <section class="hero-grid px-6 pt-20 pb-16 bg-[var(--color-bg)]">
      <div class="max-w-4xl mx-auto text-center" data-animate>
        <span class="inline-flex items-center px-4 py-1.5 rounded-full bg-[var(--color-accent)]/15 border border-[var(--color-accent)]/30 text-[var(--color-accent2)] text-xs font-semibold tracking-wide mb-7">
          {site.contact_badge}
        </span>
        <h1 class="text-5xl lg:text-6xl font-bold tracking-tight text-white leading-tight mb-7">Parlons de vos chiffres</h1>
        <p class="text-lg text-[var(--color-muted)] leading-relaxed max-w-2xl mx-auto">{site.contact_text}</p>
      </div>
    </section>

    <!-- Coordonnées + formulaire -->
    <section class="px-6 py-20 bg-[var(--color-bg)]">
      <div class="max-w-7xl mx-auto grid lg:grid-cols-5 gap-12">
        <div class="lg:col-span-2 space-y-6" data-animate>
          <div class="bg-[var(--color-surface)] border border-white/[0.06] rounded-2xl p-7 space-y-6">
            <div class="flex items-start gap-4">
              <span class="w-11 h-11 rounded-full bg-white/[0.05] border border-white/[0.08] flex items-center justify-center shrink-0">
                <iconify-icon icon="solar:map-point-linear" class="text-[var(--color-accent2)] text-lg"></iconify-icon>
              </span>
              <div>
                <div class="text-xs text-[var(--color-muted)] uppercase tracking-widest mb-1">Adresse</div>
                <div class="text-sm font-medium text-white">{site.address}</div>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <span class="w-11 h-11 rounded-full bg-white/[0.05] border border-white/[0.08] flex items-center justify-center shrink-0">
                <iconify-icon icon="solar:phone-linear" class="text-[var(--color-accent2)] text-lg"></iconify-icon>
              </span>
              <div>
                <div class="text-xs text-[var(--color-muted)] uppercase tracking-widest mb-1">Ligne directe</div>
                <a href={`tel:${site.phone}`} class="text-sm font-medium text-white hover:text-[var(--color-accent2)]">{site.phone}</a>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <span class="w-11 h-11 rounded-full bg-white/[0.05] border border-white/[0.08] flex items-center justify-center shrink-0">
                <iconify-icon icon="solar:letter-linear" class="text-[var(--color-accent2)] text-lg"></iconify-icon>
              </span>
              <div>
                <div class="text-xs text-[var(--color-muted)] uppercase tracking-widest mb-1">Email</div>
                <a href={`mailto:${site.email}`} class="text-sm font-medium text-white hover:text-[var(--color-accent2)]">{site.email}</a>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <span class="w-11 h-11 rounded-full bg-white/[0.05] border border-white/[0.08] flex items-center justify-center shrink-0">
                <iconify-icon icon="solar:clock-circle-linear" class="text-[var(--color-accent2)] text-lg"></iconify-icon>
              </span>
              <div>
                <div class="text-xs text-[var(--color-muted)] uppercase tracking-widest mb-1">Horaires</div>
                <div class="text-sm font-medium text-white">{site.hours}</div>
                <div class="text-xs text-[var(--color-muted)] mt-1">Rendez-vous en présentiel ou en visio</div>
              </div>
            </div>
          </div>
          <div class="bg-[var(--color-surface)] border border-[var(--color-accent)]/30 rounded-2xl p-7">
            <div class="flex items-center gap-3 mb-3">
              <iconify-icon icon="solar:star-bold" class="text-amber-400 text-lg"></iconify-icon>
              <span class="text-sm font-bold text-white">{site.hero_badge_rating}</span>
            </div>
            <p class="text-sm text-[var(--color-muted)] leading-relaxed">Réponse garantie sous 24h ouvrées. Premier échange gratuit et confidentiel, couvert par le secret professionnel.</p>
          </div>
        </div>

        <form method="POST" action={formAction} class="lg:col-span-3 bg-[var(--color-surface)] border border-white/[0.06] rounded-2xl p-8 space-y-5" data-animate>
          <h2 class="text-2xl font-bold text-white mb-1">{site.contact_form_title}</h2>
          <p class="text-sm text-[var(--color-muted)] mb-4">Décrivez votre besoin, un associé vous rappelle personnellement.</p>
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label class="text-xs font-semibold text-[var(--color-muted)] block mb-1.5">Prénom *</label>
              <input type="text" name="firstname" required placeholder="Votre prénom"
                class="w-full px-4 py-3 bg-white/[0.04] border border-white/[0.08] rounded-lg text-sm text-white placeholder:text-white/30 focus:outline-none focus:border-[var(--color-accent)]" />
            </div>
            <div>
              <label class="text-xs font-semibold text-[var(--color-muted)] block mb-1.5">Nom *</label>
              <input type="text" name="lastname" required placeholder="Votre nom"
                class="w-full px-4 py-3 bg-white/[0.04] border border-white/[0.08] rounded-lg text-sm text-white placeholder:text-white/30 focus:outline-none focus:border-[var(--color-accent)]" />
            </div>
          </div>
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label class="text-xs font-semibold text-[var(--color-muted)] block mb-1.5">Email *</label>
              <input type="email" name="email" required placeholder="votre@email.fr"
                class="w-full px-4 py-3 bg-white/[0.04] border border-white/[0.08] rounded-lg text-sm text-white placeholder:text-white/30 focus:outline-none focus:border-[var(--color-accent)]" />
            </div>
            <div>
              <label class="text-xs font-semibold text-[var(--color-muted)] block mb-1.5">Téléphone</label>
              <input type="tel" name="phone" placeholder="06 12 34 56 78"
                class="w-full px-4 py-3 bg-white/[0.04] border border-white/[0.08] rounded-lg text-sm text-white placeholder:text-white/30 focus:outline-none focus:border-[var(--color-accent)]" />
            </div>
          </div>
          <div>
            <label class="text-xs font-semibold text-[var(--color-muted)] block mb-1.5">Service souhaité</label>
            <select name="service"
              class="w-full px-4 py-3 bg-white/[0.04] border border-white/[0.08] rounded-lg text-sm text-white focus:outline-none focus:border-[var(--color-accent)] [&>option]:text-[#0F172A]">
              <option value="">Sélectionnez un service</option>
              {site.services.map(svc => <option>{svc.name}</option>)}
              <option>Création d'entreprise</option>
            </select>
          </div>
          <div>
            <label class="text-xs font-semibold text-[var(--color-muted)] block mb-1.5">Votre message</label>
            <textarea name="message" rows="5" placeholder="Décrivez votre activité et votre besoin…"
              class="w-full px-4 py-3 bg-white/[0.04] border border-white/[0.08] rounded-lg text-sm text-white placeholder:text-white/30 resize-y focus:outline-none focus:border-[var(--color-accent)]"></textarea>
          </div>
          <label class="flex items-start gap-3 text-xs text-[var(--color-muted)] leading-relaxed cursor-pointer">
            <input type="checkbox" name="consent" required class="mt-0.5 accent-[var(--color-accent)]" />
            J'accepte que mes données soient utilisées pour me recontacter dans le cadre de ma demande.
          </label>
          <button type="submit"
            class="w-full sm:w-auto bg-[var(--color-accent)] hover:bg-[var(--color-accent2)] text-white px-9 py-4 rounded-full font-semibold text-sm transition-all flex items-center justify-center gap-2 shadow-lg shadow-blue-600/25">
            {site.contact_form_cta}
            <iconify-icon icon="solar:arrow-right-linear" class="text-base"></iconify-icon>
          </button>
        </form>
      </div>
    </section>

  </main>
  <Footer />
</Base>
