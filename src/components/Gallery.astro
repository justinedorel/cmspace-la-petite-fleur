---
import site from '../data/site.json';
---
<section class="bg-[#FFF8E7] py-20">
  <div class="max-w-7xl mx-auto px-4">

    <!-- Titre -->
    <div class="text-center mb-12 reveal">
      <div class="font-cursive text-[#EAB308] text-5xl mb-2">{site.gallery_cursive}</div>
      <h2 class="text-4xl font-black uppercase text-[#4A3219]">{site.gallery_title}</h2>
    </div>

    <!-- Grille masonry 2x2 + 2 -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 reveal" style="grid-template-rows: 220px 220px;">

      <!-- Grande image sur 2 colonnes / 2 lignes -->
      <div class="col-span-2 row-span-2 overflow-hidden rounded-3xl group relative">
        <img
          src="https://images.unsplash.com/photo-1488477304112-4944851de03d?q=80&w=800&auto=format&fit=crop"
          alt="Galerie pâtisserie"
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-[#4A3219]/0 group-hover:bg-[#4A3219]/30 transition-colors rounded-3xl flex items-center justify-center">
          <iconify-icon icon="solar:eye-linear" class="text-white text-4xl opacity-0 group-hover:opacity-100 transition-opacity"></iconify-icon>
        </div>
      </div>

      <!-- Image haut droite -->
      <div class="overflow-hidden rounded-3xl group relative">
        <img
          src="https://images.unsplash.com/photo-1519869325930-281384150729?q=80&w=500&auto=format&fit=crop"
          alt="Tartelette citron"
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-[#4A3219]/0 group-hover:bg-[#4A3219]/30 transition-colors rounded-3xl flex items-center justify-center">
          <iconify-icon icon="solar:eye-linear" class="text-white text-3xl opacity-0 group-hover:opacity-100 transition-opacity"></iconify-icon>
        </div>
      </div>

      <!-- Image milieu droite -->
      <div class="overflow-hidden rounded-3xl group relative">
        <img
          src="https://images.unsplash.com/photo-1571115177098-24ec42ed204d?q=80&w=500&auto=format&fit=crop"
          alt="Macarons"
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-[#4A3219]/0 group-hover:bg-[#4A3219]/30 transition-colors rounded-3xl flex items-center justify-center">
          <iconify-icon icon="solar:eye-linear" class="text-white text-3xl opacity-0 group-hover:opacity-100 transition-opacity"></iconify-icon>
        </div>
      </div>

      <!-- Image basse large sur 2 colonnes -->
      <div class="col-span-2 overflow-hidden rounded-3xl group relative">
        <img
          src="https://images.unsplash.com/photo-1464219789935-c2d9d9aba644?q=80&w=900&auto=format&fit=crop"
          alt="Gâteau signature"
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-[#4A3219]/0 group-hover:bg-[#4A3219]/30 transition-colors rounded-3xl flex items-center justify-center">
          <iconify-icon icon="solar:eye-linear" class="text-white text-4xl opacity-0 group-hover:opacity-100 transition-opacity"></iconify-icon>
        </div>
      </div>

      <!-- Image atelier (cachée sur mobile) -->
      <div class="hidden md:block overflow-hidden rounded-3xl group relative">
        <img
          src="https://images.unsplash.com/photo-1606313564200-e75d5e30476c?q=80&w=500&auto=format&fit=crop"
          alt="Atelier pâtisserie"
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-[#4A3219]/0 group-hover:bg-[#4A3219]/30 transition-colors rounded-3xl flex items-center justify-center">
          <iconify-icon icon="solar:eye-linear" class="text-white text-3xl opacity-0 group-hover:opacity-100 transition-opacity"></iconify-icon>
        </div>
      </div>

    </div>
  </div>
</section>
