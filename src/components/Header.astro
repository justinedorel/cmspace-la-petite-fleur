---
import site from '../data/site.json';
---
<header id="nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" style="background:rgba(250,250,247,0.92);backdrop-filter:blur(12px);border-bottom:1px solid rgba(92,122,92,0.12);">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="font-serif text-xl font-light text-dark tracking-wide">
      {site.company_name}
    </a>

    <!-- Navigation desktop -->
    <nav class="hidden md:flex items-center gap-8">
      <a href="/" class="text-sm font-sans text-dark/70 hover:text-dark transition-colors">Accueil</a>
      <a href="/a-propos/" class="text-sm font-sans text-dark/70 hover:text-dark transition-colors">À propos</a>
      <a href="/services/" class="text-sm font-sans text-dark/70 hover:text-dark transition-colors">Soins</a>
      <a href="/contact/" class="text-sm font-sans text-dark/70 hover:text-dark transition-colors">Contact</a>
      <a href="/contact/" class="btn-accent text-sm font-sans px-5 py-2 rounded-sm">
        {site.hero_cta}
      </a>
    </nav>

    <!-- Mobile toggle -->
    <button id="mobile-toggle" class="md:hidden p-2" aria-label="Menu">
      <div class="w-5 h-px bg-dark mb-1.5"></div>
      <div class="w-5 h-px bg-dark mb-1.5"></div>
      <div class="w-5 h-px bg-dark"></div>
    </button>
  </div>
</header>

<!-- Mobile menu -->
<div id="mobile-overlay" class="fixed inset-0 bg-dark/40 z-40 hidden backdrop-blur-sm"></div>
<div id="mobile-panel" class="fixed top-0 right-0 h-full w-72 z-50 p-8 flex flex-col gap-8 pt-20" style="background:#FAFAF7;transform:translateX(100%);transition:transform 0.4s cubic-bezier(0.16,1,0.3,1);">
  <a href="/" class="font-serif text-2xl font-light text-dark hover:opacity-60">Accueil</a>
  <a href="/a-propos/" class="font-serif text-2xl font-light text-dark hover:opacity-60">À propos</a>
  <a href="/services/" class="font-serif text-2xl font-light text-dark hover:opacity-60">Soins</a>
  <a href="/contact/" class="font-serif text-2xl font-light text-dark hover:opacity-60">Contact</a>
  <a href="/contact/" class="btn-accent text-center py-3 rounded-sm font-sans text-sm">{site.hero_cta}</a>
</div>

<script is:inline>
  var toggle = document.getElementById('mobile-toggle');
  var panel = document.getElementById('mobile-panel');
  var overlay = document.getElementById('mobile-overlay');
  var open = false;
  function openMenu() { open = true; panel.style.transform = 'translateX(0)'; overlay.classList.remove('hidden'); document.body.style.overflow = 'hidden'; }
  function closeMenu() { open = false; panel.style.transform = 'translateX(100%)'; overlay.classList.add('hidden'); document.body.style.overflow = ''; }
  toggle.addEventListener('click', function() { open ? closeMenu() : openMenu(); });
  overlay.addEventListener('click', closeMenu);
  panel.querySelectorAll('a').forEach(function(a) { a.addEventListener('click', closeMenu); });
</script>
