---
import site from '../data/site.json';
---
<header id="nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
  <div class="max-w-7xl mx-auto px-8 py-5 flex items-center justify-between">
    <a href="/" class="font-serif text-2xl tracking-[0.2em] font-light text-dark">{site.company_name}</a>
    <nav class="hidden md:flex items-center gap-10">
      <a href="/services" class="font-sans text-xs tracking-[0.18em] uppercase text-dark/70 hover:text-dark transition-colors">Saveurs</a>
      <a href="/a-propos" class="font-sans text-xs tracking-[0.18em] uppercase text-dark/70 hover:text-dark transition-colors">À propos</a>
      <a href="/contact" class="font-sans text-xs tracking-[0.18em] uppercase text-dark/70 hover:text-dark transition-colors">Contact</a>
      <a href={`mailto:${site.email}`} class="font-sans text-xs tracking-[0.18em] uppercase border border-dark/30 text-dark px-5 py-2.5 hover:bg-dark hover:text-bg transition-all duration-300">{site.hero_cta}</a>
    </nav>
    <!-- Mobile menu button -->
    <button id="mobile-menu-btn" class="md:hidden flex flex-col gap-1.5 p-2" aria-label="Menu">
      <span class="w-6 h-px bg-dark block transition-all duration-300"></span>
      <span class="w-6 h-px bg-dark block transition-all duration-300"></span>
      <span class="w-6 h-px bg-dark block transition-all duration-300"></span>
    </button>
  </div>
  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-bg border-t border-sand/40">
    <div class="max-w-7xl mx-auto px-8 py-6 flex flex-col gap-5">
      <a href="/services" class="font-sans text-xs tracking-[0.18em] uppercase text-dark/70 hover:text-dark transition-colors">Saveurs</a>
      <a href="/a-propos" class="font-sans text-xs tracking-[0.18em] uppercase text-dark/70 hover:text-dark transition-colors">À propos</a>
      <a href="/contact" class="font-sans text-xs tracking-[0.18em] uppercase text-dark/70 hover:text-dark transition-colors">Contact</a>
      <a href={`mailto:${site.email}`} class="font-sans text-xs tracking-[0.18em] uppercase border border-dark/30 text-dark px-5 py-2.5 hover:bg-dark hover:text-bg transition-all duration-300 self-start">{site.hero_cta}</a>
    </div>
  </div>
</header>

<script is:inline>
  var nav = document.getElementById('nav');
  window.addEventListener('scroll', function() {
    if (window.scrollY > 80) {
      nav.style.backgroundColor = '#f5f2ee';
      nav.style.boxShadow = '0 1px 0 rgba(0,0,0,0.06)';
    } else {
      nav.style.backgroundColor = 'transparent';
      nav.style.boxShadow = 'none';
    }
  });

  var mobileBtn = document.getElementById('mobile-menu-btn');
  var mobileMenu = document.getElementById('mobile-menu');
  mobileBtn.addEventListener('click', function() {
    mobileMenu.classList.toggle('hidden');
  });
</script>
