---
import site from '../data/site.json';
const nav = [
  { href: '/services/', label: 'Nos Produits' },
  { href: '/a-propos/', label: 'À propos' },
  { href: '/contact/', label: 'Contact' },
];
const current = Astro.url?.pathname ?? '';
---
<header class="sticky top-0 z-50 bg-[#F9F7F2]/95 backdrop-blur-sm border-b border-[#2D4A2D]/10">
  <div class="max-w-6xl mx-auto px-6 h-18 flex items-center justify-between py-4">
    <a href="/" class="font-display text-xl font-bold text-[#2D4A2D]">{site.company_name}</a>
    <nav class="hidden md:flex items-center gap-8 text-sm font-medium text-[#6B7C6B]">
      {nav.map(n => (
        <a href={n.href} class={`hover:text-[#2D4A2D] transition-colors ${current.startsWith(n.href) ? 'text-[#2D4A2D] font-semibold' : ''}`}>{n.label}</a>
      ))}
    </nav>
    <a href="/contact/" class="bg-[#2D4A2D] text-[#E8D5A3] text-sm font-semibold px-5 py-2.5 rounded-full hover:bg-[#1C2B1C] transition-colors">{site.nav_cta}</a>
  </div>
</header>
