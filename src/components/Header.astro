---
import site from '../data/site.json';
---
<nav class="sticky top-0 z-50 w-full backdrop-blur-md border-b" style={`background-color: ${site.color_bg}e6; border-color: ${site.color_accent}4d;`}>
  <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12 flex justify-between items-center h-20">
    <a href="/" class="flex items-center hover:opacity-80 transition-opacity">
      {site.logo_url
        ? <img src={site.logo_url} alt={site.company_name} class="h-8 sm:h-10 w-auto object-contain" />
        : <span class="font-heading text-xl font-bold" style={`color: ${site.color_dark};`}>{site.company_name}</span>
      }
    </a>
    <div class="hidden md:flex items-center gap-8 text-sm font-medium text-gray-600">
      <a href="/services" class="transition-colors hover:opacity-80" style={`color: ${site.color_dark};`}>Services</a>
      <a href="/a-propos" class="transition-colors hover:opacity-80" style={`color: ${site.color_dark};`}>À propos</a>
      <a href="/contact" class="transition-colors hover:opacity-80" style={`color: ${site.color_dark};`}>Contact</a>
    </div>
    <div class="flex items-center gap-4">
      <a href="/contact" class="text-white text-sm font-semibold px-5 py-2.5 rounded-lg shadow-sm transition-all duration-200 hover:opacity-90" style={`background-color: ${site.color_primary};`}>
        Nous contacter
      </a>
    </div>
  </div>
</nav>

<script is:inline>
  (function() {
    var header = document.querySelector('header, nav[class*="fixed"]');
    if (!header) return;
    var alreadyGlass = getComputedStyle(header).backdropFilter !== 'none';
    window.addEventListener('scroll', function() {
      if (window.scrollY > 60) {
        header.style.backdropFilter = 'blur(12px)';
        header.style.webkitBackdropFilter = 'blur(12px)';
        if (!alreadyGlass) header.style.backgroundColor = header.style.backgroundColor || 'rgba(0,0,0,0.8)';
      } else {
        if (!alreadyGlass) {
          header.style.backdropFilter = 'none';
          header.style.webkitBackdropFilter = 'none';
        }
      }
    }, { passive: true });
  })();
</script>
