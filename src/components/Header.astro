---
import site from '../data/site.json';
---
<header id="nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
  <div class="max-w-7xl mx-auto px-6 md:px-8 h-16 md:h-20 flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="font-serif text-xl md:text-2xl tracking-[0.15em] font-light text-white nav-logo transition-colors duration-500">
      {site.company_name}
    </a>

    <!-- Navigation desktop -->
    <nav class="hidden md:flex items-center gap-8">
      <a href="/services" class="nav-link font-sans text-[11px] tracking-[0.2em] uppercase text-white/80 hover:text-white transition-colors relative group">
        {(site as any).nav_services_label || 'Services'}
        <span class="absolute -bottom-0.5 left-0 w-0 h-px bg-white group-hover:w-full transition-all duration-300"></span>
      </a>
      <a href="/a-propos" class="nav-link font-sans text-[11px] tracking-[0.2em] uppercase text-white/80 hover:text-white transition-colors relative group">
        À propos
        <span class="absolute -bottom-0.5 left-0 w-0 h-px bg-white group-hover:w-full transition-all duration-300"></span>
      </a>
      <a href="/contact" class="nav-link font-sans text-[11px] tracking-[0.2em] uppercase text-white/80 hover:text-white transition-colors relative group">
        Contact
        <span class="absolute -bottom-0.5 left-0 w-0 h-px bg-white group-hover:w-full transition-all duration-300"></span>
      </a>
      <a href="/contact" class="nav-cta font-sans text-[11px] tracking-[0.2em] uppercase border border-white/50 text-white px-6 py-2.5 hover:bg-white hover:text-dark transition-all duration-300 ml-2">
        {site.hero_cta}
      </a>
    </nav>

    <!-- Mobile toggle -->
    <button id="mobile-toggle" class="md:hidden flex flex-col gap-[5px] p-2 group" aria-label="Menu">
      <span id="m1" class="w-6 h-px bg-white block transition-all duration-400 origin-center"></span>
      <span id="m2" class="w-4 h-px bg-white block transition-all duration-400 ml-auto"></span>
      <span id="m3" class="w-6 h-px bg-white block transition-all duration-400 origin-center"></span>
    </button>
  </div>
</header>

<!-- Mobile menu — slide depuis la droite -->
<div id="mobile-menu" class="fixed inset-0 z-40 pointer-events-none">
  <div id="mobile-overlay" class="absolute inset-0 bg-dark/60 opacity-0 transition-opacity duration-400 backdrop-blur-sm"></div>
  <div id="mobile-panel" class="absolute right-0 top-0 h-full w-72 bg-bg flex flex-col pt-24 px-8 pb-8 translate-x-full transition-transform duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]">
    <nav class="flex flex-col gap-8 mb-auto">
      <a href="/services" class="font-serif text-3xl font-light text-dark hover:opacity-60 transition-opacity">{(site as any).nav_services_label || 'Services'}</a>
      <a href="/a-propos"  class="font-serif text-3xl font-light text-dark hover:opacity-60 transition-opacity">À propos</a>
      <a href="/contact"   class="font-serif text-3xl font-light text-dark hover:opacity-60 transition-opacity">Contact</a>
    </nav>
    <div class="border-t border-sand pt-8 space-y-3">
      <a href={`mailto:${site.email}`} class="block font-sans text-xs tracking-[0.15em] uppercase text-muted hover:text-dark transition-colors">{site.email}</a>
      {(site as any).phone && <a href={`tel:${(site as any).phone}`} class="block font-sans text-xs tracking-[0.15em] uppercase text-muted hover:text-dark transition-colors">{(site as any).phone}</a>}
    </div>
  </div>
</div>

<script is:inline>
  var nav = document.getElementById('nav');
  var logo = nav.querySelector('.nav-logo');
  var links = nav.querySelectorAll('.nav-link');
  var cta = nav.querySelector('.nav-cta');
  var scrolled = false;

  function updateNav() {
    var atTop = window.scrollY < 80;
    if (atTop) {
      nav.style.backgroundColor = 'transparent';
      nav.style.backdropFilter  = 'none';
      nav.style.boxShadow       = 'none';
      logo.style.color          = '#fff';
      links.forEach(function(l) { l.style.color = 'rgba(255,255,255,0.8)'; l.querySelectorAll('span').forEach(function(s) { s.style.background = '#fff'; }); });
      if (cta) { cta.style.borderColor = 'rgba(255,255,255,0.5)'; cta.style.color = '#fff'; cta.style.backgroundColor = 'transparent'; }
    } else {
      nav.style.backgroundColor = 'rgba(250,248,242,0.92)';
      nav.style.backdropFilter  = 'blur(12px)';
      nav.style.boxShadow       = '0 1px 0 rgba(0,0,0,0.06)';
      logo.style.color          = '#1a1a1a';
      links.forEach(function(l) { l.style.color = 'rgba(26,26,26,0.7)'; l.querySelectorAll('span').forEach(function(s) { s.style.background = '#1a1a1a'; }); });
      if (cta) { cta.style.borderColor = 'rgba(26,26,26,0.4)'; cta.style.color = '#1a1a1a'; cta.style.backgroundColor = 'transparent'; }
    }
  }
  updateNav();
  window.addEventListener('scroll', updateNav, { passive: true });

  // Mobile menu
  var toggle = document.getElementById('mobile-toggle');
  var menu   = document.getElementById('mobile-menu');
  var overlay = document.getElementById('mobile-overlay');
  var panel   = document.getElementById('mobile-panel');
  var m1 = document.getElementById('m1');
  var m2 = document.getElementById('m2');
  var m3 = document.getElementById('m3');
  var open = false;

  function openMenu() {
    open = true;
    menu.style.pointerEvents = 'all';
    overlay.style.opacity = '1';
    panel.style.transform = 'translateX(0)';
    m1.style.transform = 'rotate(45deg) translate(3.5px, 3.5px)';
    m2.style.opacity = '0';
    m3.style.transform = 'rotate(-45deg) translate(3.5px, -3.5px)';
    document.body.style.overflow = 'hidden';
  }
  function closeMenu() {
    open = false;
    menu.style.pointerEvents = 'none';
    overlay.style.opacity = '0';
    panel.style.transform = 'translateX(100%)';
    m1.style.transform = ''; m2.style.opacity = ''; m3.style.transform = '';
    document.body.style.overflow = '';
  }
  toggle.addEventListener('click', function() { open ? closeMenu() : openMenu(); });
  overlay.addEventListener('click', closeMenu);
  panel.querySelectorAll('a').forEach(function(a) { a.addEventListener('click', closeMenu); });
</script>
