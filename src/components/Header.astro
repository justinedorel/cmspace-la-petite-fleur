---
import site from '../data/site.json';
const nav = [
  { label: 'Accueil', href: '/' },
  { label: 'À propos', href: '/a-propos/' },
  { label: 'Services', href: '/services/' },
  { label: 'Contact', href: '/contact/' },
];
const current = Astro.url.pathname;
---
<header class="sticky top-0 z-50 bg-[#050A14]/95 backdrop-blur-md border-b border-white/[0.06]">
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between gap-4">
    <a href="/" class="flex items-center gap-3 shrink-0">
      <span class="w-10 h-10 rounded-xl bg-[var(--color-accent)] flex items-center justify-center">
        <iconify-icon icon="solar:calculator-minimalistic-bold" class="text-xl text-white"></iconify-icon>
      </span>
      <span class="leading-tight">
        <span class="block text-lg font-bold text-white tracking-tight">{site.company_name}<span class="text-[var(--color-accent2)]">.</span></span>
        <span class="block text-[10px] font-semibold tracking-[0.2em] text-[var(--color-muted)]">{site.company_sub}</span>
      </span>
    </a>
    <nav class="hidden lg:flex items-center gap-8 text-sm font-medium text-[var(--color-muted)]">
      {nav.map(item => (
        <a href={item.href}
          class={`hover:text-white transition-colors ${current === item.href || current === item.href.slice(0,-1) ? 'text-white font-semibold' : ''}`}>
          {item.label}
        </a>
      ))}
    </nav>
    <div class="hidden lg:flex items-center gap-5">
      <a href={`tel:${site.phone}`} class="flex items-center gap-2 text-sm font-medium text-[var(--color-muted)] hover:text-white transition-colors">
        <iconify-icon icon="solar:phone-linear" class="text-base text-[var(--color-accent2)]"></iconify-icon>
        {site.phone}
      </a>
      <a href="/contact/"
        class="bg-white text-[#0F172A] px-5 py-2.5 rounded-full text-sm font-semibold hover:bg-blue-50 transition-all">
        Prendre rendez-vous
      </a>
    </div>
    <button id="menu-btn" class="lg:hidden p-2 text-[var(--color-muted)]" aria-label="Menu">
      <iconify-icon icon="solar:hamburger-menu-linear" class="text-2xl"></iconify-icon>
    </button>
  </div>
  <div id="mobile-menu" class="hidden lg:hidden border-t border-white/[0.06] bg-[#050A14] px-6 py-4 space-y-3">
    {nav.map(item => (
      <a href={item.href} class="block text-sm font-medium text-[var(--color-muted)] hover:text-white py-1">{item.label}</a>
    ))}
    <a href={`tel:${site.phone}`} class="block text-sm font-medium text-[var(--color-muted)] py-1">{site.phone}</a>
    <a href="/contact/" class="block bg-white text-[#0F172A] text-center px-5 py-2.5 rounded-full text-sm font-semibold mt-2">Prendre rendez-vous</a>
  </div>
</header>
<script>
  document.getElementById('menu-btn')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
</script>
