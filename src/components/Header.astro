---
import site from '../data/site.json';
const nav = [
  { label: 'Accueil', href: '/' },
  { label: 'Services', href: '/services' },
  { label: 'À propos', href: '/a-propos' },
  { label: 'Contact', href: '/contact' },
];
const current = Astro.url.pathname;
---
<header style="background:var(--colorBg);border-bottom:1px solid #e5e7eb;position:sticky;top:0;z-index:100;">
  <div class="container" style="display:flex;align-items:center;justify-content:space-between;height:4rem;">
    <a href="/" style="font-family:var(--fontHeading);font-size:1.25rem;font-weight:700;color:var(--colorPrimary);">
      {site.logo_url ? <img src={site.logo_url} alt={site.company_name} style="height:2.5rem;" /> : site.company_name}
    </a>
    <nav style="display:flex;align-items:center;gap:2rem;">
      {nav.map(item => (
        <a href={item.href} style={`font-size:0.9rem;font-weight:500;color:${current === item.href ? 'var(--colorAccent)' : 'var(--colorText)'};`}>
          {item.label}
        </a>
      ))}
      {site.nav_cta_href && (
        <a href={site.nav_cta_href} class="btn-primary" style="padding:0.5rem 1.25rem;font-size:0.85rem;">
          {site.nav_cta_label}
        </a>
      )}
    </nav>
  </div>
</header>
