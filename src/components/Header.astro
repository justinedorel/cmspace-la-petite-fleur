---
import site from '../data/site.json';
const nav = [
  { label: 'Services', href: '/services' },
  { label: 'À propos', href: '/a-propos' },
  { label: 'Contact', href: '/contact' },
];
const current = Astro.url.pathname;
---
<header class="sticky top-0 z-50 w-full border-b border-zinc-900 bg-zinc-950/80 backdrop-blur-md">
  <div class="container mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="text-xl font-medium tracking-tighter text-zinc-100">
      {site.logo_url
        ? <img src={site.logo_url} alt={site.company_name} class="h-8 w-auto" />
        : site.company_name
      }
    </a>
    <nav class="hidden md:flex items-center gap-8 text-sm text-zinc-400">
      {nav.map(item => (
        <a href={item.href}
          class={`hover:text-zinc-100 transition-colors ${current === item.href ? 'text-zinc-100' : ''}`}>
          {item.label}
        </a>
      ))}
    </nav>
    <a href="/contact" class="px-4 py-2 text-sm font-medium bg-zinc-100 text-zinc-950 rounded-md hover:bg-zinc-200 transition-colors">
      Démarrer un projet
    </a>
  </div>
</header>

<script is:inline>
  (function() {
    var header = document.querySelector('header, nav[class*="fixed"]');
    if (!header) return;
    var alreadyGlass = getComputedStyle(header).backdropFilter !== 'none';
    window.addEventListener('scroll', function() {
      if (window.scrollY > 60) {
        header.style.backdropFilter = 'blur(12px)';
        header.style.webkitBackdropFilter = 'blur(12px)';
        if (!alreadyGlass) header.style.backgroundColor = header.style.backgroundColor || 'rgba(0,0,0,0.8)';
      } else {
        if (!alreadyGlass) {
          header.style.backdropFilter = 'none';
          header.style.webkitBackdropFilter = 'none';
        }
      }
    }, { passive: true });
  })();
</script>
