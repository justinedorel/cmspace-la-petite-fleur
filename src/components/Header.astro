---
import site from '../data/site.json';
---
<header id="site-header" class="sticky top-0 z-50 bg-white border-b border-[#4A3219]/10 shadow-sm transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between gap-4">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 shrink-0">
      <div class="grid grid-cols-2 gap-0.5 w-9 h-9">
        <iconify-icon icon="solar:star-bold" class="text-[#EAB308] text-lg"></iconify-icon>
        <iconify-icon icon="solar:cup-hot-bold" class="text-[#EAB308] text-lg"></iconify-icon>
        <iconify-icon icon="solar:heart-bold" class="text-[#EAB308] text-lg"></iconify-icon>
        <iconify-icon icon="solar:gift-linear" class="text-[#EAB308] text-lg"></iconify-icon>
      </div>
      <div>
        <div class="text-2xl font-bold tracking-tight text-[#4A3219] leading-none">{site.company_name}</div>
        <div class="text-[10px] tracking-widest text-[#4A3219]/60 uppercase leading-tight">{site.company_sub}</div>
      </div>
    </a>

    <!-- Nav desktop -->
    <nav class="hidden md:flex items-center gap-6 text-sm font-medium text-[#4A3219]/70">
      <a href="/" class="hover:text-[#EAB308] transition-colors">Accueil</a>
      <a href="/services" class="hover:text-[#EAB308] transition-colors">Nos Créations</a>
      <a href="/a-propos" class="hover:text-[#EAB308] transition-colors">Notre Histoire</a>
      <a href="/contact" class="hover:text-[#EAB308] transition-colors">Contact</a>
    </nav>

    <!-- CTA desktop -->
    <div class="hidden md:flex items-center gap-3 shrink-0">
      <a href={"tel:" + site.phone}
         class="flex items-center gap-2 bg-[#FFF8E7] border border-[#EAB308]/40 text-[#4A3219] text-sm font-medium px-4 py-2 rounded-full hover:border-[#EAB308] transition-colors">
        <iconify-icon icon="solar:phone-linear" class="text-[#EAB308]"></iconify-icon>
        {site.phone}
      </a>
      <a href={"tel:" + site.phone}
         class="bg-[#EAB308] hover:bg-[#ca9b07] text-white text-sm font-semibold px-5 py-2 rounded-full transition-colors">
        APPELEZ MAINTENANT
      </a>
    </div>

    <!-- Burger mobile -->
    <button
      id="burger-btn"
      aria-label="Menu"
      class="md:hidden flex items-center justify-center w-10 h-10 rounded-full border border-[#4A3219]/20 text-[#4A3219]">
      <iconify-icon icon="solar:hamburger-menu-outline" class="text-xl"></iconify-icon>
    </button>
  </div>

  <!-- Menu mobile -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-[#4A3219]/10 bg-white px-4 py-4 flex flex-col gap-3">
    <a href="/" class="text-sm font-medium text-[#4A3219]/70 hover:text-[#EAB308] py-2 border-b border-[#4A3219]/5">Accueil</a>
    <a href="/services" class="text-sm font-medium text-[#4A3219]/70 hover:text-[#EAB308] py-2 border-b border-[#4A3219]/5">Nos Créations</a>
    <a href="/a-propos" class="text-sm font-medium text-[#4A3219]/70 hover:text-[#EAB308] py-2 border-b border-[#4A3219]/5">Notre Histoire</a>
    <a href="/contact" class="text-sm font-medium text-[#4A3219]/70 hover:text-[#EAB308] py-2 border-b border-[#4A3219]/5">Contact</a>
    <a href={"tel:" + site.phone}
       class="mt-2 flex items-center justify-center gap-2 bg-[#EAB308] hover:bg-[#ca9b07] text-white font-semibold px-5 py-3 rounded-full transition-colors">
      <iconify-icon icon="solar:phone-linear"></iconify-icon>
      Appelez maintenant
    </a>
  </div>
</header>

<script is:inline>
  // Burger toggle
  (function () {
    var btn = document.getElementById('burger-btn');
    var menu = document.getElementById('mobile-menu');
    if (!btn || !menu) return;
    btn.addEventListener('click', function () {
      menu.classList.toggle('hidden');
    });
  })();

  // Scroll glass effect
  (function () {
    var header = document.getElementById('site-header');
    if (!header) return;
    window.addEventListener('scroll', function () {
      if (window.scrollY > 60) {
        header.style.backdropFilter = 'blur(12px)';
        header.style.webkitBackdropFilter = 'blur(12px)';
        header.style.backgroundColor = 'rgba(255,255,255,0.92)';
      } else {
        header.style.backdropFilter = 'none';
        header.style.webkitBackdropFilter = 'none';
        header.style.backgroundColor = '#ffffff';
      }
    }, { passive: true });
  })();
</script>
