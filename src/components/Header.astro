---
import site from '../data/site.json';
---
<nav class="sticky top-0 z-50 bg-white border-b border-zinc-100 shadow-sm">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="font-bold text-lg text-zinc-900 tracking-tight">{site.company_name}</a>
    <div class="hidden md:flex items-center gap-8">
      <a href="/services" class="text-sm text-zinc-600 hover:text-zinc-900 transition-colors">Services</a>
      <a href="/a-propos" class="text-sm text-zinc-600 hover:text-zinc-900 transition-colors">À propos</a>
      <a href="/contact" class="text-sm text-zinc-600 hover:text-zinc-900 transition-colors">Contact</a>
    </div>
    <a href="/contact" class="bg-accent text-white text-sm font-medium rounded-lg px-4 py-2 hover:opacity-90 transition-opacity">
      {site.nav_cta}
    </a>
  </div>
</nav>

<script is:inline>
  (function() {
    var header = document.querySelector('header, nav[class*="fixed"]');
    if (!header) return;
    var alreadyGlass = getComputedStyle(header).backdropFilter !== 'none';
    window.addEventListener('scroll', function() {
      if (window.scrollY > 60) {
        header.style.backdropFilter = 'blur(12px)';
        header.style.webkitBackdropFilter = 'blur(12px)';
        if (!alreadyGlass) header.style.backgroundColor = header.style.backgroundColor || 'rgba(0,0,0,0.8)';
      } else {
        if (!alreadyGlass) {
          header.style.backdropFilter = 'none';
          header.style.webkitBackdropFilter = 'none';
        }
      }
    }, { passive: true });
  })();
</script>
