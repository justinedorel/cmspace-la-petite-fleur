---
import site from '../data/site.json';
---
<footer style="background:#1A1A1A;" class="py-16">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid md:grid-cols-3 gap-10 mb-12">
      <div>
        <p class="font-serif text-xl text-white font-light mb-1">{site.company_name}</p>
        <p class="font-sans text-sm text-white/40">{site.company_sub}</p>
        {(site as any).address && <p class="font-sans text-sm text-white/40 mt-2">{(site as any).address}</p>}
      </div>
      <div>
        <p class="font-sans text-xs text-white/30 uppercase tracking-widest mb-4">Navigation</p>
        <nav class="flex flex-col gap-3">
          <a href="/" class="font-sans text-sm text-white/60 hover:text-white transition-colors">Accueil</a>
          <a href="/services/" class="font-sans text-sm text-white/60 hover:text-white transition-colors">Soins</a>
          <a href="/a-propos/" class="font-sans text-sm text-white/60 hover:text-white transition-colors">À propos</a>
          <a href="/contact/" class="font-sans text-sm text-white/60 hover:text-white transition-colors">Contact</a>
        </nav>
      </div>
      <div>
        <p class="font-sans text-xs text-white/30 uppercase tracking-widest mb-4">Horaires</p>
        <p class="font-sans text-sm text-white/60 mb-1">{(site as any).hours_week}</p>
        <p class="font-sans text-sm text-white/60 mb-4">{(site as any).hours_sunday}</p>
        <a href={`mailto:${site.email}`} class="font-sans text-sm text-white/60 hover:text-white transition-colors">{site.email}</a>
      </div>
    </div>
    <div style="border-top:1px solid rgba(255,255,255,0.1);" class="pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="font-sans text-xs text-white/25">&copy; {new Date().getFullYear()} {site.company_name}. Tous droits réservés.</p>
      <a href="/mentions-legales/" class="font-sans text-xs text-white/25 hover:text-white/50 transition-colors">Mentions légales</a>
    </div>
  </div>
</footer>
