---
import site from '../data/site.json';
---
<footer class="bg-black py-16">
  <div class="max-w-7xl mx-auto px-8">
    <div class="grid md:grid-cols-3 gap-12 mb-14">
      <div>
        <p class="font-sans text-3xl font-light text-white tracking-[0.2em] mb-2">{site.company_name}</p>
        <p class="font-sans text-xs tracking-[0.18em] uppercase text-white/30">{site.company_sub}</p>
      </div>
      <div>
        <p class="font-sans text-xs tracking-[0.18em] uppercase text-white/30 mb-4">Navigation</p>
        <nav class="flex flex-col gap-3">
          <a href="/" class="font-sans text-sm font-light text-white/60 hover:text-white transition-colors tracking-wide">Accueil</a>
          <a href="/services" class="font-sans text-sm font-light text-white/60 hover:text-white transition-colors tracking-wide">Saveurs & Services</a>
          <a href="/a-propos" class="font-sans text-sm font-light text-white/60 hover:text-white transition-colors tracking-wide">À propos</a>
          <a href="/contact" class="font-sans text-sm font-light text-white/60 hover:text-white transition-colors tracking-wide">Contact</a>
        </nav>
      </div>
      <div>
        <p class="font-sans text-xs tracking-[0.18em] uppercase text-white/30 mb-4">Contact</p>
        <a href={`mailto:${site.email}`} class="font-sans text-sm font-light text-white/60 hover:text-white transition-colors tracking-wide block mb-4">{site.email}</a>
        <p class="font-sans text-xs tracking-[0.18em] uppercase text-white/30 mb-4 mt-6">Suivre</p>
        <div class="flex gap-5">
          {(site.social_instagram && site.social_instagram !== '') ? (
            <a href={site.social_instagram} class="text-white/40 hover:text-white/80 transition-colors">
              <span class="iconify" data-icon="lucide:instagram" data-width="18"></span>
            </a>
          ) : null}
          {(site.social_facebook && site.social_facebook !== '') ? (
            <a href={site.social_facebook} class="text-white/40 hover:text-white/80 transition-colors">
              <span class="iconify" data-icon="lucide:facebook" data-width="18"></span>
            </a>
          ) : null}
          {(site.social_linkedin && site.social_linkedin !== '') ? (
            <a href={site.social_linkedin} class="text-white/40 hover:text-white/80 transition-colors">
              <span class="iconify" data-icon="lucide:linkedin" data-width="18"></span>
            </a>
          ) : null}
        </div>
      </div>
    </div>
    <div class="border-t border-white/10 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="font-sans text-xs font-light text-white/25 tracking-wide">{site.footer_tagline}</p>
      <div class="flex items-center gap-6">
        <a href="/mentions-legales" class="font-sans text-xs text-white/20 hover:text-white/40 transition-colors tracking-[0.1em]">Mentions légales</a>
        <p class="font-sans text-xs text-white/20 tracking-[0.1em]">&copy; {new Date().getFullYear()} {site.company_name}</p>
      </div>
    </div>
  </div>
</footer>
