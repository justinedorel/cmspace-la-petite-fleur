---
import site from '../data/site.json';
---
<footer style="background-color:#1C1C1C;" class="py-16">
  <div class="max-w-6xl mx-auto px-6 md:px-8">
    <div class="grid md:grid-cols-3 gap-12 mb-12">

      <!-- Brand -->
      <div>
        <p class="font-display text-2xl font-medium text-white tracking-[0.12em] mb-2">{site.company_name}</p>
        <p class="font-body text-xs text-white/40 mb-4">{site.company_sub}</p>
        <p class="font-body text-sm text-white/50 leading-relaxed">{site.footer_tagline}</p>
      </div>

      <!-- Navigation -->
      <div>
        <p class="font-body text-xs tracking-[0.18em] uppercase text-white/30 mb-5">Navigation</p>
        <nav class="flex flex-col gap-3">
          <a href="/" class="font-body text-sm text-white/55 hover:text-white transition-colors">Accueil</a>
          <a href="/a-propos/" class="font-body text-sm text-white/55 hover:text-white transition-colors">Le Salon</a>
          <a href="/services/" class="font-body text-sm text-white/55 hover:text-white transition-colors">Services</a>
          <a href="/contact/" class="font-body text-sm text-white/55 hover:text-white transition-colors">Réserver</a>
        </nav>
      </div>

      <!-- Contact -->
      <div>
        <p class="font-body text-xs tracking-[0.18em] uppercase text-white/30 mb-5">Contact</p>
        <div class="space-y-2 mb-6">
          <a href={`mailto:${site.email}`} class="font-body text-sm text-white/55 hover:text-white transition-colors block">{site.email}</a>
          {(site as any).phone && <a href={`tel:${(site as any).phone}`} class="font-body text-sm text-white/55 hover:text-white transition-colors block">{(site as any).phone}</a>}
          <p class="font-body text-sm text-white/40">{site.address}</p>
        </div>
        <p class="font-body text-xs tracking-[0.18em] uppercase text-white/30 mb-3">Horaires</p>
        <p class="font-body text-sm text-white/40">{site.hours_week}</p>
        <p class="font-body text-sm text-white/40">{site.hours_sunday}</p>
        <div class="flex gap-4 mt-5">
          {(site.social_instagram && site.social_instagram !== '') ? (
            <a href={site.social_instagram} class="text-white/30 hover:text-white/70 transition-colors" aria-label="Instagram">
              <span class="iconify" data-icon="lucide:instagram" data-width="18"></span>
            </a>
          ) : null}
          {(site.social_facebook && site.social_facebook !== '') ? (
            <a href={site.social_facebook} class="text-white/30 hover:text-white/70 transition-colors" aria-label="Facebook">
              <span class="iconify" data-icon="lucide:facebook" data-width="18"></span>
            </a>
          ) : null}
        </div>
      </div>
    </div>

    <div class="border-t border-white/10 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="font-body text-xs text-white/20">&copy; {new Date().getFullYear()} {site.company_name}. Tous droits réservés.</p>
      <a href="/mentions-legales/" class="font-body text-xs text-white/20 hover:text-white/40 transition-colors">Mentions légales</a>
    </div>
  </div>
</footer>
