---
import site from '../data/site.json';
---
<footer class="bg-[#FFF8E7] border-t border-[#4A3219]/10 pt-14 pb-8">
  <div class="max-w-7xl mx-auto px-4 flex flex-col gap-10">

    <!-- Top row -->
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 shrink-0">
        <div class="grid grid-cols-2 gap-0.5 w-8 h-8">
          <iconify-icon icon="solar:star-bold" class="text-[#EAB308] text-base"></iconify-icon>
          <iconify-icon icon="solar:cup-hot-bold" class="text-[#EAB308] text-base"></iconify-icon>
          <iconify-icon icon="solar:heart-bold" class="text-[#EAB308] text-base"></iconify-icon>
          <iconify-icon icon="solar:gift-linear" class="text-[#EAB308] text-base"></iconify-icon>
        </div>
        <div>
          <div class="font-bold text-lg text-[#4A3219] leading-none">{site.company_name}</div>
          <div class="text-[10px] tracking-widest text-[#4A3219]/50 uppercase">{site.company_sub}</div>
        </div>
      </a>

      <!-- Nav -->
      <nav class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-[#4A3219]/60">
        <a href="/" class="hover:text-[#EAB308] transition-colors">Accueil</a>
        <a href="/a-propos" class="hover:text-[#EAB308] transition-colors">Notre Histoire</a>
        <a href="/services" class="hover:text-[#EAB308] transition-colors">Nos Créations</a>
        <a href="/contact" class="hover:text-[#EAB308] transition-colors">Contact</a>
        <a href="/mentions-legales" class="hover:text-[#EAB308] transition-colors">Mentions légales</a>
      </nav>

      <!-- Réseaux sociaux -->
      <div class="flex items-center gap-3">
        {site.social_facebook && (
          <a href={site.social_facebook}
             class="w-9 h-9 flex items-center justify-center rounded-full bg-white border border-[#4A3219]/10 text-[#4A3219]/50 hover:text-[#EAB308] hover:border-[#EAB308] transition-colors"
             aria-label="Facebook">
            <iconify-icon icon="mdi:facebook"></iconify-icon>
          </a>
        )}
        {site.social_instagram && (
          <a href={site.social_instagram}
             class="w-9 h-9 flex items-center justify-center rounded-full bg-white border border-[#4A3219]/10 text-[#4A3219]/50 hover:text-[#EAB308] hover:border-[#EAB308] transition-colors"
             aria-label="Instagram">
            <iconify-icon icon="mdi:instagram"></iconify-icon>
          </a>
        )}
        <a href={"https://wa.me/" + site.phone.replace(/\s+/g, '').replace('+', '')}
           class="w-9 h-9 flex items-center justify-center rounded-full bg-white border border-[#4A3219]/10 text-[#4A3219]/50 hover:text-[#EAB308] hover:border-[#EAB308] transition-colors"
           aria-label="WhatsApp">
          <iconify-icon icon="mdi:whatsapp"></iconify-icon>
        </a>
      </div>
    </div>

    <!-- Contact rapide -->
    <div class="grid sm:grid-cols-3 gap-4">
      <a href={"tel:" + site.phone}
         class="flex items-center gap-3 bg-white rounded-2xl p-4 border border-[#EAB308]/20 hover:border-[#EAB308] transition-colors">
        <iconify-icon icon="solar:phone-linear" class="text-[#EAB308] text-xl shrink-0"></iconify-icon>
        <span class="text-sm text-[#4A3219]/70">{site.phone}</span>
      </a>
      <a href={"mailto:" + site.email}
         class="flex items-center gap-3 bg-white rounded-2xl p-4 border border-[#EAB308]/20 hover:border-[#EAB308] transition-colors">
        <iconify-icon icon="solar:letter-linear" class="text-[#EAB308] text-xl shrink-0"></iconify-icon>
        <span class="text-sm text-[#4A3219]/70 truncate">{site.email}</span>
      </a>
      <div class="flex items-center gap-3 bg-white rounded-2xl p-4 border border-[#EAB308]/20">
        <iconify-icon icon="solar:map-point-linear" class="text-[#EAB308] text-xl shrink-0"></iconify-icon>
        <span class="text-sm text-[#4A3219]/70">{site.address}</span>
      </div>
    </div>

    <!-- Copyright -->
    <div class="border-t border-[#4A3219]/10 pt-6 text-center text-xs text-[#4A3219]/40">
      &copy; {new Date().getFullYear()} <strong class="text-[#4A3219]/60">{site.company_name}</strong> — {site.company_sub}. Tous droits réservés.
    </div>
  </div>
</footer>
