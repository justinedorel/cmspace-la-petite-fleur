---
import site from '../data/site.json';
---
<footer class="bg-[#1C2B1C] text-[#E8D5A3]/70 py-12">
  <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-6">
    <div>
      <p class="font-display text-[#E8D5A3] font-semibold text-lg mb-1">{site.company_name}</p>
      <p class="text-sm">{site.address}</p>
    </div>
    <nav class="flex items-center gap-6 text-sm">
      <a href="/services/" class="hover:text-[#E8D5A3] transition-colors">Nos Produits</a>
      <a href="/a-propos/" class="hover:text-[#E8D5A3] transition-colors">À propos</a>
      <a href="/contact/" class="hover:text-[#E8D5A3] transition-colors">Contact</a>
      <a href="/mentions-legales/" class="hover:text-[#E8D5A3] transition-colors">Mentions légales</a>
    </nav>
    <p class="text-xs text-[#E8D5A3]/40">© {new Date().getFullYear()} {site.company_name}</p>
  </div>
</footer>
