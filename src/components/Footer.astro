---
import site from '../data/site.json';
const socials = [
  { key: 'instagram', url: site.social_instagram, label: 'Instagram' },
  { key: 'facebook', url: site.social_facebook, label: 'Facebook' },
  { key: 'linkedin', url: site.social_linkedin, label: 'LinkedIn' },
].filter(s => s.url);
---
<footer style="background:var(--colorPrimary);color:#fff;padding:3rem 0 1.5rem;">
  <div class="container">
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:3rem;margin-bottom:2rem;">
      <div>
        <div style="font-family:var(--fontHeading);font-size:1.25rem;font-weight:700;margin-bottom:0.75rem;">
          {site.company_name}
        </div>
        <p style="font-size:0.9rem;opacity:0.75;line-height:1.6;">{site.footer_tagline}</p>
      </div>
      <div>
        <div style="font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;opacity:0.5;margin-bottom:1rem;">Navigation</div>
        <div style="display:flex;flex-direction:column;gap:0.5rem;">
          <a href="/" style="font-size:0.9rem;opacity:0.8;hover:opacity:1;">Accueil</a>
          <a href="/services" style="font-size:0.9rem;opacity:0.8;">Services</a>
          <a href="/a-propos" style="font-size:0.9rem;opacity:0.8;">À propos</a>
          <a href="/contact" style="font-size:0.9rem;opacity:0.8;">Contact</a>
        </div>
      </div>
      <div>
        <div style="font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;opacity:0.5;margin-bottom:1rem;">Contact</div>
        <div style="display:flex;flex-direction:column;gap:0.5rem;font-size:0.9rem;opacity:0.8;">
          {site.email && <span>{site.email}</span>}
          {site.phone && <span>{site.phone}</span>}
          {site.city && <span>{site.city}</span>}
        </div>
        {socials.length > 0 && (
          <div style="display:flex;gap:1rem;margin-top:1rem;">
            {socials.map(s => (
              <a href={s.url} target="_blank" rel="noopener" style="font-size:0.85rem;opacity:0.75;">{s.label}</a>
            ))}
          </div>
        )}
      </div>
    </div>
    <div style="border-top:1px solid rgba(255,255,255,0.15);padding-top:1.5rem;display:flex;justify-content:space-between;align-items:center;font-size:0.8rem;opacity:0.5;">
      <span>© {new Date().getFullYear()} {site.company_name}. {site.footer_legal}</span>
      <a href="/mentions-legales" style="opacity:0.7;">Mentions légales</a>
    </div>
  </div>
</footer>
