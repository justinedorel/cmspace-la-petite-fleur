---
import site from '../data/site.json';
const colServices = [
  ['Comptabilité & Gestion', '/services/'],
  ['Fiscalité', '/services/'],
  ['Conseil financier', '/services/'],
  ['Création d\'entreprise', '/services/'],
];
const colCabinet = [
  ['À propos', '/a-propos/'],
  ['Notre équipe', '/a-propos/'],
  ['Contact', '/contact/'],
  ['Prendre rendez-vous', '/contact/'],
];
const colLegal = [
  ['Mentions légales', '/mentions-legales/'],
];
---
<footer class="bg-[#050A14] border-t border-white/[0.06] pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">
      <div>
        <div class="flex items-center gap-3 mb-4">
          <span class="w-9 h-9 rounded-lg bg-[var(--color-accent)] flex items-center justify-center">
            <iconify-icon icon="solar:calculator-minimalistic-bold" class="text-lg text-white"></iconify-icon>
          </span>
          <span class="leading-tight">
            <span class="block text-base font-bold text-white tracking-tight">{site.company_name}<span class="text-[var(--color-accent2)]">.</span></span>
            <span class="block text-[9px] font-semibold tracking-[0.2em] text-[var(--color-muted)]">{site.company_sub}</span>
          </span>
        </div>
        <p class="text-sm text-[var(--color-muted)] leading-relaxed mb-5">{site.tagline}</p>
        <div class="flex gap-3">
          <a href="https://www.linkedin.com" target="_blank" rel="noopener" aria-label="LinkedIn" class="w-9 h-9 rounded-full bg-white/[0.06] border border-white/[0.06] flex items-center justify-center text-[var(--color-muted)] hover:text-white hover:border-[var(--color-accent)] transition-all">
            <iconify-icon icon="solar:link-circle-linear" class="text-base"></iconify-icon>
          </a>
          <a href={`mailto:${site.email}`} aria-label="Email" class="w-9 h-9 rounded-full bg-white/[0.06] border border-white/[0.06] flex items-center justify-center text-[var(--color-muted)] hover:text-white hover:border-[var(--color-accent)] transition-all">
            <iconify-icon icon="solar:letter-linear" class="text-base"></iconify-icon>
          </a>
        </div>
      </div>
      <div>
        <div class="text-xs font-semibold uppercase tracking-widest text-white/40 mb-4">Services</div>
        <ul class="space-y-2.5">
          {colServices.map(([l, h]) => (
            <li><a href={h} class="text-sm text-[var(--color-muted)] hover:text-white transition-colors">{l}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <div class="text-xs font-semibold uppercase tracking-widest text-white/40 mb-4">Cabinet</div>
        <ul class="space-y-2.5">
          {colCabinet.map(([l, h]) => (
            <li><a href={h} class="text-sm text-[var(--color-muted)] hover:text-white transition-colors">{l}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <div class="text-xs font-semibold uppercase tracking-widest text-white/40 mb-4">Légal</div>
        <ul class="space-y-2.5">
          {colLegal.map(([l, h]) => (
            <li><a href={h} class="text-sm text-[var(--color-muted)] hover:text-white transition-colors">{l}</a></li>
          ))}
          <li class="text-sm text-[var(--color-muted)]">{site.address}</li>
          <li><a href={`tel:${site.phone}`} class="text-sm text-[var(--color-muted)] hover:text-white transition-colors">{site.phone}</a></li>
        </ul>
      </div>
    </div>
    <div class="border-t border-white/[0.06] pt-6 flex flex-col md:flex-row justify-between items-center gap-2 text-xs text-white/30">
      <span>© {new Date().getFullYear()} {site.legal_name}. Tous droits réservés.</span>
      <span>Expert-comptable inscrit à l'Ordre des Experts-Comptables — Région Paris Île-de-France</span>
    </div>
  </div>
</footer>
